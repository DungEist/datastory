        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'You know that I\\'m not directing you to \"find\" her.', 4: '2'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'But instead, I need you to remind her of her duty as an agent of the network. Don\\'t \"save\" people to her own whims.', 4: '2'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
