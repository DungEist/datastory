        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Roland', 3: 'But with me, Miss Luna? I\\'m afraid a person of your stature might be required for her to listen.', 4: '1'}"
    },
    {
