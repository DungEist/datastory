        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Roland', 3: 'Disregarding one\\'s duties as an agent, with no heed to the aptitude of the target, \"saving\" people with the power of Asc-net to one\\'s whims...', 4: '1'}"
