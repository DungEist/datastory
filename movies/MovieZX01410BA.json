        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'I can\\'t tell what they were thinking either, but I\\'m afraid it\\'s true. Derek\\'s voice is specifically designed to resonate with the frequency of humanoid-hybrid M.I.N.D.s.', 4: '2'}"
    },
