        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'How can I calm down at a time like this? Do you know how dire the situation is? What on earth is the code to control Amberia?!', 4: '1'}"
