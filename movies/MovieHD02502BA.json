        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'I\\'ve heard of WGAA artists getting discouraged by creative blocks. Now I understand how they feel.', 4: '1', 18: '100002136'}"
