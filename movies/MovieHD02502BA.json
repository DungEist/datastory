        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'But what\\'s missing here...? Argh, I don\\'t know.', 4: '1', 18: '100002135'}"
