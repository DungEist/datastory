        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'That\\'s why I hate learning things through data transfer. It never feels like mine.', 4: '1', 18: '100002134'}"
