        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Lucia', 3: 'Commandant, you\\'re here.', 4: '1'}"
    },
    {
        "Id": 5,
        "ActionId": 133,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Kept you waiting?', 3: '5', 4: 'When did you get here?', 5: '6'}"
    },
    {
        "Id": 6,
        "ActionId": 5,
        "NextActionId": 7,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'No. I don\\'t mind waiting if it\\'s you.', 4: '1'}"
    },
    {
        "Id": 7,
        "ActionId": 6,
        "NextActionId": 7,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'A few hours ago. I didn\\'t know when you would arrive, so I came early, just in case.', 4: '1'}"
    },
    {
        "Id": 8,
        "ActionId": 7,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'But enough about that. Let\\'s return to our date. The reason I\\'ve invited you here is because my recovery has reached an end.', 4: '1'}"
    },
    {
        "Id": 9,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Through exhaustive reviews of prior files, I\\'ve ascertained the kind of person I am, and what I must do.', 4: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 134,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'And what kind of person is that?', 3: '9', 4: 'What must you do?', 5: '10'}"
    },
    {
        "Id": 11,
        "ActionId": 9,
        "NextActionId": 11,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'A fairly playful girl, Commandant.', 4: '1'}"
    },
    {
        "Id": 12,
        "ActionId": 10,
        "NextActionId": 11,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'The thing I\\'m about to do.', 4: '1'}"
    },
    {
        "Id": 13,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Sit down next to me first. I prepared a sumptuous meal for you.', 4: '1'}"
    },
    {
        "Id": 14,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Halfway through the sentence, Lucia seems to change into a different person. Her voice lightens, and her smile turns softer than usual.'}"
    },
    {
        "Id": 15,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Strange, isn\\'t it? You won\\'t see this side of me often. Relaxing moments like these are hard to come by, after all.', 4: '1'}"
    },
    {
        "Id": 16,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'At Lucia\\'s insistence, you take the utensils and sit down on a mat draped on the coarse ground.'}"
    },
    {
        "Id": 17,
        "ActionId": 132,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'You made this, Lucia?', 3: '15', 4: '(Eat death)', 5: '16'}"
    },
    {
        "Id": 18,
        "ActionId": 15,
        "NextActionId": 17,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: '...As much as I would like to say \"yes\", I left it up to the support staff, in the interest of your health.', 4: '1'}"
    },
    {
        "Id": 19,
        "ActionId": 16,
        "NextActionId": 17,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'It should be good. I didn\\'t get to taste-test, but I trust the chefs.', 4: '1'}"
    },
    {
        "Id": 20,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'While you eat, you listen to Lucia talk at length about current events.'}"
    },
    {
        "Id": 21,
        "ActionId": 18,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Once, you were worried about her turning into a different person after the procedure. But from her words and actions, the new Lucia is simply a little more \"playful.\"'}"
    },
    {
        "Id": 22,
        "ActionId": 19,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: '...', 4: '1'}"
    },
    {
        "Id": 23,
        "ActionId": 20,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'As the moon rises high, Lucia suddenly goes quiet, her eyes closing as if in prayer.'}"
    },
    {
        "Id": 24,
        "ActionId": 121,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'What are you doing?', 3: '21', 4: 'Are you tired?', 5: '22'}"
    },
    {
        "Id": 25,
        "ActionId": 21,
        "NextActionId": 200,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'I\\'m summoning the aliens, Commandant. Want to join in?', 4: '1'}"
    },
    {
        "Id": 26,
        "ActionId": 22,
        "NextActionId": 200,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'No, I\\'m just trying to summon aliens. With telepathy.', 4: '1'}"
    },
    {
        "Id": 27,
        "ActionId": 200,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Aliens?', 3: '520'}"
    },
    {
        "Id": 28,
        "ActionId": 520,
        "NextActionId": null,
        "Type": 401,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '207'}"
    },
    {
        "Id": 29,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Mh-hm. I mean, extraterrestrial cultures...', 4: '1'}"
    },
    {
        "Id": 30,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'My records indicate that you once had a conversation with Qu, the leader of Kowloong.', 4: '1'}"
    },
    {
        "Id": 31,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'She once said that Tabula Akasha was all about leaving traces of humanity behind, letting \"travelers\" know we were once here... I think by \"travelers\", she must have meant aliens.', 4: '1'}"
    },
    {
        "Id": 32,
        "ActionId": 26,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'I may not be a big fan of this plan, but I do think it\\'s amazing that there might be other cultures, other beings, out there.', 4: '1'}"
    },
    {
        "Id": 33,
        "ActionId": 27,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Don\\'t you think so too, Commandant? If \"others\" really do exist in the universe, what would they look like?', 4: '1'}"
    },
    {
        "Id": 34,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'But no matter what they look like, if they can reach us through the void of space, that would mean that their technology far outstrips ours...', 4: '1'}"
    },
    {
        "Id": 35,
        "ActionId": 29,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'If that\\'s the case, they may have a way of stopping, maybe even eradicating the Punishing Virus.', 4: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 223,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'That would be nice.', 3: '30', 4: 'Maybe even they can\\'t do it.', 5: '31'}"
    },
    {
        "Id": 37,
        "ActionId": 30,
        "NextActionId": 32,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Yes, indeed it would be.', 4: '1'}"
    },
    {
        "Id": 38,
        "ActionId": 31,
        "NextActionId": 32,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: '...Then that would be catastrophic. Aliens infected with the Punishing Virus would be no joke.', 4: '1'}"
    },
    {
        "Id": 39,
        "ActionId": 32,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'But aliens are probably just wishful thinking, both for Qu and for us...', 4: '1'}"
    },
    {
        "Id": 40,
        "ActionId": 231243,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '6'}"
    },
    {
        "Id": 41,
        "ActionId": 33,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'If you want something, you have to reach for it. Fight for it. For me, for you, for all of us.', 4: '1'}"
    },
    {
        "Id": 42,
        "ActionId": 34,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You suddenly feel Lucia\\'s embrace from behind.'}"
    },
    {
        "Id": 43,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Though I may never be myself again, I think this is how \"Lucia\" expresses her emotions.', 4: '1'}"
    },
    {
        "Id": 44,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": 1,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'So, just like this... let me be with you, Commandant.', 4: '1'}"
    }
]