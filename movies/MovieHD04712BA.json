        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'In the next instant, his cue moves like an arrow loosed from a bow, striking the cue ball with a crisp, clean sound. It rolls forward with perfect speed and hits the orange ball near the pocket.'}"
    },
    {
        "Id": 19,
