        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Chrome', 3: 'I\\'m just the only one nearby who knows how to play. There are plenty of better players in Babylonia.', 4: '1'}"
    },
    {
        "Id": 26,
        "ActionId": 26,
