        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Every shot after that, Chrome calculates the angles, the force, and the cue ball\\'s path with precision. Each ball moves as if it follows his command, gliding gracefully across the table.'}"
    },
    {
        "Id": 51,
        "ActionId": 51,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'His skill isn\\'t just in landing the shot—it\\'s in controlling the entire game.'}"
    },
