        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'But knowing the game did give me the chance to do this with you. I\\'d say that counts as a new experience.', 4: '1'}"
