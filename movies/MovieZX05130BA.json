        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Those couldn\\'t be just dreams.'}"
    },
    {
        "Id": 59,
        "ActionId": 59,
