        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The M.I.N.D. can\\'t fabricate something so detailed.'}"
    },
    {
        "Id": 60,
        "ActionId": 60,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The development of the Hyperreal frame was just completed. There\\'s no way I could dream in such detail about its specific battle capabilities. My new frame is still just a blueprint—even its appearance remains classified...'}"
    },
    {
        "Id": 61,
        "ActionId": 61,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'I couldn\\'t possibly visualize such detailed things that \"don\\'t exist\".'}"
    },
