        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Bianca', 3: 'I don\\'t know how to work with a commandant like you.', 4: '1'}"
    },
    {
        "Id": 5,
        "ActionId": 4,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Huh?', 3: '5', 4: 'What were the commandants you worked with like?', 5: '6'}"
    },
    {
        "Id": 6,
        "ActionId": 5,
        "NextActionId": 8,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'I\\'m sorry. That came out of nowhere.', 4: '1'}"
    },
    {
        "Id": 7,
        "ActionId": 6,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'Having a stronger sense of rank and station, keeping the relationship between superiors and subordinates professional. The kind Karenina despises.', 4: '1'}"
    },
    {
        "Id": 8,
        "ActionId": 7,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'But I believe that respecting the hierarchy of our station is also instrumental to our success.', 4: '1'}"
    },
    {
        "Id": 9,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'To put it simply, I hope that you would treat us more like tools in the future, Commandant.', 4: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'Of course, you\\'re free to treat the Gray Ravens how you have always treated them. But as for me...', 4: '1'}"
    },
    {
        "Id": 11,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'You\\'re part of Gray Raven now.', 3: '11', 4: 'Doesn\\'t it make you uncomfortable to be treated as a tool?', 5: '12'}"
    },
    {
        "Id": 12,
        "ActionId": 11,
        "NextActionId": 13,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'More like a liaison than a member, I would say. I still belong to the Purifying Force on the system files.', 4: '1'}"
    },
    {
        "Id": 13,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'I will handle my feelings. You don\\'t have to worry about that.', 4: '1'}"
    },
    {
        "Id": 14,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'Your recent showings of intimacy, like the gifts you offered me, have caught me off guard.', 4: '1'}"
    },
    {
        "Id": 15,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'I don\\'t think I can reciprocate the way you were hoping for like how Liv or Nanami could.', 4: '1'}"
    },
    {
        "Id": 16,
        "ActionId": 15,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": 1,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'So I\\'d advise you against spending time on me.', 4: '1'}"
    }
