        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Judging from what we saw earlier, there may also be mechanoids similar to the \"defects\" here.', 4: '2'}"
    },
