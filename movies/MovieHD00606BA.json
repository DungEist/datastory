        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'But they keep moving toward somewhere deeper inside... as if they have found something.', 4: '1'}"
    },
    {
