        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Atiel', 3: 'Oh, you haven\\'t heard? 【kuroname】 was the top graduate of their year in commandant school. That\\'s why Simon and his peers call 【kuroname】 boss.', 4: '2'}"
    },
