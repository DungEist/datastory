        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Atiel', 3: 'My name is Atiel. Our original team is still recovering from their injuries, so it\\'s just us. We sure are happy to see you, Boss!', 4: '2'}"
    },
    {
        "Id": 42,
        "ActionId": 32,
