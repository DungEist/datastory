        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Simon', 3: 'The name\\'s Simon, Commandant Simon. I was sent here to lead troops just like you, Boss... Sorry, I\\'m a little motion sick.', 4: '1'}"
    },
    {
        "Id": 47,
        "ActionId": 36,
