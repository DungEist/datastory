        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Noticing your gaze, Rosetta turns her head and looks over with a puzzled expression.'}"
    },
    {
        "Id": 9,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'What happened to your centaur module?', 3: '9', 4: 'Your light wings look nice.', 5: '3000'}"
    },
    {
        "Id": 10,
        "ActionId": 9,
        "NextActionId": 10,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'The centaur module... You Babylonia people sure like asking about that... Quite the opposite for the ARU.', 4: '1'}"
    },
    {
        "Id": 11,
        "ActionId": 10,
        "NextActionId": 11,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'I don\\'t know the details, but that Asimov guy said Babylonia can\\'t help with centaur modules.', 4: '1'}"
    },
    {
        "Id": 12,
        "ActionId": 11,
        "NextActionId": 14,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'Instead, they gave me this specially upgraded spear and shield. Just as effective though.', 4: '1'}"
    },
    {
        "Id": 13,
        "ActionId": 3000,
        "NextActionId": 12,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
