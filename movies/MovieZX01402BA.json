        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'During his self-introduction, Simon held his head down as if in discomfort, while Atiel was like an overexcited bunny regarding you curiously.'}"
    },
    {
        "Id": 48,
        "ActionId": 1009,
        "NextActionId": null,
