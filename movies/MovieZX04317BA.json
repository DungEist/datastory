        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Teddy', 3: 'The code for Gestalt\\'s foundational database has been lost in the chaos for a long time, so I can\\'t gauge how bad the potential damage might be.', 4: '2'}"
    },
    {
