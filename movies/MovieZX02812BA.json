        "EndDelay": null,
        "Params": "{1: '1', 2: '500494', 3: '7', 6: '-150'}"
    },
    {
        "Id": 69,
        "ActionId": 69,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 3: 'Shocked, Karenina looks at the ground under her feet and sees a ripple-like effect on it. But she knows it isn\\'t an illusion, nor is the ground really turning soft. The gravitational waves have distorted the light nearby.'}"
    },
    {
        "Id": 70,
        "ActionId": 70,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The Corrupted touched by the gravitational waves are either slammed into the ground or launched upward into space. Some are even torn apart mid-air by opposing gravitational forces.'}"
    },
    {
        "Id": 71,
        "ActionId": 71,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
