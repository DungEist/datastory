        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rebecca', 3: 'Liszt, the executive meeting of the World Government will commence in half an hour. You will be participating as a councilman from the Diplomatic Court. Have you got the topic ready?', 4: '2'}"
