        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Knowing she will never win the argument with this man, Rebecca diverts her attention to the other two in the meeting room.'}"
