        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "RImgBg1Shake",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'But the Corrupted never attacks... or cannot attack, to be precise. It is held up in the air for a few seconds, then suddenly gets slammed into the wall of the reactor room, leaving a crack in the wall.'}"
    },
    {
        "Id": 68,
        "ActionId": 68,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
