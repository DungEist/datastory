    {
        "Id": 77,
        "ActionId": 77,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Karenina immediately leaps back, trying to get out of the impacted area. The pencil in her chest accidentally falls out. The moment it touches the gravitational waves, it is shredded into wood dust in a split second.'}"
    },
    {
        "Id": 78,
        "ActionId": 78,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'The zero-point engine...!', 4: '1'}"
    },
    {
        "Id": 79,
        "ActionId": 79,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Karenina can only think of one possible explanation: at least one control center linking to the reactor array has been infected by the Punishing Virus, pumping more than the required energy into the zero-point engine and causing out-of-control gravitational impact.'}"
    },
    {
        "Id": 80,
        "ActionId": 80,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'If the zero-point engine continues to run like this...'}"
    },
    {
        "Id": 81,
        "ActionId": 81,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'The Punishing Virus will be the last thing I need to worry about. The entire lunar base could be destroyed...', 4: '1'}"
    },
    {
        "Id": 82,
        "ActionId": 82,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The zero-point reactor itself has been reinforced and buried deep underground. Everything around it will probably be wiped out... After all, this miraculous engine is capable of sending the entire Babylonia across space.'}"
    },
    {
        "Id": 83,
        "ActionId": 83,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'This must be stopped!', 4: '1'}"
    },
    {
        "Id": 84,
        "ActionId": 84,
        "NextActionId": null,
        "Type": 202,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 6: '1'}"
    },
    {
        "Id": 85,
        "ActionId": 85,
        "NextActionId": null,
        "Type": 101,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Assets/Product/Texture/Image/BgStory/BgStory586.jpg'}"
    },
    {
        "Id": 86,
        "ActionId": 86,
