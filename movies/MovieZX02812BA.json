        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Collins', 3: 'You really have wronged me. You know, I never liked to break the rules. It\\'s just that... sometimes the cost of breaking the rules is too low.', 4: '1'}"
    },
    {
