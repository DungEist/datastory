        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'They gave their lives to protect you. In other words, they placed your life above theirs. Are you going to insult their dedication?', 4: '2'}"
