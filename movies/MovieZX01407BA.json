        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'What\\'s the point? It\\'s not like you can do anything about it. This will just be like the previous tides, it\\'ll come to an end soon... Ah...', 4: '2'}"
