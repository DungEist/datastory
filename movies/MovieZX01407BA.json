        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Simon', 3: 'A code... So some kind of preset authentication?', 4: '1'}"
    },
    {
        "Id": 52,
        "ActionId": 41,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'Something like that... Anyway, the leaders in control of the code put Amberia into a deep sleep. They then sealed her and the bionics away somewhere in this tundra.', 4: '2'}"
    },
    {
        "Id": 53,
        "ActionId": 42,
