        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Diana', 3: 'Tell me, Captain. Why did you try to cover it up? Where is she now? How can you tolerate this?!', 4: '1'}"
    },
    {
        "Id": 38,
        "ActionId": 29,
        "NextActionId": null,
