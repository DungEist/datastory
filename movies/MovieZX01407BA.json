        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'I REALLY DON\\'T! All I heard from the previous captain was that Amberia\\'s nightmares are what\\'s controlling the tide.', 4: '2'}"
    },
    {
        "Id": 57,
