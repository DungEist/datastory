        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'There won\\'t be no \"tragedy.\" We easily snuffed out the last tide, and we\\'ll do it again this time... Ah...', 4: '2'}"
