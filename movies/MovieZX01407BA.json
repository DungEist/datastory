        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Diana let out her anger in a rare sight of rage, proving the significance of her name to the Forest Guard.'}"
