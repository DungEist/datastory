        "ActionId": 35,
        "NextActionId": 36,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'I wasn\\'t trying to! But who\\'d believe me? And you know what happens to traitors!', 4: '2'}"
    },
    {
        "Id": 46,
        "ActionId": 36,
        "NextActionId": 37,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'Not to mention, if I were to tell everyone that Amberia was still alive, the ARU would delve into chaos. If we ran into any trouble during so, we\\'d all...', 4: '2'}"
    },
    {
        "Id": 47,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: '...Oh, forget it! I don\\'t care anymore! You wanna know the truth, I\\'ll tell you truth! But you better not tell anyone else!', 4: '2'}"
    },
    {
        "Id": 48,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
