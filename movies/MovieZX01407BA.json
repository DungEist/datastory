        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'That\\'s what should be the case this time round as well. The bionics also mentioned Amberia, yeah?', 4: '2'}"
