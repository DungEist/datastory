        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'With a smile that\\'s still more radiant than the gold of the wheat fields, the girl opens her mouth to speak.'}"
    },
    {
