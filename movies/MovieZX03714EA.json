        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Oakley', 3: 'Well, I\\'m afraid that\\'s what\\'s going to happen soon if you don\\'t quit smoking.', 4: '1'}"
    },
