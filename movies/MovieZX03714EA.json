        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Max', 3: 'Oakley, why are you...?', 4: '2'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Oakley', 3: 'Get yourself together already. Remember what I said? Death takes everything away from you, and I\\'m nothing but part of your dream.', 4: '1'}"
    },
    {
        "Id": 20,
        "ActionId": 20,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Max', 3: 'R-right... Oakley is dead... and she\\'s not coming back...', 4: '2'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Oakley', 3: 'But look at you... you\\'re still alive, no?', 4: '1'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Oakley puts her hand over Max\\'s chest. She can feel his heartbeat.'}"
    },
    {
