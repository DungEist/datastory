        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Max isn\\'t quite sure what just happened, but he thinks he just saw Oakley—whom he\\'s seen countless times in his dreams—flip the bird at him.'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
