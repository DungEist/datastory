        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Max', 3: 'You\\'re right... Guess it isn\\'t time for our paths to cross again just yet.', 4: '2'}"
    },
    {
        "Id": 27,
        "ActionId": 27,
        "NextActionId": null,
