        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Max', 3: 'Haha... well, I suppose I\\'ll stick around just a while longer to help them out, then.', 4: '2'}"
