        "ActionId": 72,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Yup.', 3: '73'}"
    },
    {
        "Id": 72,
        "ActionId": 73,
