        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Because you\\'re our distinguished guest from Kowloong, Qu.', 3: '75', 4: 'Because I\\'m your companion.', 5: '77'}"
    },
    {
        "Id": 74,
        "ActionId": 75,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'Is that what\\'s making you nervous?', 4: '1'}"
    },
    {
        "Id": 75,
        "ActionId": 76,
        "NextActionId": 79,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'But don\\'t sweat it, because I\\'m not here representing Kowloong.', 4: '1'}"
    },
    {
        "Id": 76,
        "ActionId": 77,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'That\\'s straightforward of it.', 4: '1'}"
    },
    {
        "Id": 77,
        "ActionId": 78,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'I\\'m glad you\\'re aware of that, though.', 4: '1'}"
    },
    {
        "Id": 78,
        "ActionId": 79,
        "NextActionId": null,
        "Type": 202,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
