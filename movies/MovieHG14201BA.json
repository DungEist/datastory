        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'So I heard you were a Chief at F.O.S.? Guess they totally overestimated you there.', 4: '1'}"
    },
    {
        "Id": 68,
        "ActionId": 69,
        "NextActionId": null,
