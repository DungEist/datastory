        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'The first thing you checked on was me and not the aircraft itself right after that turbulence just now.', 4: '1'}"
    },
