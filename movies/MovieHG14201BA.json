        "ActionId": 9,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'I believe humanity will be able to escape the threat of the Punishing if we can go from orbital transport to interstellar travel in terms of our navigation technology—and when that happens, both the residents of Babylonia and Kowloong would benefit from it.', 4: '1'}"
    },
    {
