        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'At this moment, looking out the porthole, one could see the beautiful and fragile outline of the blue planet.'}"
    },
    {
