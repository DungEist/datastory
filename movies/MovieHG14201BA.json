        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'It was clear from the letter that he had to put in a lot of effort writing it from his sickbed.', 4: '1'}"
