        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'With the drastic change in pressure and temperature, the small transport craft from Babylonia experiences brief tremors. Time and again, the passengers sitting in the aircraft can feel the jolts coming into the cabin through the anti-shock structure.'}"
    },
    {
        "Id": 5,
        "ActionId": 6,
