        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '???', 3: '...Time is precisely what I lack. It can forge a lion cub into a king, and just as easily grind a king to dust. Even the mightiest cannot defy its passage.', 4: '18'}"
    },
    {
        "Id": 56,
        "ActionId": 56,
        "NextActionId": null,
        "Type": 202,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
