        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Zack', 3: 'I never thought to hear an Ascendant speak with such reverence for life.'}"
    },
    {
        "Id": 58,
        "ActionId": 58,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '18', 2: '501445', 3: '4', 4: '315', 5: '-255', 6: '-400'}"
    },
