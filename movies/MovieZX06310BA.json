        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rumyantsev', 3: 'Yet we cannot afford to underestimate Babylonia. Ha! This stalemate... it reminds me of my tactical studies in Kowloong.', 4: '2'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
