        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '???', 3: 'Anyone can boast. But those rising humans... now they are fascinating. Especially that Gray Raven Commandant.', 4: '18'}"
