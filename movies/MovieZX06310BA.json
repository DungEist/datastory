        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '???', 3: 'The battlefield is yours to manage. But my patience wears thin. Is the black box data still not ready?', 4: '18'}"
    },
    {
