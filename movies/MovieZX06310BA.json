        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Zack', 3: 'We may lose a pod of bionic whales, but our strength is not diminished. Besides... they are useless in the enemy\\'s hands.'}"
    },
