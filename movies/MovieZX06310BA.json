        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '???', 3: 'We share an acquaintance. Having seen that commandant today... I am intrigued. Frostheart Emperor, instruct your men to take care. Do not kill that one.', 4: '18'}"
    },
