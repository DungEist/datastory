        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Fyodor', 3: 'Except for the main gates, the city remains in our grasp.', 4: '1'}"
    },
    {
        "Id": 8,
