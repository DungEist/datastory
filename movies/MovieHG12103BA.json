        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Unable to see clearly in the darkness, you walk in the direction of the faint light from the terminal.'}"
    },
    {
        "Id": 14,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"...Step by step, the lemming approaches the seemingly fertile meadow. The white wolf cub huddles behind a nearby stone, awaiting the opportunity to pounce.\"'}"
    },
    {
        "Id": 15,
        "ActionId": 15,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Walking around a series of messy tables and chairs, you arrive at the source of the sound.'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It\\'s a small space made of supply crates and tables. An old audio-visual terminal is laying on the ground in the center of the space, playing a popular nature documentary from the Golden Age.'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Although this is the source of the sound echoing in the room, the figure you had just seen is now gone.'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You can\\'t help but lower your gaze at the content playing on the audio-visual terminal. Who put it here?'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"The white wolf waits quietly for the lemming to approach, every muscle ready to pounce.\"'}"
