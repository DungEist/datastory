        "ActionId": 20,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"Hunting is a primal instinct engraved in the wolf\\'s DNA, allowing them to capture their prey with impeccable speed and accuracy.\"'}"
