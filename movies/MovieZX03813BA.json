        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'Ah, Commandant. I see it clicked, huh?', 4: '1'}"
    },
    {
        "Id": 93,
        "ActionId": 93,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'Babylonia has been very protective of you, which is a real shame. I\\'ve seen your inspection report and it was perfect.', 4: '1'}"
    },
    {
        "Id": 94,
        "ActionId": 94,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'I mean... you\\'d have made a very excellent vessel. Better than any of the girls, perhaps.', 4: '1'}"
    },
    {
        "Id": 95,
        "ActionId": 95,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'So you\\'re the one behind all those missing people.', 3: '96'}"
    },
    {
        "Id": 96,
        "ActionId": 96,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'Well... I\\'d say I only gave them what they wanted.', 4: '1'}"
    },
    {
        "Id": 97,
        "ActionId": 97,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'Most of them came to me of their own volition. I only picked a few of them and brought them here as ingredients.', 4: '1'}"
    },
    {
        "Id": 98,
        "ActionId": 98,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'Now, is that supposed to be condemnable?', 4: '1'}"
    },
    {
        "Id": 99,
        "ActionId": 99,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'All I\\'ve done is give them a third choice other than life and death.', 4: '1'}"
    },
    {
        "Id": 100,
        "ActionId": 100,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'And when all of this is over, all of us... will live forever and ever in an actual utopia.', 4: '1'}"
    },
    {
        "Id": 101,
        "ActionId": 101,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'Life stops for all of us here—so none of us will age or die, and all of us will possess power beyond our imagination... and that really is something beautiful if you just think about it.', 4: '1'}"
    },
    {
        "Id": 102,
        "ActionId": 102,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'Well, it\\'s about time. I must get the show on the road...', 4: '1'}"
    },
    {
        "Id": 103,
        "ActionId": 103,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pickman', 3: 'And best of luck to you, Commandant... with trying to get out of here alive.', 4: '1'}"
