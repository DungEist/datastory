        "ActionId": 89,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'You followed the clues I left behind to find me, didn\\'t you? You even found a way to deal with \"me\"—looks like you haven\\'t forgotten about those old missions after all.', 4: '2'}"
    },
    {
        "Id": 90,
