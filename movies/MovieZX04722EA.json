        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "AniZhuanchangEnd",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Shorthalt', 3: 'Want me to tell you what happened to me? You probably know most of it already.', 4: '2'}"
    },
    {
        "Id": 68,
        "ActionId": 68,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'The Ascendant—that purple-haired kid turned this place into their stronghold, throwing Constructs with stable M.I.N.D.s together to merge them. We were just one batch of test subjects, and they\\'ll keep doing this.', 4: '2'}"
    },
    {
        "Id": 69,
        "ActionId": 69,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
