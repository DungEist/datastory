        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'Forget it, let\\'s drop this. My head\\'s already a mess—I can\\'t handle any more chaos right now.', 4: '2'}"
    },
    {
        "Id": 81,
        "ActionId": 81,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Shorthalt taps his head, gesturing to Wanshi.'}"
    },
    {
        "Id": 82,
        "ActionId": 82,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'With so many M.I.N.D.s overlapping, I\\'ve seen countless memories of the past, including ones from this place.', 4: '2'}"
    },
    {
        "Id": 83,
        "ActionId": 83,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'This research facility experiments on children. The \"dump\" out back is almost full.', 4: '2'}"
    },
    {
        "Id": 84,
        "ActionId": 84,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'I tried to get the children out, running everywhere, but couldn\\'t find an exit. Then they marked me as an intruder and opened fire.', 4: '2'}"
    },
    {
        "Id": 85,
        "ActionId": 85,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'Seems like it was all just hallucinations I pieced together.', 4: '2'}"
    },
    {
        "Id": 86,
        "ActionId": 86,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Wanshi', 3: 'I know everything, Shorthalt. I can see all that you\\'ve done.', 4: '1'}"
