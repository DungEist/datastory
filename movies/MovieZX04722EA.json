        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Wanshi', 3: '...Those memories are too persistent—anyone would have trouble forgetting them.', 4: '1'}"
    },
