        "Params": "{1: '1', 2: '10'}"
    },
    {
        "Id": 70,
        "ActionId": 70,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Wanshi', 3: 'It\\'s all over now.', 4: '1'}"
    },
    {
        "Id": 71,
        "ActionId": 71,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Seeing Wanshi\\'s expression, Shorthalt seems to understand.'}"
    },
    {
        "Id": 72,
        "ActionId": 72,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'Oh... it\\'s been so long.', 4: '2'}"
    },
    {
        "Id": 73,
        "ActionId": 73,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'Who was involved?', 4: '2'}"
    },
    {
        "Id": 74,
        "ActionId": 74,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Wanshi', 3: 'From what I heard, there were a lot of people, including the Gray Raven Commandant and... your clone.', 4: '1'}"
    },
    {
        "Id": 75,
        "ActionId": 75,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Wanshi', 3: 'Your Nameplate has been returned and is now in Valeria\\'s custody.', 4: '1'}"
    },
    {
        "Id": 76,
        "ActionId": 76,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'What about Valeria? They didn\\'t do anything unnecessary, did they?', 4: '2'}"
    },
    {
        "Id": 77,
        "ActionId": 77,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Wanshi', 3: 'I\\'m not sure.', 4: '1'}"
    },
    {
        "Id": 78,
        "ActionId": 78,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Shorthalt', 3: 'What about you? Sometimes you\\'re even more obsessive than those lunatics.', 4: '2'}"
    },
    {
        "Id": 79,
        "ActionId": 79,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Wanshi', 3: '...', 4: '1'}"
    },
    {
        "Id": 80,
        "ActionId": 80,
