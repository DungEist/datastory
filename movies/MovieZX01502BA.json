        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'Changyu, come here. Laoyu, Call over Mr. Bai and Ol\\' Song in the back courtyard. Dismiss the helpers in the firewood room.', 4: '2'}"
    },
    {
