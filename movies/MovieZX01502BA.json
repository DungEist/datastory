        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: '...This isn\\'t something that passing out flyers can fix.', 4: '2'}"
    },
    {
        "Id": 67,
        "ActionId": 68,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'Sigh... Forget it... You\\'re all grown up. It\\'s time for you to learn a thing or two about the theater.', 4: '2'}"
    },
    {
        "Id": 68,
