        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Changyu', 3: 'I won\\'t let this happen!', 4: '1'}"
    },
    {
        "Id": 81,
        "ActionId": 82,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
