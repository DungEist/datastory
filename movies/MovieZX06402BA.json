        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Listen, I don\\'t care about what you did, but Nikola told me how bad the situation is.', 4: '11'}"
    },
    {
        "Id": 92,
        "ActionId": 92,
        "NextActionId": null,
