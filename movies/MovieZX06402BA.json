        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nirvatia', 3: 'I\\'ve noticed. The Punishing Virus concentration here is spiking rapidly, which is precisely why I need to focus and complete my mission as quickly as possible.', 4: '1'}"
