        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Nirvatia', 3: 'You must have seen my mission log. Given the unique properties of the Carthaki radiation zone, the military should understand my need to take initiative.', 4: '1'}"
    },
