        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'That\\'s why I\\'m calling. Your objectives have been updated: suspend the test data recovery, and proceed to provide support for a different mission.', 4: '11'}"
