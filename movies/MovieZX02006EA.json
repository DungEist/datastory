        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'When the shield-wielding Corrupted leaped out, No. 21 received another hallucination.'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
        "NextActionId": null,
