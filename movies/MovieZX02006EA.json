        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'No. Not a hallucination. It was the emotion that came after that, more impactful and intense.'}"
    },
    {
