        "BeginAnim": "AniZhuanchangEnd",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'There was a blurry light—light and pain—and she felt like she was going to have her artificial heart ripped out from her body.'}"
    },
