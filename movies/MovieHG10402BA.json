        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'As for the other data regarding my frame, I\\'m sure you can look them up on the system. I\\'ll save you the lecture.', 4: '1'}"
