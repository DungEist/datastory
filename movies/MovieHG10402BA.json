        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'My main duty is to hunt down and destroy defected or corrupted Constructs. My specialty is archery.', 4: '1'}"
    },
    {
        "Id": 16,
        "ActionId": 15,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'While I perform well in melee combat, I believe it is a captain\\'s role to know the battlefield inside out.', 4: '1'}"
    },
    {
        "Id": 17,
        "ActionId": 16,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'Which is why I picked a bow as my weapon of choice...', 4: '1'}"
    },
    {
        "Id": 18,
