        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: '...After all, it\\'s not affected by the Punishing Virus. As long as you can calibrate the imaging, it\\'s a good way to find your bearings when the navigation system is down.', 4: '2'}"
    },
