        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'Never in my wildest dreams did I expect a Gray Raven member to come to our rescue! I thought you guys only went to the most dangerous of battlefields!', 4: '2'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Why would you have that impression...', 4: '1'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'Oh, sorry, I didn\\'t mean anything by that. I just thought that elite teams like you guys would receive more important missions.', 4: '2'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
