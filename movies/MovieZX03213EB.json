        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'As for newbies like us, the command central only sends us out to set up devices and patrol bases...', 4: '2'}"
