        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: '...Someone who couldn\\'t even save his own partner.', 4: '2'}"
    },
    {
