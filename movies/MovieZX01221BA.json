        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'You\\'re too damaged. Let the others do the fighting.', 4: '2'}"
    },
