        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'That doesn\\'t sound good. I need to get to Commandant as soon as possible.'}"
    },
    {
        "Id": 25,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Agh... Argh!'}"
    },
    {
        "Id": 26,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "RImgBg1Shake",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'I need to be there for everyone... be there for Commandant. Something tells me that I\\'ll regret it if I don\\'t. I mobilize every working part of my body and crawl out of the bed.'}"
    },
    {
        "Id": 27,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'Hold on, what are you doing?', 4: '2'}"
    },
    {
        "Id": 28,
        "ActionId": 26,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Send me to battle...'}"
    },
    {
        "Id": 29,
        "ActionId": 27,
