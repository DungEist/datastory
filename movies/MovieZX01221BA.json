        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The president\\'s words jog my memories. It was a loss against Alpha, again.'}"
    },
    {
        "Id": 18,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '—Losing to myself.'}"
    },
    {
        "Id": 19,
        "ActionId": 18,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It wasn\\'t enough. It ended in failure. I wanted to show Commandant. I wanted Commandant to be proud. But, I lost again.'}"
    },
    {
        "Id": 20,
        "ActionId": 19,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'In the end, when I was lying in Commandant\\'s arms, I tried to smile, so that Commandant wouldn\\'t be as worried about me.'}"
    },
    {
        "Id": 21,
        "ActionId": 20,
        "NextActionId": null,
