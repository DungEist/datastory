        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 3: '0'}"
    },
    {
        "Id": 41,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Lucia, we developed a new frame for you. Built on all the data Gray Raven has gained so far.', 4: '1'}"
    },
    {
        "Id": 42,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'As in what we\\'ve been through...?'}"
    },
    {
        "Id": 43,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'You can say that, but your experiences alone aren\\'t enough. If you\\'ve realized that you are a replica, then you know how powerful the original Lucia is.', 4: '1'}"
    },
    {
        "Id": 44,
        "ActionId": 40,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'I know. That\\'s why I don\\'t want to lose.'}"
    },
    {
        "Id": 45,
        "ActionId": 41,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'That\\'s why I tuned up this frame with data from Alpha. Unedited. The entire set.', 4: '1'}"
    },
    {
        "Id": 46,
        "ActionId": 42,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'That\\'s... what the initialization is for?'}"
    },
    {
        "Id": 47,
        "ActionId": 43,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Yes. The frame is data-overloaded. So if you want to use it, your thought model will have to be reconfigured through initialization.', 4: '1'}"
    },
    {
        "Id": 48,
        "ActionId": 44,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'We don\\'t know what will become of you after the initialization. More Lucia, more Alpha, or someone completely different? No one can tell.', 4: '1'}"
    },
    {
        "Id": 49,
        "ActionId": 45,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Even if it all works out and you\\'re back in operation, you will longer be yourself.', 4: '1'}"
    },
    {
        "Id": 50,
        "ActionId": 46,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Constructs can acquire memories by loading themselves with data. But you will only be reading these memories, not living them. They will always be someone else\\'s.', 4: '1'}"
    },
    {
        "Id": 51,
        "ActionId": 504,
