        "BeginAnim": "AniZhuanchangEnd",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Using this frame is tantamount to suicide—it will kill Lucia, this current Lucia. That\\'s what Asimov is implying.'}"
    },
    {
        "Id": 60,
        "ActionId": 52,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'That\\'s a small price to pay, much smaller than I expected. Everyone has a grim look on their face, and yet I can\\'t help smiling.'}"
    },
