        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '2', 2: '500011', 4: '-400'}"
    },
    {
        "Id": 52,
        "ActionId": 505,
        "NextActionId": null,
        "Type": 203,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 3: '400'}"
    },
    {
        "Id": 53,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Hassen', 3: 'Asimov, this is too much... And even if we activate that frame, there\\'s still no way of getting her back in battle, right?', 4: '2'}"
    },
    {
        "Id": 54,
        "ActionId": 48,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'We do have a decommissioned single-person aircraft left. Still functional enough to take her to Kowloong.', 4: '1'}"
    },
    {
        "Id": 55,
        "ActionId": 300,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'I just caught a signal from Gray Raven... They might be in danger.', 4: '1'}"
    },
    {
        "Id": 56,
        "ActionId": 49,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Your frame, Lucia. Your call.', 4: '1'}"
    },
    {
