        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'I sent Gray Raven to join the resistance against Gabriel. I had Ayla bring a comms device with them, but then at some point we lost connection.', 4: '2'}"
    },
    {
        "Id": 24,
        "ActionId": 22,
