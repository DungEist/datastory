        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'I know you have a lot of questions, but right now, you need to rest.', 4: '2'}"
    },
    {
        "Id": 16,
