        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"President Hassen, are we in Babylonia, or somewhere else?\" Words. Lips. Mouth moving, or not? Sound does not come out.'}"
    },
    {
        "Id": 15,
        "ActionId": 15,
        "NextActionId": null,
