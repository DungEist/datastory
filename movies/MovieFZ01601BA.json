        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Murray', 3: '...But, this is an opportunity for me as well.', 4: '1'}"
    },
