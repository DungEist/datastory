        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Murray', 3: 'Hah. Our good President just handed down the thorniest mission like it\\'s nothing.', 4: '1'}"
    },
