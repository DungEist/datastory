        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'If it were me, I\\'d want to store this very moment tonight.', 3: '79'}"
    },
