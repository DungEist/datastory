        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee? When did you get here?', 3: '28', 4: '...! How do you move without a sound?', 5: '28'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
