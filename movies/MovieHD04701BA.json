        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'More important than the festival is that you\\'re here. Last Double Seventh, you were so buried in your report that someone had to feed you cake. Have you forgotten?', 4: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
