        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Lee', 3: 'The vendor clearly overstated its capabilities. Still, small creations like this from the late Golden Age have no means of restoration left. These days, their worth lies more in collection than in practical use.', 4: '1'}"
