        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Lee', 3: 'According to my scans, the market\\'s energy efficiency is 17.3% higher than expected. Some stalls even hide defensive structures under designs that fit perfectly with the festival\\'s atmosphere...', 4: '1'}"
    },
    {
        "Id": 27,
