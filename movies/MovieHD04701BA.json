        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Lee\\'s gaze is bright, his expression serious yet touched with the faintest trace of expectation as he looks at you.'}"
    },
    {
