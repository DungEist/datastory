        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'But, this allows them to be set up anywhere, which makes it more portable once you\\'re familiar with it.', 4: '1'}"
