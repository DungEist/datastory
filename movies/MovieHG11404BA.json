        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'Non-freestanding tents require an added support structure, making them more difficult to assemble.', 4: '1'}"
