        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: '\"Criminals, thugs, scums, and people who couldn\\'t make it anywhere else,\" right?', 3: '125'}"
    },
    {
        "Id": 125,
        "ActionId": 125,
        "NextActionId": null,
