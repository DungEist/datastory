        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'But ever since you came after I received this frame, I\\'ve felt a bit strange.', 4: '1'}"
