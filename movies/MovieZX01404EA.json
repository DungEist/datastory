        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Confirming the safety of the surroundings, Diana approaches you. She seems relieved at seeing you once again.'}"
    },
    {
