        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Fisher A', 3: 'The Capt. had ye over, aye... Yeah, yeah, thanks n\\' all, but this\\'s ARU matter, not yers.', 4: '1'}"
