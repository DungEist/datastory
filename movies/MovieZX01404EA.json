        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Fisher A', 3: 'Y\\'all just repayin\\' yer debts.', 4: '1'}"
    },
    {
