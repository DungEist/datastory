        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'But her extended hand is met with the same hostility as before.'}"
    },
    {
        "Id": 15,
        "ActionId": 1006,
