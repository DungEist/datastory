        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'We rescued you.', 3: '10', 4: 'Why are you so hostile to the Forest Guards?', 5: '11'}"
    },
    {
