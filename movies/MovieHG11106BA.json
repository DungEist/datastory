        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Sophia', 3: 'Because what I hear Lucia, Liv and Lee talk about most... Isn\\'t your leadership and combat skills, but other things.', 4: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
