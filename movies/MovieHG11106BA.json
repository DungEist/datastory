        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Sophia', 3: 'I think if I have enough time to acquire combat experience and tech from your team, maybe I can learn something useful... Something useful for Jamilah.', 4: '1'}"
