        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Sophia', 3: 'Like... your card playing, artistic taste... You seem to know them just as well. That shows how close you all are.', 4: '1'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
        "NextActionId": null,
