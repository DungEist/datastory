        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Sophia', 3: 'But from what I saw, this is completely inconsistent with the Gray Ravens\\' performance in battle. This makes me believe that what you have may be different from what I once knew.', 4: '1'}"
    },
