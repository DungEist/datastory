        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Sophia', 3: 'So I concluded that your behavior was foolish and dangerous.', 4: '1'}"
    },
    {
