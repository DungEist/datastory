        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Without hesitation, I went on the offensive against the Constructs. In my mind, battle was joined the moment weapons were drawn.'}"
    },
    {
        "Id": 48,
        "ActionId": 44,
        "NextActionId": null,
        "Type": 401,
        "IsBlock": null,
