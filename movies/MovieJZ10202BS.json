        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Lucia', 3: 'What... what is this?', 4: '2'}"
    },
    {
        "Id": 40,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'On one of Commandant\\'s rest days, I was summoned to a training room by an unpaired team of Constructs. When I arrived, I saw that they had both their weapons and mine, along with a wager—with Commandant as the stakes.'}"
    },
    {
        "Id": 41,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Let me guess... If I lose, I hand over the commandant. Correct?', 4: '2'}"
    },
    {
        "Id": 42,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'After all, we are fully staffed and ready to deploy, whereas with you, I\\'m afraid you\\'ll never...', 4: '3'}"
    },
    {
        "Id": 43,
        "ActionId": 40,
        "NextActionId": null,
