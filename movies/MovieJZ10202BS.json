        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "PanelActor3Shake",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'Coward! Jumping the gun just to win!?', 4: '3'}"
    },
    {
