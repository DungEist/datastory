        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The presence of the human has vanished, and the world that was created for that individual no longer has a purpose to exist.'}"
