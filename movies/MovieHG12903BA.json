        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'Hm? This? This is a solar thermal collector from ages ago. It was used to collect and store solar energy.', 4: '1'}"
    },
    {
        "Id": 83,
        "ActionId": 83,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'It\\'s pretty cold at night right now... The Scavengers who moved out might have a place to stay, but they have nothing to keep them warm. I want to make a simple heating device with this and a few other things.', 4: '1'}"
    },
    {
        "Id": 84,
        "ActionId": 84,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Karenina fiddles with her hair by her ear, her gaze darting around.'}"
    },
    {
        "Id": 85,
        "ActionId": 85,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '4'}"
    },
    {
