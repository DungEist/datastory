        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'After all, it\\'s too dangerous for them to make a fire in their shelters... The Engineering Force\\'d have to clean up their mess if they start a fire...', 4: '1'}"
    },
    {
        "Id": 87,
        "ActionId": 87,
