        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Taking the small trinket from you, she flips it around in the sun. Light passes through its translucent shell, scattering into a rainbow of colors. But Karenina eventually shrugs.'}"
    },
    {
        "Id": 105,
        "ActionId": 105,
