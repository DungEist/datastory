        "Id": 99,
        "ActionId": 99,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'Even unassuming junk... can become treasures that help people in the hands of engineers.', 4: '1'}"
