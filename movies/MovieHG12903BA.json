        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'The port for an energy converter. It\\'s a bit damaged right now, but I should be able to fix it.', 4: '1'}"
    },
    {
        "Id": 97,
        "ActionId": 97,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'I used to go treasure-hunting in the slums with Grandpa back in the slums. We would find all kinds of parts to assemble machines that we didn\\'t know.', 4: '1'}"
    },
    {
        "Id": 98,
        "ActionId": 98,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Karenina takes the port back and easily fixes it before attaching it to the panel.'}"
