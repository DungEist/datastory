        "ActionId": 102,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You look around and see a small object glistening in the sun. Picking it up, you find a chip with an intricate circuit attached to it.'}"
    },
    {
        "Id": 103,
        "ActionId": 103,
        "NextActionId": null,
