        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'If the power system still works, we might even be able to turn it back on. And then... Tch. Now\\'s not the time to think about that!', 4: '1'}"
