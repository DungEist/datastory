        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'It takes experience and imagination to determine if what you found is valuable... if it\\'s \"treasure\"\" or \"\"trash.\"', 4: '1'}"
