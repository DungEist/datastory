        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Karenina blinks and looks at you in disbelief.'}"
    },
    {
        "Id": 90,
        "ActionId": 90,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'You? This isn\\'t commanding a squad. It takes alertness and awareness, not wit.', 4: '1'}"
    },
    {
