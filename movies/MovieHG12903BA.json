        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'Hmph, of course! How can this junk even hope to hurt me... I was just caught by surprise.', 4: '1'}"
