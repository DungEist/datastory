        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'It\\'s just a small bulb for decoration, not something useful, unfortunately. At most, it\\'d give off a little bit of light... if it isn\\'t broken. Definitely \"trash.\"', 4: '1'}"
    },
