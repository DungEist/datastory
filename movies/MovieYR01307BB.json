        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'I didn\\'t expect the game to have KuroStylish clothing data in it. You\\'ve been a great help, Commandant!', 4: '1'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'KuroStylish?', 3: '9', 4: 'Huh?', 5: '12'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'It\\'s that super famous designer clothing brand in the Golden Age! Their design style is very unique, and the ready-to-wear clothes they made were very popular.', 4: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'So we decided to reboot the brand, but KuroStylish clothes were discontinued before the Post-Pandemic Age, and most of the related info is lost.', 4: '1'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": 14,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'We\\'re still in the process of collecting and restoring clothing designs.', 4: '1'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'We decided to reboot the Golden Age brand, KuroStylish, so we\\'re recovering the relevant design data. I didn\\'t expect that the game would have several actual swimsuit designs that were sold.', 4: '1'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'It\\'s very helpful to the study of the KuroStylish design style, and it\\'s saved me a lot of effort.', 4: '1'}"
    },
    {
        "Id": 14,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '1'}"
    },
    {
        "Id": 15,
        "ActionId": 15,
