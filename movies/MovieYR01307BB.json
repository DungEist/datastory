        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'During so, shopping malls had very attractive discount events. People would go out with their friends or lovers to shop and eat together.', 4: '1'}"
