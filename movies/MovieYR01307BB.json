        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'Apparently, various regions had different festivals and events during the summer in the Golden Age, and students also had a one to two month long summer vacation.', 4: '1'}"
