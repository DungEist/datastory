        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'This swimsuit has a Babylonian touch added to its base design, and to increase utility, I asked the tech department to give input on functionality.', 4: '1'}"
