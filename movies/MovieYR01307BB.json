        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'Some would go to seaside vacation spots and do all sorts of beach activities. Hmm... Like we did in the game that day.', 4: '1'}"
