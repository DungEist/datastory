        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'You\\'re welcome. Wearing nice clothes makes you feel better, after all. Even in this world, we cannot give up on our pursuit of beautiful things.', 4: '1'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'Well, I have to get back to work. Can I ask you to deliver the clothes for me, Commandant? Help me deliver one, I\\'ll deliver the other.', 4: '1'}"
