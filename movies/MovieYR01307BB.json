        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'So, even if an emergency occurs, you can enter battle immediately too!', 4: '1'}"
