        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'So... As a trial run for relaunching the brand, I made the swimsuits that Lee and Liv wore!', 4: '1'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Ayla pats the package in her hand and shows you a dazzling smile. You remember seeing her smile like this whenever she creates a satisfying piece of work.'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'Commandant, your application to make swimsuits for Constructs would ordinarily not be approved, but if it\\'s a cultural restoration project from the WGAA, it\\'s no problem at all!', 4: '1'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
