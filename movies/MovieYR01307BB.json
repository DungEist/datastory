        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'Before I became a Construct, I stayed indoors all the time and didn\\'t have many opportunities to go out. These things are also...', 4: '1'}"
