        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'His consciousness is not like the traitor\\'s, so he can\\'t last long in the cradle.'}"
    },
