        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Lustrous', 3: 'I\\'m glad to have you as my colleagues. It\\'s an honor working with you all.', 4: '1'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Admin Director', 3: 'The honor is mine. I look forward to Atlantis leading the next Industrial Revolution, but if I won\\'t live long enough for that day to come, I\\'ll die where it sits.', 4: '2'}"
    },
    {
        "Id": 29,
        "ActionId": 29,
