        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Admin Director', 3: 'I\\'ll \"go\" first. Try to stay away as long as you can.', 4: '1'}"
    },
    {
        "Id": 33,
        "ActionId": 33,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Admin Director', 3: 'We are sorry that you have to be the one who carries it all at the end.', 4: '1'}"
    },
    {
        "Id": 34,
        "ActionId": 34,
