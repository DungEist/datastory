        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Admin Director', 3: 'My hands would be on your neck if I was still the same person from when I first came here.', 4: '2'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Admin Director', 3: 'Remember the first night you became the director? I dragged you out from your lab and hosted a dinner with the other directors.', 4: '2'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Admin Director', 3: 'I asked you what you think of the base when we were eating. You said this place is like a brain constantly metabolizing.', 4: '2'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
