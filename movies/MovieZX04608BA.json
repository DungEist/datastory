        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'We\\'ll have a proper talk with Aleksei.', 3: '65'}"
    },
    {
        "Id": 65,
        "ActionId": 65,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"Tsiolkovsky Aerospace City holds things Babylonia needs—from the launch data of Dawn-III to the fusion reactors stored here, and even \"\"Bifrost\"\" itself.\"'}"
    },
    {
        "Id": 66,
        "ActionId": 66,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"Regardless of the city\\'s current stance, establishing contact with its ostensible leader is imperative to gather further insights. While this action carries inherent risks, it\\'s worth attempting since you have the means to retreat safely if necessary.\"'}"
    },
    {
        "Id": 67,
        "ActionId": 67,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: '\"...Even if Aleksei agrees to the peace proposal, Veronica, the one with real authority, may not necessarily follow his suggestion.\"', 4: '1'}"
    },
    {
        "Id": 68,
        "ActionId": 68,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: '\"Whether we succeed or not, we can still gather new intelligence from him.\"', 3: '69'}"
    },
    {
        "Id": 69,
        "ActionId": 69,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: '\"Of course, having a direct conversation with Veronica would greatly improve our odds.\"', 3: '70'}"
    },
