        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: '\"So, I believe we can figure out a way for mechanoids and humans to live together peacefully in this city.\"'}"
    },
