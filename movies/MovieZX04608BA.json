        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Hanying', 3: '\"Commandant, Liv... I don\\'t wish to see this city descend into conflict between humans and mechanoids, either.\"', 4: '1'}"
    },
    {
        "Id": 81,
        "ActionId": 81,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'I can speak to Veronica. There are a few things I need to confirm with her anyway.', 4: '1'}"
    },
    {
        "Id": 82,
        "ActionId": 82,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: '\"Based on the city history Dimitri shared, Veronica\\'s anger is not entirely groundless.\"', 3: '83'}"
    },
    {
        "Id": 83,
        "ActionId": 83,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: '\"Hanying, I\\'m really sorry for what humans have done to harm the mechanoids.\"', 3: '84'}"
    },
    {
        "Id": 84,
        "ActionId": 84,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: '\"No... that\\'s not your fault, Commandant.\"', 4: '1'}"
    },
    {
        "Id": 85,
        "ActionId": 85,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: '\"It\\'s not that I can\\'t understand Veronica\\'s anger—those mechanoids are my kin, after all.\"', 4: '1'}"
    },
    {
        "Id": 86,
        "ActionId": 86,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"A flicker of hesitation appears in Hanying\\'s eyes, but vanishes just as quickly.\"'}"
    },
    {
        "Id": 87,
        "ActionId": 87,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: '\"I\\'m merely a bystander in all of this. While I can feel the sorrow of the mechanoids, I\\'ve also witnessed the suffering of humans.\"', 4: '1'}"
    },
    {
        "Id": 88,
        "ActionId": 88,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The dark chocolate in her bag stands as a testament to that short-lived friendship.'}"
    },
    {
        "Id": 89,
        "ActionId": 89,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'It might sound hypocritical... but I really want to work toward peace in this conflict.', 4: '1'}"
    },
    {
        "Id": 90,
        "ActionId": 90,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: '\"Even in a place like this, the possibility of humans and mechanoids coexisting still stands... don\\'t you think?\"', 4: '1'}"
