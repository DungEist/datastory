        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'I\\'ll talk to Veronica as a fellow mechanoid. We share a common background—I\\'m sure she\\'ll at least hear what I have to say.'}"
    },
