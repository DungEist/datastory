        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lilith', 3: 'Punishing Virus. Aunt\\'s Construct can handle the viral breach, though how long it holds out depends on the quality of its internal shielding.', 4: '2'}"
