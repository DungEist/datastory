        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Echo', 3: 'I did. I practiced over and over, but I still felt nervous.', 4: '1'}"
    },
    {
        "Id": 54,
        "ActionId": 54,
        "NextActionId": null,
        "Type": 204,
