    },
    {
        "Id": 80,
        "ActionId": 80,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Echo', 3: 'In class this afternoon, Commandant, you sounded well versed in poetry.', 4: '1'}"
    },
    {
        "Id": 81,
        "ActionId": 81,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Echo', 3: 'I brought a poem and I want you to guess which one it is.', 4: '1'}"
    },
    {
        "Id": 82,
        "ActionId": 82,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Is it one of those Kowloong poems you\\'ve been studying?', 3: '83'}"
    },
    {
        "Id": 83,
        "ActionId": 83,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Echo', 3: 'Yes. Since it\\'s the Double Seventh Festival here in Constellia, I stocked up on Kowloong poems. This one fits the night perfectly.', 4: '1'}"
    },
    {
        "Id": 84,
        "ActionId": 84,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Always prepared. That\\'s so like you.', 3: '85', 4: 'So what\\'s it about?', 5: '85'}"
    },
    {
        "Id": 85,
        "ActionId": 85,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Echo', 3: 'It\\'s a poem about the moon, about the universe\\'s vastness and how small we are.', 4: '1'}"
    },
    {
        "Id": 86,
        "ActionId": 86,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Echo', 3: 'It says that when the moon rises, the river, the water, the whole world fills with its glow. When the moon sets, branches along the shore break that glow apart and only a few people walk home across the dappled light.', 4: '1'}"
    },
    {
        "Id": 87,
        "ActionId": 87,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'That is a beautiful picture.', 3: '88'}"
    },
    {
        "Id": 88,
        "ActionId": 88,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Echo', 3: 'The poem links the moon to love, as if love were a bold, brave stance stretching across the ages, a shield against the void.', 4: '1'}"
    },
    {
        "Id": 89,
        "ActionId": 89,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Just as she did in class, she speaks with emotion, and you wait for her conclusion.'}"
    },
    {
        "Id": 90,
        "ActionId": 90,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I think I know which poem it is. Is that its title?', 3: '91'}"
    },
    {
        "Id": 91,
        "ActionId": 91,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Echo glances at her notebook and nods.'}"
    },
    {
