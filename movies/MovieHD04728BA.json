        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'A faint blush colors her cheeks, making her even lovelier in the dying light.'}"
    },
    {
        "Id": 64,
        "ActionId": 64,
        "NextActionId": null,
