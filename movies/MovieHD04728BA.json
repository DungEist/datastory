        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Echo stays silent, yet you know the poem describes a moment exactly like this.'}"
    },
    {
