        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'In Echo\\'s eyes you see the very moonlight that enchants her, as if the moon itself from those ancient verses had traveled a thousand years to shine on you both.'}"
