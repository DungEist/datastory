        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Echo', 3: 'In the distant past of Kowloong, there was a poet born on Double Seventh and who also died on Double Seventh... Yet he was not known for romance.', 4: '1'}"
    },
    {
        "Id": 7,
        "ActionId": 7,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Echo', 3: 'His most famous works mourn a shattered homeland—mountains and rivers in ruin, ancestral gardens battered by wind and rain...', 4: '1'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
