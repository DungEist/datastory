        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Echo', 3: 'Does anyone know which poem this is?', 4: '1'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
        "NextActionId": null,
        "Type": 202,
        "IsBlock": null,
