        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Yes, Miss Echo.', 3: '62'}"
    },
    {
        "Id": 62,
        "ActionId": 62,
