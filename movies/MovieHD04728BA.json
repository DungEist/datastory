        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You see Echo teaching earnestly, occasionally consulting her densely written notes.'}"
    },
