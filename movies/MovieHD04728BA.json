        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'She gently presses a finger to your lips before the words escape. Moonlight spills onto the nearby lake, rippling just like the unspoken lines between you.'}"
    },
    {
        "Id": 96,
        "ActionId": 96,
