        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It\\'s clear these kids have no understanding of such ancient poetry. Echo had not expected complete silence. The room falls quiet.'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
