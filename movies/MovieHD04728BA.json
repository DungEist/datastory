        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Eager to bathe in the moonlight, she dashes outside. You lock the classroom doors and windows, then follow at a leisurely pace.'}"
    },
    {
        "Id": 76,
        "ActionId": 76,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Under the streetlamp she flips through her notebook. When she notices you, Echo snaps it shut, walks over, and the two of you start toward the lounge.'}"
    },
    {
        "Id": 77,
        "ActionId": 77,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You stroll beside Constellia\\'s artificial river, the only path back to the lounge.'}"
    },
    {
        "Id": 78,
        "ActionId": 78,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The moon isn\\'t full, yet the sky is crystal clear, every cloud gone. Moonlight pours over the water like liquid silver.'}"
    },
    {
        "Id": 79,
        "ActionId": 79,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
