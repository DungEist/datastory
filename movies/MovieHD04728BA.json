        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Dusk approaches, uneven sunlight spills into the room, lingering among the children\\'s clear voices.'}"
    },
    {
