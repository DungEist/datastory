        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'John', 3: 'Isn\\'t it the same thing?', 4: '1'}"
    },
    {
