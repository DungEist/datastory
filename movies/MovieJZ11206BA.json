        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'Countless times, you say?', 4: '2'}"
    },
    {
        "Id": 16,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Kamui', 3: 'You\\'ve been saying the same thing over and over since we got on the aircraft. Oh, and you also said: \"If anything happens, you get out of here. I\\'ll take care of the rest.\"', 4: '1'}"
    },
    {
        "Id": 17,
