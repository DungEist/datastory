        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'No. I\\'ve always followed your orders. The reason my goal is to become Smith is because I have no other choice.', 4: '2'}"
    },
    {
        "Id": 55,
        "ActionId": 67,
        "NextActionId": null,
