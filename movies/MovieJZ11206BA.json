        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Chrome realizes from this conversation that Kamui noticed his concern and figured out his plan for the day, but he doesn\\'t know when.'}"
    },
