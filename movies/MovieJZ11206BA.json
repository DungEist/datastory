        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'John', 3: 'Looks like the battle\\'s already started. Chrome, I\\'ll arrange for the support forces to pick you up at a location nearby. Retreat immediately.', 4: '1'}"
    },
    {
        "Id": 47,
        "ActionId": 47,
