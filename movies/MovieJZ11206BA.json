        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'I\\'m bringing it up because I want my autonomy back.', 4: '2'}"
    },
