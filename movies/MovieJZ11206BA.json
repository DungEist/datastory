        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: '...Where are the others? Why are their signals outside this area?', 4: '2'}"
    },
    {
