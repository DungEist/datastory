        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'The objective of this mission is to occupy this Corrupted spawning ground. Strike Hawk and the other teams will stay behind in Zone C to attract and contain any and all hostile entities.', 4: '2'}"
    },
    {
        "Id": 13,
        "ActionId": 10,
