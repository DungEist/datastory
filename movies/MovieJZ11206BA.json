        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'And then I\\'ll become Smith?', 4: '2'}"
    },
    {
        "Id": 48,
        "ActionId": 50,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'John', 3: 'I\\'ll have to climb to the position I need first. But you did carry out the responsibility of \"Smith\". Soon, I believe, you\\'ll become Smith, like you wanted. Now, retreat.', 4: '1'}"
    },
    {
        "Id": 49,
        "ActionId": 53,
