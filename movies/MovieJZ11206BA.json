        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'Every action of mine is determined by your will...', 4: '2'}"
    },
    {
        "Id": 56,
        "ActionId": 70,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'John', 3: 'That is the price of your existence. What\\'s the point of bringing it up now?', 4: '1'}"
    },
    {
        "Id": 57,
        "ActionId": 73,
        "NextActionId": null,
        "Type": 301,
