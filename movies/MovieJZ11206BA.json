        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'He instantly feels something—not nervousness, not animosity. Chrome can\\'t really tell what it is. It\\'s something he hasn\\'t ever experienced before... something that seems to have burst his bubble.'}"
    },
