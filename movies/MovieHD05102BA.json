        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'You dare pry into my schedule? How amusing. I\\'ll let it slide this time, but only because it\\'s you.', 4: '1'}"
    },
    {
        "Id": 42,
        "ActionId": 42,
        "NextActionId": null,
        "Type": 204,
