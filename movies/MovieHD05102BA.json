        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'I don\\'t take pictures for trivial matters, nor do I have a habit of printing them as souvenirs.', 4: '1'}"
    },
    {
        "Id": 46,
        "ActionId": 46,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'You attended the military academy. Surely you\\'re aware of the military\\'s security protocols.', 4: '1'}"
    },
    {
        "Id": 47,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '13'}"
    },
    {
