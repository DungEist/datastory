        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'I don\\'t mind snapping a souvenir while taking an enemy\\'s head. Projecting that at a post-battle meeting would surely make those useless bureaucrats piss themselves.', 4: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'But I don\\'t have time to spare for such touristy photo events. I\\'m busy.', 4: '1'}"
    },
    {
        "Id": 38,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I know you have no schedule after this.', 3: '39'}"
    },
    {
        "Id": 39,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'There must be another reason.', 3: '40'}"
    },
    {
        "Id": 40,
        "ActionId": 40,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '13'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
