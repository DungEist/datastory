        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'Are you done setting up your shot? Then hurry up and finish your task, so we can be done with it.', 4: '1'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
