        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noctis', 3: 'Probably some sort of magnetic substance? That\\'s something Nigel would inject into his targets with his weapons.', 4: '1'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noctis', 3: 'Once it\\'s inside the target\\'s body, he can cause a cardiac arrest with it if the target is a human, or paralyze the target\\'s M.I.N.D. if they\\'re a Construct, which kills them eventually... and that\\'s how he manages to smoke his targets even if the attack itself isn\\'t fatal.', 4: '1'}"
    },
