        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Meaning that Daemon and his people aren\\'t operating alone.', 3: '20'}"
    },
    {
        "Id": 20,
