        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noctis', 3: 'Makes sense! Who sent them here to spearhead the attack, though? That\\'s the million-dollar question here.', 4: '1'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
        "NextActionId": null,
