        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I\\'m guessing it\\'s this \"Generalissimo\" he was talking about...', 3: '22'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noctis', 3: 'I\\'m having trouble seeing where this \"Generalissimo\" fits in the picture... since Daemon said he belonged to the Forsaken...', 4: '1'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
