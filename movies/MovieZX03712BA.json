        "ActionId": 30,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noctis', 3: 'His M.I.N.D. was damaged from modification and that caused him to go blind for good... but that doesn\\'t seem to get in his way at all.', 4: '1'}"
