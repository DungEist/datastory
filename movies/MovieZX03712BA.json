        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noctis', 3: 'But what Daemon said is a little weird if you think about it... I mean, how are they able to control Hetero-Creatures?', 4: '1'}"
    },
    {
        "Id": 33,
        "ActionId": 33,
        "NextActionId": null,
