        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Beats me. For all we know, this \"Generalissimo\" might very well be Nigel.', 3: '24'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Unable to reach Babylonia, you have no idea what\\'s happened to the Forsaken or Watanabe...'}"
    },
    {
