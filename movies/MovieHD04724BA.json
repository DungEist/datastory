        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Haicma', 3: 'Humans call spontaneous creative thought \"inspiration.\" After running a self-check, I can confirm that whenever I\\'m with you, inspiration always bursts within me.', 4: '1'}"
    },
    {
        "Id": 54,
        "ActionId": 54,
