        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Sure enough, about 15 minutes later, the patrol captain finally wraps up his speech and calls the meeting to a close.'}"
    },
