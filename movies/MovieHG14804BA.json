        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Patrol Captain', 3: 'You\\'ve all done well. When I get back, I\\'ll make sure you get a taste of the local specialties here in the conservation area...', 4: '1'}"
