        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Patrol Captain', 3: '...This concludes our operation report. We\\'ve recovered most of the sound devices across the area. At this point, I\\'d like to extend my gratitude to each of you for your efforts.', 4: '1'}"
    },
    {
        "Id": 7,
        "ActionId": 7,
        "NextActionId": null,
