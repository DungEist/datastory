        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Was served a piece of good news and bad news today, and I\\'m not really sure how I\\'m supposed to feel.', 2: 'ffffffff', 4: 'Assets/Product/Texture/Image/BgStory/Bgstory209.png', 6: '1'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'The good news is that it was a peaceful day without any attacks from the Corrupted.', 2: 'ffffffff', 4: 'Assets/Product/Texture/Image/BgStory/Bgstory209.png', 6: '1'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'And the bad news is that I have to be out there in the pouring rain to stand sentry because I\\'ve lost a bet.', 2: 'ffffffff', 4: 'Assets/Product/Texture/Image/BgStory/Bgstory209.png', 6: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Just because I\\'m a Construct doesn\\'t mean I don\\'t grow rusty... Uhm, let me scrap that. Don\\'t think that\\'s something I want anyone to hear.', 2: 'ffffffff', 4: 'Assets/Product/Texture/Image/BgStory/Bgstory209.png', 6: '1'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Been a few weeks since I came to this place in the middle of nowhere and have seen nothing much other than a few seagulls fly by.', 2: 'ffffffff', 4: 'Assets/Product/Texture/Image/BgStory/Bgstory209.png', 6: '1'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Word has it that they had a battle here with an Ascendant, which is why a few elite squads have been sent here to station the place.', 2: 'ffffffff', 4: 'Assets/Product/Texture/Image/BgStory/Bgstory209.png', 6: '1'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Haven\\'t even seen a single Corrupted so far, let alone an Ascendant.', 2: 'ffffffff', 4: 'Assets/Product/Texture/Image/BgStory/Bgstory209.png', 6: '1'}"
    },
    {
        "Id": 14,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'All the enemies just went poof like that. Guess we should thank the Goddess of Sea and count our blessings since the place is named Atlantis?', 2: 'ffffffff', 4: 'Assets/Product/Texture/Image/BgStory/Bgstory209.png', 6: '1'}"
    },
    {
        "Id": 15,
