        "EndDelay": null,
        "Params": "{1: 'Arghh... To hell with the rain! I\\'m out!', 2: 'ffffffff', 4: 'Assets/Product/Texture/Image/BgStory/Bgstory209.png', 6: '1', 9: '1'}"
    },
