        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'Perhaps. But we only got rid of one of the Ascendants...', 4: '2'}"
    },
    {
        "Id": 23,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Kamui', 3: 'But before she left, that fish lady mentioned something about Roland retreating.', 4: '1'}"
    },
    {
        "Id": 24,
        "ActionId": 18,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'Even that only makes two. Gabriel, Alpha, and according to the report, their leader, Luna, might still be here somewhere.', 4: '2'}"
    },
    {
        "Id": 25,
        "ActionId": 19,
        "NextActionId": null,
