        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'Not me. It\\'s Lucia, member of Gray Raven, that\\'s asking for help.', 4: '3'}"
