        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Kamui', 3: 'Gray Raven? What happened to them?', 4: '1'}"
    },
    {
        "Id": 39,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'They seem to be trapped inside the core area, you know, through that light wall. After losing contact with them for a while, the president got Lucia a new frame and sent her after them.', 4: '3'}"
    },
    {
        "Id": 40,
        "ActionId": 32,
