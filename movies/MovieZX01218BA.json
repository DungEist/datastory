        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Kamui', 3: 'By the looks of things, it\\'s only a matter of time before we win this, right?', 4: '1'}"
    },
    {
        "Id": 22,
        "ActionId": 16,
