        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Kamui', 3: 'Losing contact...? Could they be in danger? And how did Lucia get separated from the squad?', 4: '1'}"
    },
    {
        "Id": 41,
        "ActionId": 33,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'It\\'s a long story. Anyway, the clock is ticking—', 4: '3'}"
    },
    {
