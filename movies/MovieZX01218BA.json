        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'I\\'ve read about you before. Do you require our help?', 4: '2'}"
    },
    {
        "Id": 36,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
