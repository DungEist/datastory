        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'We can\\'t let our guard down until we get a visual confirmation. Kamui, let\\'s keep searching.', 4: '2'}"
    },
