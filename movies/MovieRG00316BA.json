        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Granton', 3: 'The power of the artifact allowed us to summon the Demon King in the last war. The Goddess originally wanted to balance the power of both sides to reduce casualty.', 4: '1'}"
