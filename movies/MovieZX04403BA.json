        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Lamia', 3: 'That\\'s too dangerous, Miss Luna! If you can\\'t maintain your sense of self, they\\'ll tear your consciousness apart!', 4: '1'}"
