        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'If that\\'s the case, I\\'ll put them to use. I will embrace all of the hatred these consciousnesses harbor against agents.', 4: '1'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
        "NextActionId": null,
