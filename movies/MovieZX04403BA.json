        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: '...That feeling comes from those who died in the Red Tide. I used to dismiss the pulls as noise, but while the static in my mind faded with my diminishing permissions, the voices of the Red Tide remained clear.', 4: '1'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
