        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'In order to reduce the burden on your M.I.N.D., I can only approximate its performance according to your previous frame after the calibration. I can\\'t match it perfectly.', 4: '2'}"
    },
