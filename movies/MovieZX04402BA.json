        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: 'There\\'s not much I can do, and I hope Miss Luna won\\'t think I\\'m rude...', 4: '18'}"
