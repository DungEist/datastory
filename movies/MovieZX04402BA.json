        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'Cthylla was trying to stop you from taking the living egg even at the very end.'}"
