        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: '...The egg stopped responding after that battle. It became just like any other Hetero-Creature.', 4: '18'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: 'And then Cinderelik in the egg said... she wanted to save her memories of the Cthylla Project for Babylonia, so I...', 4: '18'}"
    },
