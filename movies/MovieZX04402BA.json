        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: 'I wanted to bring back the egg, but \"Cthylla\"\" linked \"\"her\" to herself instead.', 4: '18'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
