        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: 'That consciousness only helped her control the \"Leviathan\" beneath the waves, a cradle for the rebirth of the dead.', 4: '18'}"
