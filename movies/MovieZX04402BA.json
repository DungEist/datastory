        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: 'They might be free from Lithos and couldn\\'t sense the others anymore, but the chains at the bottom of the sea were still...', 4: '18'}"
