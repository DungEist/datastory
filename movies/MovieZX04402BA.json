        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: 'I think Lithos stopped her from escaping until he was forcefully expelled in the end...', 4: '18'}"
