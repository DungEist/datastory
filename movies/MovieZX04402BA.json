        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'Don\\'t worry so much. You know how meticulous he is, so he would have stopped you right from the start if you really ruined his plan.'}"
