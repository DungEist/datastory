        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: 'Ah, sorry! I didn\\'t mean to say anything bad about you, Miss Luna. I just want to stay here with you.', 4: '18'}"
