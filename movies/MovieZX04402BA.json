        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: 'If you tell me what\\'s happening with you, I will do my best to help...', 4: '18'}"
