        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'Similar consciousnesses can have similar requests for the Ascension-Network... That\\'s what happened with my sister and \"that\" sister back then.'}"
