        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: '...Y-you\\'re right. Lilith was very close to me... If she wanted to stop me, she would have already...', 4: '18'}"
