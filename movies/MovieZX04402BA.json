        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: 'That\\'s why I hope you\\'ll pass the Filtering safely. Then I can... I can stay in this familiar place.', 4: '18'}"
