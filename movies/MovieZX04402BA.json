        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lamia', 3: 'Consciousnesses within the Giant Whale had always maintained a minimal connection with Cthylla—they were practically unrelated.', 4: '18'}"
