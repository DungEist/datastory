        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Nigel finds himself unable to get back to his feet from the excessive damage his frame has taken.'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Spewing \"poison,\" his right arm has become a goner from the punch, too, no longer able to manipulate magnetic objects.'}"
    },
    {
        "Id": 29,
        "ActionId": 29,
        "NextActionId": null,
