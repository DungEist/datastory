        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Noctis shows Nigel a smile, apparently oblivious to the riposte.'}"
    },
    {
        "Id": 63,
        "ActionId": 63,
