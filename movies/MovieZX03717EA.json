        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noctis', 3: 'Well, so what if we are... naivety makes us strong, as we\\'ve seen.', 4: '1'}"
    },
