        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '2', 2: '500201', 4: '-400'}"
    },
    {
        "Id": 42,
        "ActionId": 27,
