        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Simon', 3: 'So... Why did they turn you into Constructs? If they fear the power of humanoid-hybrids, then why would they continue making them?', 4: '2'}"
    },
    {
        "Id": 43,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'There wasn\\'t a choice. The Punishing Virus poses a terrifying threat.', 4: '1'}"
    },
    {
        "Id": 44,
        "ActionId": 29,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'Corrupted invasions are rare for the ARU, but not nonexistent. We\\'re far from safe...', 4: '1'}"
    },
