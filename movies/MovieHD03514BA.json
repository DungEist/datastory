        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'But the people of the Arctic Route Union hold their tools tight, settling in and making their stand against that endless expanse of snow and ice.', 4: '1'}"
    },
