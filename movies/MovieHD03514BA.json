        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: '【kuroname】, my homeland is frozen all year round, and the warm season vanishes in a heartbeat—just like the Double Seventh Festival. Most people see it as a ruthless place where survival doesn\\'t come easy.', 4: '1'}"
    },
    {
