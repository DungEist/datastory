        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: '【kuroname】... I keep thinking: if you weren\\'t here with me today, would the fortune teller\\'s cards still turn out this lucky?', 4: '1'}"
    },
    {
        "Id": 46,
        "ActionId": 46,
