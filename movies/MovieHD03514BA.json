        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'In Constellia\\'s night sky, countless stars sprawl across a dazzling canvas. The radiant Milky Way cuts through the darkness, linking distant constellations on both sides.'}"
    },
    {
        "Id": 48,
        "ActionId": 48,
