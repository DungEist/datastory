        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'It\\'s true—I don\\'t mind drawing a winning hand in a game, just like I enjoy a stroke of good luck.', 4: '1'}"
    },
    {
        "Id": 43,
        "ActionId": 43,
        "NextActionId": null,
