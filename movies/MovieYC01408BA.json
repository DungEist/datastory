        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Staessen\\'s roar stops the indignant fisherman. He continues.'}"
    },
