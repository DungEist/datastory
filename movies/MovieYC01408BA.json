        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'Just... Just...! Everything\\'s over with! It\\'s all over!', 4: '1'}"
    },
