        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'As if infected by Staessen, tears also begin to dot the others faces. They support their wounded companions and retreat. Some throw their weapons onto the ground.'}"
