        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'Stop this war AT ONCE! Stop all the fighting! I\\'m not repeating myself! If you don\\'t listen, you\\'ll be branded a sinner...', 4: '1'}"
