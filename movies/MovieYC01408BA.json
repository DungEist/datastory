        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Was it from the relief of the ebbing danger? Or certain decisions and resolves in his heart?'}"
