        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'Just listen up, everyone! You too, bionics! This is the captain\\'s orders!', 4: '1'}"
