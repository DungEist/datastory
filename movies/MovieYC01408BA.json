        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Staessen', 3: 'That\\'s why I said she\\'s proof of our foolishness! And I\\'m just another gimboid like them old duds!', 4: '1'}"
    },
