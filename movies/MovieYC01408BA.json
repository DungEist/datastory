        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Fisher', 3: 'Capt., you hiding this from us the whole time? You just let that thing be? What if Amberia went gaga like before...?', 4: '1'}"
