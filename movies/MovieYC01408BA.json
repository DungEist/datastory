        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'We\\'ve both paid more than enough for the past! Do whatever you want with me! I\\'ll tell you everything you want to know! Just...', 4: '1'}"
