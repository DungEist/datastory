        "Params": "{3: 'While strolling through downtown Constellia, you hear applause and cheers in the distance. Both humans and Constructs have stopped to watch something ahead.'}"
    },
    {
        "Id": 5,
        "ActionId": 5,
        "NextActionId": null,
