        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Your gaze is drawn to Hanying\\'s lingering dance rhythm. Her smooth movements under the lantern light and moonlight seem covered in a soft glow, calm yet full of strength. The background noise fades into a distant hum.'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The cyan-green Construct looks at you in surprise, a hint of shyness in her eyes. As if afraid to disturb the moment, the crowd gradually disperses, but you remain rooted in place.'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 402,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
