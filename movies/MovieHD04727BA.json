        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 3: 'Weaving through the crowded throng, you catch sight of a graceful figure in turquoise. Light and shadow play across her as she moves, and her mastery of the dance is nothing short of breathtaking.'}"
    },
    {
        "Id": 7,
        "ActionId": 7,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying?', 3: '8', 4: 'Didn\\'t think I\\'d run into you here!', 5: '8'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
