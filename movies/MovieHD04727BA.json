        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You take a deep breath and place your hand into Hanying\\'s cool palm. Her fingers are steady and strong, carrying a reassuring strength.'}"
    },
    {
        "Id": 45,
        "ActionId": 45,
        "NextActionId": null,
