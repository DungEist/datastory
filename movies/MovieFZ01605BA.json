        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liadrin', 3: 'At this rate, you\\'ll lose me sooner or later.', 4: '2'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liadrin', 3: 'The only way to save me from the threat of the Punishing Virus is doing what Gabriel the angel told me to do.', 4: '2'}"
