        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Angel', 3: 'If there is a shortcut, then why are we still fighting against the virus?!', 4: '1'}"
    },
    {
        "Id": 39,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liadrin', 3: '...', 4: '2'}"
    },
