        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liadrin', 3: 'Angel, when I fought as a Construct, I witnessed terrible deaths over and over again.', 4: '2'}"
