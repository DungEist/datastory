        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liadrin', 3: 'Regardless, there\\'s no \"if.\" I am what I am already.', 4: '2'}"
