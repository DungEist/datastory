        "ActionId": 40,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liadrin', 3: 'Good question. Every \"shortcut\" comes with a certain risk. However, if the alternative is to die in battle like the others, I\\'d rather take the risk. I was never born to fight. I was born to do research with you.', 4: '2'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Angel', 3: 'Sister... Did you come to that conclusion after being wounded?', 4: '1'}"
    },
    {
        "Id": 42,
        "ActionId": 42,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liadrin', 3: '...', 4: '2'}"
    },
