    {
        "Id": 47,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liadrin', 3: 'But ever since I became a Construct, you can\\'t stay focused on your job. It\\'s only a matter of time before you\\'re fired.', 4: '2'}"
    },
