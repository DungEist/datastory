        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Rosetta\\'s voice is barely audible, but you hear every word that comes out of her mouth since the two of you are so close.'}"
