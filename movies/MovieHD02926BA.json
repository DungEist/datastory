    {
        "Id": 38,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'It\\'s your birthday today, and it\\'s on very day that you came into this world, and it\\'s also because of today that I got to cross paths with you.', 4: '1'}"
    },
