        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Unable to understand Hanying\\'s words, Spooner shakes his head.'}"
    },
    {
        "Id": 67,
        "ActionId": 67,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Spooner', 3: 'Humans are always so complicated.', 4: '1'}"
    },
    {
        "Id": 68,
        "ActionId": 68,
