        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'That\\'s an oversimplification.', 4: '2'}"
    },
    {
        "Id": 66,
        "ActionId": 66,
