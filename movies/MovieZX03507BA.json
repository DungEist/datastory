        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'But for the people of Kowloong, lamenting the passing of the seasons amidst the beauty of nature is a habit that\\'s ingrained in their minds.', 4: '2'}"
    },
    {
