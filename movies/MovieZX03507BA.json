        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'This is how it works. For instance, for mechanoids like us, a place like this might be described as \"scenic,\" and that would be an objective truth.', 4: '2'}"
    },
