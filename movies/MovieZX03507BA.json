        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Spooner', 3: 'You mean that humans are often too blinded by their own emotions to see the objective truth of the place?', 4: '1'}"
    },
    {
        "Id": 64,
        "ActionId": 64,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
