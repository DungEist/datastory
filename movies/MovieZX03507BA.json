        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'I can\\'t think of a fitting way to describe this view off the top of my head, so I recited a line from an ancient Kowloong text.', 4: '2'}"
    },
    {
        "Id": 75,
        "ActionId": 75,
        "NextActionId": null,
