    },
    {
        "Id": 71,
        "ActionId": 71,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The leading figure whispers one last line before following the female researcher and walking away. Only one man remains in the spacious laboratory; he walks toward the capsule, stroking the thick glass shell.'}"
    },
    {
        "Id": 72,
        "ActionId": 72,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The waking girl looks at her surroundings curiously, her hand placed on the transparent cover.'}"
    },
    {
        "Id": 73,
        "ActionId": 73,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Male Researcher', 3: 'She\\'s not a tool.', 4: '1'}"
    },
    {
        "Id": 74,
        "ActionId": 74,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Male Researcher', 3: 'She\\'s my child, and she\\'s—', 4: '1'}"
    },
    {
        "Id": 75,
        "ActionId": 75,
        "NextActionId": null,
        "Type": 202,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogDisable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 6: '1'}"
    },
    {
        "Id": 76,
        "ActionId": 76,
        "NextActionId": null,
        "Type": 504,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '0'}"
    },
    {
        "Id": 77,
        "ActionId": 77,
        "NextActionId": null,
        "Type": 401,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": 300.0,
        "Params": "{1: '1', 2: '36'}"
    },
    {
        "Id": 78,
        "ActionId": 78,
        "NextActionId": null,
