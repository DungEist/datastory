        "Params": "{2: 'MPA-01', 3: 'Understood.'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: 'Opening records on the machine consciousness experiment. Opening behavior account of subject: Nanami.'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: '...Her character is constantly reshaping. Her personality data is normal.'}"
    },
    {
        "Id": 20,
        "ActionId": 20,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: 'Currently, her thought process and behavioral logic are akin to a human\\'s. Out of the twelve humanoid subjects, only Nanami has shown this trait.'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Female Researcher', 3: 'That\\'s right... She\\'s special.', 4: '1'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: 'I switched to Personality 134 in order to have a more effective conversation and record changes in her emotions.', 7: '1'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: 'But she questioned my behavior, believing I was not talking to her \"as myself.\"', 7: '1'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Female Researcher', 3: '\"As yourself\"?', 4: '1'}"
    },
    {
        "Id": 25,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: 'Without activating my personality module.'}"
    },
    {
        "Id": 26,
        "ActionId": 26,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The administrative AI sounds hesitant.'}"
    },
    {
        "Id": 27,
        "ActionId": 27,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: 'I have performed self-test on all my modules, but I have not detected any anomalies. This happenstance did not occur in my conversation with other subjects.'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Female Researcher', 3: 'It seems that... only she can notice the difference.', 4: '1'}"
    },
    {
        "Id": 29,
        "ActionId": 29,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Female Researcher', 3: 'In that case, do as she said. Talk to her \"as yourself.\"', 4: '1'}"
    },
    {
        "Id": 30,
        "ActionId": 30,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: 'Understood.'}"
    },
    {
        "Id": 31,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Female Researcher', 3: '...You called her name instead of her code, didn\\'t you? You never did that with other subjects.', 4: '1'}"
    },
    {
        "Id": 32,
        "ActionId": 32,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: '...'}"
    },
    {
        "Id": 33,
        "ActionId": 33,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: 'I...'}"
    },
    {
        "Id": 34,
        "ActionId": 34,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Female Researcher', 3: 'Relax. I wasn\\'t accusing you of anything.', 4: '1'}"
    },
    {
        "Id": 35,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Female Researcher', 3: 'I just... hope you won\\'t forget what you\\'re feeling now.', 4: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: 'Understood. As requested, I will record everything I see.'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
