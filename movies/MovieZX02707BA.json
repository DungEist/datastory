    },
    {
        "Id": 117,
        "ActionId": 117,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500486', 3: '10'}"
    },
    {
        "Id": 118,
        "ActionId": 118,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Haicma', 3: '...', 4: '1'}"
    },
    {
        "Id": 119,
        "ActionId": 119,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Haicma does not know how to define the feeling she has right now.'}"
    },
    {
        "Id": 120,
        "ActionId": 120,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1'}"
    },
    {
        "Id": 121,
        "ActionId": 121,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'She has so many questions. Even when she knows the objective definition of every emotion, she still cannot truly understand all that is to be a human.'}"
    },
    {
        "Id": 122,
        "ActionId": 122,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'But an intense curiosity surges in her mind. She desperately wants to ask her creator something, but she fails to compose the right question.'}"
    },
    {
        "Id": 123,
        "ActionId": 123,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Most of the machines she has met on her journey are simply repeating the commands they received from humans, mimicking human behaviors.'}"
    },
    {
        "Id": 124,
        "ActionId": 124,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
