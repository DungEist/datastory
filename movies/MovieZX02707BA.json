        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: '—Replacement complete. The new frame will reach its growth limit in approximately two years.'}"
    },
    {
        "Id": 63,
        "ActionId": 63,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'MPA-01', 3: 'Reminder: A scheduled meeting is starting in ten minutes. Attendants are recommended to arrive on time.'}"
    },
    {
        "Id": 64,
        "ActionId": 64,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'A gentle but cold female voice speaks, easing the tension in the air.'}"
    },
    {
        "Id": 65,
        "ActionId": 65,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Female Researcher', 3: '...If you would follow me, please. I\\'ll be reporting the detailed progress of the project.'}"
    },
    {
        "Id": 66,
        "ActionId": 66,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"These naive mad scientists and their machines.\"'}"
    },
    {
        "Id": 67,
        "ActionId": 67,
        "NextActionId": null,
        "Type": 203,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
