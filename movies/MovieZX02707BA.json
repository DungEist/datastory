        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Female Researcher', 3: 'MPA-01, please pull up the observation report on subject MPL-00.', 4: '1'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
