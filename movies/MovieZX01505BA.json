        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Changyu', 3: 'What are you doing, Director? Why are you just standing there...? Are you also planning...', 4: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500229'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Director', 3: '...Yes. I made my own choice as well... I don\\'t want to board the ship and run away. Nor do I want to join the Tabula Akasha. I\\'m staying here in the theater.', 4: '1'}"
    },
    {
        "Id": 38,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'I can\\'t do something like abandoning my body and living in some machine.', 4: '1'}"
    },
    {
        "Id": 39,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'All I can do is stay with the theater left to me by my ancestors.', 4: '1'}"
    },
    {
        "Id": 40,
        "ActionId": 40,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500230', 3: '5'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Changyu', 3: '...In that case, I\\'ll stay here too!', 4: '1'}"
    },
    {
        "Id": 42,
        "ActionId": 42,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500229'}"
    },
    {
        "Id": 43,
        "ActionId": 43,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Director', 3: 'Quit kidding around! Go upstairs and pack your things. Laoyu, go take Changyu to the port.', 4: '1'}"
    },
    {
        "Id": 44,
        "ActionId": 44,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Laoyu', 3: 'O-of course.'}"
    },
    {
        "Id": 45,
        "ActionId": 45,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'You\\'re still young. You shouldn\\'t give up your life like the rest of us.', 4: '1'}"
    },
    {
        "Id": 46,
        "ActionId": 46,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500230', 3: '5'}"
    },
    {
        "Id": 47,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Changyu', 3: 'I\\'m old enough to fight!', 4: '1'}"
    },
    {
        "Id": 48,
        "ActionId": 48,
        "NextActionId": null,
        "Type": 203,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '0.25', 3: '-400'}"
    },
    {
        "Id": 49,
        "ActionId": 49,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '2', 2: '500229', 4: '400'}"
    },
    {
        "Id": 50,
        "ActionId": 50,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Director', 3: 'Now\\'s not the time to act up!', 4: '2'}"
    },
    {
        "Id": 51,
        "ActionId": 51,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Changyu', 3: 'If you\\'re staying to fight, then count me in! After the war is over, we can continue running the theater. I just finished repairing the props we\\'ll need...', 4: '1'}"
    },
    {
        "Id": 52,
        "ActionId": 52,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'Changyu, if you really have grown up, then quit being so naive!', 4: '2'}"
    },
    {
        "Id": 53,
        "ActionId": 53,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '14'}"
    },
    {
        "Id": 54,
        "ActionId": 54,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'I didn\\'t have the heart to say it, but I sold the theater a long time ago. That\\'s why Yusheng was able to take his wife to see a doctor.', 4: '2'}"
    },
    {
        "Id": 55,
        "ActionId": 55,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'But who could\\'ve imagined something like this would happen before she was cured.', 4: '2'}"
    },
    {
        "Id": 56,
        "ActionId": 56,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'You are just a child. You can\\'t possibly understand the cruelties of war—we might not survive. This is the last time we\\'ll ever see each other.', 4: '2'}"
    },
    {
        "Id": 57,
        "ActionId": 57,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'As the director, I appreciate your dedication to the theater... But some things in this world can\\'t be paid back.', 4: '2'}"
    },
    {
        "Id": 58,
        "ActionId": 58,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Director', 3: 'We are just a footnote in the history of Kowloong. We are constantly pushed forward by the flow of time.', 4: '2'}"
    },
    {
        "Id": 59,
        "ActionId": 59,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '21'}"
    },
    {
        "Id": 60,
        "ActionId": 60,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Changyu', 3: 'Enough!', 4: '1'}"
    },
    {
        "Id": 61,
        "ActionId": 61,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Changyu', 3: 'I just don\\'t want to lose everyone. I want things to go back to normal. You always treat me like a child and make decisions for me. But have you really asked what I think?!', 4: '1'}"
    },
    {
        "Id": 62,
        "ActionId": 62,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
