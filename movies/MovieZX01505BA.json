        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Changyu', 3: '...Yusheng! Where have you been all this time?', 4: '1'}"
    },
    {
