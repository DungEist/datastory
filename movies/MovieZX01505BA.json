        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Changyu perks up with a smile, surprised at the sight of seeing a familiar face after so long.'}"
    },
    {
