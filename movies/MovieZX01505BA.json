        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Yusheng', 3: 'I had some family matters to attend to, so...'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
        "NextActionId": null,
