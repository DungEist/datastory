        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Yusheng rubs his fingers. His once immaculate white hands are now wrapped in bandages.'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Yusheng', 3: 'You\\'re back just in time. I wanted to bid you all farewell.'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
