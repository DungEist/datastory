        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Changyu replies and looks around the theater. Laoyu is sitting at a table off to the side with Yusheng, who he had not seen for some time.'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
