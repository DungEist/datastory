        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Conductor', 3: 'These emotions are conflicting and contradicting, and I just don\\'t understand how they can appear at the same time...', 4: '1'}"
    },
    {
