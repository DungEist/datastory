        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Conductor', 3: 'Such emotional fluctuations only ever appear alongside insignificant historical nodes, and yet... you all seem to see them as important. I have a hard time understanding such complicated fluctuations as they\\'re not part of my database...', 4: '1'}"
    },
    {
        "Id": 20,
        "ActionId": 20,
