        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Conductor', 3: 'Agony... joy... happiness... and sadness... are what I observed, and they don\\'t make logical sense.', 4: '1'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
        "NextActionId": null,
