        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Putting down the bandage in hand, Alpha fiddles with the campfire. The fire burns lazily, casting light that stretches the shadows of the trees into the distance.'}"
