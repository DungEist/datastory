        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'As the campfire shines in Alpha\\'s eyes, you notice the sun is slowly making its way up the sky.'}"
