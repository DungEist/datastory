        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'All great things have humble beginnings.', 3: '46'}"
    },
    {
        "Id": 46,
        "ActionId": 46,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'As if to prove your point, specks of light start appearing across the conservation area. Judging from the fact that it\\'s still the wee hours, you believe their expedition is getting ready to head out.'}"
    },
    {
        "Id": 47,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'And that\\'s humans for you—they might struggle, but they never give up.'}"
    },
    {
        "Id": 48,
        "ActionId": 48,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'And even if they\\'re trapped all the way down at the bottom of an abyss, all they need is a little hope for them to fight their way back up.'}"
    },
    {
        "Id": 49,
        "ActionId": 49,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Because they choose to do so.'}"
    },
    {
        "Id": 50,
        "ActionId": 50,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Alpha', 3: 'So naive.', 4: '1'}"
    },
    {
        "Id": 51,
        "ActionId": 51,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Surprisingly, that\\'s all Alpha says. Turning around to face the campfire, she seems so absorbed that you doubt she really heard what you said.'}"
    },
    {
        "Id": 52,
        "ActionId": 52,
        "NextActionId": null,
