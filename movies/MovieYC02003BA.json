        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"Life is great, but .300 Magnum is greater, because it can take away any life with ease.\"'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"It makes no difference whether that life is theirs, or ours. We are just one of the many life forms.\"'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'For some reason, Roland still remembers this scene that he once witnessed.'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'But he only knew how to act back then. He didn\\'t have any question.'}"
    },
    {
        "Id": 14,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The script was there. He only had to follow it to earn money, as well as a chance to live.'}"
    },
    {
        "Id": 15,
        "ActionId": 15,
        "NextActionId": null,
