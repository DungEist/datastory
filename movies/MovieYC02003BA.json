        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'To Roland, struggling for survival amidst a world that ignores the importance of life should be called great instead. That is the real world.'}"
