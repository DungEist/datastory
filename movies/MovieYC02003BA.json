        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Roland?', 3: 'I cannot interfere with your future. I can only bring up those things that you didn\\'t want to confront.', 4: '1'}"
    },
