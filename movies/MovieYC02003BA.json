        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Roland?', 3: 'But all I can do is to stay with you and face \"you\" till the last moment.', 4: '1'}"
