        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Roland?', 3: 'I don\\'t come from outside, and I\\'m not another you either. I am just that more honest side of yours.', 4: '1'}"
    },
    {
        "Id": 62,
        "ActionId": 62,
        "NextActionId": null,
