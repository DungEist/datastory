        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Roland?', 3: 'I know you don\\'t want to see me. But rest assured, hermano. In this world, anyone can leave you...', 4: '1'}"
