        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'This is how humans fire a brass bullet. It has 2800 joules of kinetic energy, travels at 868 meters per second, and can take down most animals on the continent.'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
