        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Push the bolt to load a shiny, slim bullet, unlock the safety, then pull the trigger.'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
