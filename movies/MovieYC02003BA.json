        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Does the power to take lives really make something great? It\\'s nothing but an arrogant boast.'}"
    },
    {
