        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I was worried...', 3: '7', 4: '...I\\'m sorry.', 5: '8'}"
    },
    {
        "Id": 7,
