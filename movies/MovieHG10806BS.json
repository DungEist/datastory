        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'That said... it seems that I\\'ll have to rest up for a while.', 4: '1'}"
    },
    {
