        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'Relax. I\\'m not human, I don\\'t die that easily.', 4: '1'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'There\\'s nothing to apologize for. This is war. No one comes out the other side unscathed every time.', 4: '1'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
