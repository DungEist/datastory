    {
        "Id": 5,
        "ActionId": 4,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Snow', 3: 'God has taught us to be holy, righteous, loving, giving; to love the enemy, fast, pray; to walk in the light, to not be greedy, not to judge; to be sincere and to stay on the path.', 4: '1'}"
    },
    {
        "Id": 6,
        "ActionId": 5,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: '...To love.', 4: '1'}"
    },
    {
        "Id": 7,
        "ActionId": 6,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'But what is love to a... mechanoid? Does love really exist?', 4: '1'}"
    },
    {
        "Id": 8,
        "ActionId": 7,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'Even all the sacred texts in the database failed to tell me.', 4: '1'}"
    },
    {
        "Id": 9,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: '...Until I found a baby in the vast snow land, a human baby.', 4: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'She was cowering her fragile body, her skin purple from the cold, yet she quietly looked up at me with her golden eyes.', 4: '1'}"
    },
    {
        "Id": 11,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'My neural network ran sophisticated calculations and the conclusion I reached was that, even the angel of love was nothing compared to her.', 4: '1'}"
    },
    {
        "Id": 12,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'I raised her. Mechanoids have no concept of time, but I found that 567648000 seconds passed by in a flash.', 4: '1'}"
    },
    {
        "Id": 13,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'Bianca, my child, my kind, gentle, strong, and brave child. She loves the world and is full of faith...', 4: '1'}"
    },
    {
        "Id": 14,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'Even in this time when faith is scarce, when mechanoids teach religion. And I never could tell her the truth.', 4: '1'}"
    },
    {
        "Id": 15,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'I could explain all religious texts, recite all teachings, yet love was taught to me by my child.', 4: '1'}"
    },
    {
        "Id": 16,
        "ActionId": 15,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'If only I were human... If I am qualified as her guardian...', 4: '1'}"
    },
    {
        "Id": 17,
        "ActionId": 16,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'If I can see... Bianca, my child... Grow up.', 4: '1'}"
    },
    {
        "Id": 18,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: '...If only.', 4: '1'}"
    },
    {
        "Id": 19,
        "ActionId": 18,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'When I saw Miyi, I already understood... I understood that I would never get to see...', 4: '1'}"
    },
    {
        "Id": 20,
        "ActionId": 19,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'I separated Bianca from me, had her lead the others away while I locked myself in the basement of the church.', 4: '1'}"
    },
    {
        "Id": 21,
        "ActionId": 20,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'I took off the chains on the cross and tightly chained myself up, so tight that the truth of my mechanic presence under the human-like skin was revealed...', 4: '1'}"
    },
    {
        "Id": 22,
        "ActionId": 21,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'God loves the world, God blesses the world, yet as a mechanoid, I cannot nor do I need the blessing or protection...', 4: '1'}"
    },
    {
        "Id": 23,
        "ActionId": 22,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'But if my constant prayers and pious devotion are worth anything...', 4: '1'}"
    },
    {
        "Id": 24,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'Please protect my child, Bianca... And all the other human children like Bianca.', 4: '1'}"
    },
    {
        "Id": 25,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'They are all angels who have fallen into this world...', 4: '1'}"
    },
    {
        "Id": 26,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Snow', 3: 'God, if I ever lose myself, I am willing to accept any judgment and punishment...', 4: '1'}"
    },
    {
