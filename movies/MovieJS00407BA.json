        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'But anyhow... Come down to my dorm when we\\'re back in Babylonia.', 4: '1'}"
    },
