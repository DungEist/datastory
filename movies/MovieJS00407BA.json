        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Is it supposed to be rare?', 3: '32'}"
    },
    {
        "Id": 32,
        "ActionId": 32,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'It\\'s rare with a capital R. A friend of mine has been collecting songs by this band, and I\\'ve never seen this album before.', 4: '1'}"
