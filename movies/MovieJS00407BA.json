        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I\\'ll do everything I can so you don\\'t need to...', 3: '25'}"
    },
    {
        "Id": 25,
        "ActionId": 25,
