        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'And it\\'s a... cassette? And what\\'s that on the cover?', 4: '1'}"
    },
    {
        "Id": 30,
        "ActionId": 30,
        "NextActionId": null,
        "Type": 301,
