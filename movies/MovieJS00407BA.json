        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'And if you don\\'t, well, I guess I\\'ll just have to physically help you remember.', 4: '1'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
