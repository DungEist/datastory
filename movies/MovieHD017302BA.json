        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'That battle seemed to stretch on indefinitely, enduring long enough to wear down even those who had once vowed to stand firm against any adversity by her side.'}"
    },
