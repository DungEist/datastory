        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Fisher', 3: 'Aye aye, c\\'mon, let\\'s sail today!', 4: '1'}"
