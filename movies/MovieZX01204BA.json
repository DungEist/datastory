        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The words evidently reach them, but the fisher is met with a \"No\" gesture by an annoyed-looking sailor.'}"
