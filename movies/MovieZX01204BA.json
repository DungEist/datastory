        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Ahead of him is the port shared by members of the Arctic Route Union, with a couple ships lazing nearby. A group of sailors are huddled around a furnace-like heating device, chatting away.'}"
    },
    {
        "Id": 7,
        "ActionId": 7,
