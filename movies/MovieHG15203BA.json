        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'Did you know? Brewing alcohol predates historical records. Humanity invented it even before iron.', 4: '1'}"
    },
