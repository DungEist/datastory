        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'This wine in my hand here is more than a thousand years old. It\\'s no longer drinkable, but it still carries a strong aroma.', 4: '1'}"
    },
