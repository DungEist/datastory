        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'With the dull thud of the door, the Kowloong\\'s vault is opened for the first time in a long time. Every inch of the chamber is filled with treasures collected from all over the world.'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla would freak if she found out...', 3: '9'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500150'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Qu', 3: 'Of course, compared with the records of your unsightly WGAA, everything lying here is a shining example of human existence. This makes it the greatest witness of the human era.', 4: '1'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'Human beings may only be a flash in the pan, but the fruits of their labor will turn into fossils and remain unforgotten.', 4: '1'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'I know everything here. If you are interested, you can ask me about their stories if you so choose.', 4: '1'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: '(Ask about a stone door covered in carvings)', 3: '14', 4: '(Ask about a sallow wine botte)', 5: '20'}"
    },
    {
        "Id": 14,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'This is the stone door to the tomb of an ancient general. It\\'s carved with every battle he fought. Artisans even carved the mane of every warhorse in fine detail.', 4: '1'}"
    },
    {
        "Id": 15,
        "ActionId": 15,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "PanelActor1Shake",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'Insolent fool! I\\'ve never allowed anyone to approach me like that!', 4: '1'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I\\'m just trying to get a closer look...', 3: '17'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'Forget it. But next time... I recall an exquisite pattern on the gallows you might be interested in having a closer look at.', 4: '1'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: '...Forget about it.', 3: '19'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
