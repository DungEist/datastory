        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pulao', 3: 'And I guess you\\'d have been as busy as a bee now if we were back in the Golden Age?', 4: '1'}"
    },
    {
        "Id": 35,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Changyu', 3: 'You bet. People came to Kowloong from all over the world back then, and we never failed to take advantage of that to advertise ourselves.', 4: '2'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Changyu', 3: 'Festivals are more fun when you celebrate them lively, they said.', 4: '2'}"
    },
    {
