        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pulao', 3: 'Did people back then have to start doing all the prep in the morning for celebrations like we do now?', 4: '1'}"
