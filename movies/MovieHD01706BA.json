        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pulao', 3: 'Wait, a month?! But isn\\'t that a little...', 4: '1'}"
    },
    {
