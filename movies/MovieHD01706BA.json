        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Changyu', 3: 'So in a way, the events were opportunities for those people to busy themselves with, who otherwise would have just sat around doing nothing.', 4: '2'}"
    },
