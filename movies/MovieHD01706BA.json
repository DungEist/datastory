        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pulao', 3: 'I really enjoyed hanging out on the street because I didn\\'t hate how crowded it was. I actually really enjoyed being around a lot of people.', 4: '1'}"
    },
