        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Changyu', 3: 'One morning would never have cut it. If the event came with performances, we\\'d have to start doing all the rehearsals and getting everything we needed a month ahead.', 4: '2'}"
