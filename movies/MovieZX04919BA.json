        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Yata', 3: 'Would you feel as lost as I did when crises like this happen out of the blue...? How do people usually cope with it anyway?', 4: '1'}"
