        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Yata', 3: 'Long story short, the Scarabs failed to capture their mission target and got punished—now they\\'re on a \"wonderful\" mandatory vacation.', 4: '1'}"
    },
    {
