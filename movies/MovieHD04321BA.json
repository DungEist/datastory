        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'However, due to the lack of actors, Selena made a small adaptation, changing the story so that the Duke of Milan\\'s daughter, Miranda, personally carries out this revenge.'}"
    },
    {
        "Id": 76,
        "ActionId": 76,
