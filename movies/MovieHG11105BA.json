        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Sophia', 3: '...No, I can\\'t say that. I\\'ll cross it out.', 4: '1'}"
