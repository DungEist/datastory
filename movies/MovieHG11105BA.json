        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Sophia', 3: 'Jamilah, I still don\\'t quite understand why you dispatched me to Babylonia...', 4: '1'}"
