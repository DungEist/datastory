        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Sophia', 3: 'I know I\\'m an envoy, but I\\'m not skilled in diplomacy. I didn\\'t even learn to read and write until I became a bodyguard.', 4: '1'}"
    },
    {
        "Id": 15,
        "ActionId": 15,
