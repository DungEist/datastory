        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Rosetta', 3: 'That shouldn\\'t concern you. Aren\\'t you a Construct from Babylonia?', 4: '1'}"
    },
    {
        "Id": 35,
        "ActionId": 1012,
        "NextActionId": null,
