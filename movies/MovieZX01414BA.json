        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Amberia (Atiel)', 3: 'Hah... I should be asking you Forest Guards instead—Why are you helping the ARU?', 4: '1'}"
    },
    {
        "Id": 31,
        "ActionId": 20,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Amberia (Atiel)', 3: 'You have suffered such injustice and were even called sinners. Why? Why do you still stand by these scum of the earth?', 4: '1'}"
    },
    {
        "Id": 32,
        "ActionId": 21,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Amberia (Atiel)', 3: 'What reason do you have to protect them?', 4: '1'}"
    },
    {
        "Id": 33,
        "ActionId": 1011,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500214', 3: '4'}"
    },
    {
