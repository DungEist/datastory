        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'The Ascendant won\\'t protect you!', 3: '2001', 4: 'Many of those people are innocent!', 5: '2002'}"
    },
