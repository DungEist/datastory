        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'A statuesque woman offers a gentle greeting.'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Confronted by this straightforward question—one that leaves no room for interpretation—Lithos\\'s muddled Memory conjures countless possible answers.'}"
    },
    {
        "Id": 14,
        "ActionId": 14,
        "NextActionId": null,
