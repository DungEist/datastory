        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Then she raises her head, turning her eyes to the silver-white full moon hanging in the night sky.'}"
    },
    {
        "Id": 39,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The \"other agent\" is held captive by the humans of Babylonia on that satellite, two hundred and forty thousand miles away.'}"
    },
    {
        "Id": 40,
        "ActionId": 40,
        "NextActionId": null,
