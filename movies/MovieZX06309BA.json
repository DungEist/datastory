        "EndDelay": null,
        "Params": "{3: 'A driver in a thick scarf suddenly flips back the tarp over the truck cabin and pushes his way in, bringing the biting chill of the frontlines with him.'}"
    },
    {
        "Id": 20,
        "ActionId": 20,
        "NextActionId": null,
