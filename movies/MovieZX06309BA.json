        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Man A', 3: 'Sophiasburgh was the capital. Their stockpiles were always bigger than anyone\\'s.', 4: '1'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Man A', 3: 'And ever since the higher-ups set their sights on conquering the world, those stockpiles only grew.', 4: '1'}"
    },
    {
        "Id": 29,
        "ActionId": 29,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'He has only just spoken when he becomes aware of their collective gaze fixed on him. With a hurried wave of his hands and a sharp shake of his head, his voice grows noticeably strained.'}"
    },
    {
        "Id": 30,
        "ActionId": 30,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogShake",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Man A', 3: 'Don\\'t look at me like that! My father captained a transport ship for Sophiasburgh. I only know because I sailed with him a few times.', 4: '1'}"
    },
