        "EndDelay": null,
        "Params": "{2: 'Civilian Guard A', 3: 'We waited for the Forest Guards to defeat Amberia and end the nightmare... and then the Frostheart Emperor returned. Every time we hope, things get worse.', 5: '2'}"
