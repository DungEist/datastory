        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Man A', 3: 'What did you see out there?', 4: '1'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Driver', 3: 'The Corrupted, swarms of them. Heard some soldiers talking while we unloaded. Sophiasburgh\\'s hiding production lines, churning out more of those things. Unless they\\'re destroyed, the front\\'ll be overrun.', 4: '2'}"
    },
    {
