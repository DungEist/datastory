        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Man B', 3: 'That can\\'t be right. I used to run production lines. Where would they get all the resources?', 4: '1'}"
    },
