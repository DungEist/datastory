        "ActionId": 46,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Understood.', 3: '47', 4: 'Can we really defeat the Ascendants?', 5: '48'}"
    },
