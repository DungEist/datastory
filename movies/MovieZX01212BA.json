        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'We\\'re already at work fixing the connection, but I\\'m afraid it\\'s gonna take a while, so I had this comms device sent to you.', 4: '2'}"
    },
    {
        "Id": 40,
        "ActionId": 42,
