        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Must be the scrambler waves from Kowloong. Not sure if it\\'s effective against the Ascendants, but it sure messed up our comms systems.', 4: '1'}"
