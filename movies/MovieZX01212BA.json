        "ActionId": 43,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'Originally, several, yes. But there\\'s been a change of plans. One of the Ascendants, Gabriel, launched a surprise assault, so now I need you to go there and stop him.', 4: '2'}"
    },
    {
        "Id": 42,
        "ActionId": 44,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'Of course, I\\'ve sent other squads too. And let me repeat this—the Ascendants are after the Gestalt-grade terminal within the light wall.', 4: '2'}"
    },
    {
        "Id": 43,
        "ActionId": 45,
