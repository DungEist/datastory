        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Due to Babylonia\\'s technical bias, you\\'ve been operating in humanoid mode since the Battle of Kowloong, while your centaur module has been stuck at maintenance for one reason or another.', 4: '2'}"
