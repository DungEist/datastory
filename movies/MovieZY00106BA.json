        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Foreman', 3: 'Right, of course. Take it back! We haven\\'t touched a single thing inside.', 4: '1'}"
    },
    {
        "Id": 24,
        "ActionId": 15,
        "NextActionId": 16,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Foreman', 3: 'I\\'ve been monitoring the whole place through those recon drones above you.', 4: '1'}"
    },
    {
