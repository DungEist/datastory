        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Foreman', 3: 'Therefore, it is my honor to announce that Gray Raven is the winner of this year\\'s Fist of the Taoist, and their commandant, 【kuroname】, shall be crowned the Taoist Supreme!', 4: '1'}"
    },
