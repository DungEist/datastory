        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Foreman', 3: 'I can\\'t believe someone\\'s passed all the trials and arrived at this place! The way you tackle them and hunt those ghosts... Ain\\'t never seen anything like that!', 4: '1'}"
    },
    {
