        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Foreman', 3: 'As you can see, this group called Gray Raven has passed all of our trials, and is the first to set foot in this place!', 4: '1'}"
    },
    {
