        "ActionId": 16,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'With that, Foreman turns around and gestures dramatically like a Master of Ceremonies.'}"
    },
    {
