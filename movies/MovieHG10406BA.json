        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'I\\'m flattered...', 4: '1'}"
    },
    {
        "Id": 12,
