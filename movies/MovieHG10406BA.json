        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'That\\'s why I\\'ve worked so hard to reach the position of leadership to make sure I know the story behind every case.', 4: '1'}"
