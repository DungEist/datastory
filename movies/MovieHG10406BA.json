        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'As I\\'ve told you, I don\\'t intend to let the Purifying Force become a mindless coalition of butchers.', 4: '1'}"
