        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'I wasn\\'t forced into the Purifying Force because of my model, Commandant.', 4: '1'}"
    },
    {
