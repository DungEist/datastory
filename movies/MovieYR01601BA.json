        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Rosetta', 3: 'What\\'s your assessment on the damage to the buildings?', 4: '1'}"
    },
    {
        "Id": 107,
        "ActionId": 113,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500204'}"
    },
    {
        "Id": 108,
        "ActionId": 114,
