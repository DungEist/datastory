        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: '...Only here.', 4: '2'}"
    },
    {
        "Id": 93,
        "ActionId": 99,
        "NextActionId": null,
        "Type": 202,
        "IsBlock": null,
        "IsEnd": null,
