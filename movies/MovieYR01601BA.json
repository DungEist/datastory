        "Id": 116,
        "ActionId": 122,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'Then destroy them all in one fell swoop...', 4: '2'}"
    },
    {
        "Id": 117,
        "ActionId": 123,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'What do you mean?', 4: '1'}"
    },
