        "Id": 115,
        "ActionId": 121,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '...Maybe it was to lure those who knew about these secrets to seek shelter in the research institute.'}"
    },
