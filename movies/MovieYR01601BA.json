        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Forest Guard D', 3: 'We just received news. The Forsaken and our companions have completed the search and rescue work. The injured have been sent to the hospital for treatment, but no dead were found anywhere except the Research Institute.', 4: '1'}"
