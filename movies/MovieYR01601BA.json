        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Forest Guard C', 3: 'All areas have undergone multiple inspections. We haven\\'t seen any signs of life.', 4: '1'}"
