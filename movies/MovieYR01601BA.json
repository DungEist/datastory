        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: '...That won\\'t be necessary anymore. Is there any news outside of the research institute?', 4: '2'}"
