        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'Let\\'s also go rendezvous with the other Forest Guard and help them with the injured.', 4: '2'}"
    },
