        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Rosetta', 3: 'Her destruction to that area must have been a warning.', 4: '2'}"
    },
    {
        "Id": 114,
        "ActionId": 120,
