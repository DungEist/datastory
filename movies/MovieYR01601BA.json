        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Rosetta does not voice her speculation. Instead, she raises her hand and proceeds to give orders to the Forest Guard.'}"
    },
    {
        "Id": 119,
        "ActionId": 125,
        "NextActionId": null,
        "Type": 202,
