        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'Let the refugees take temporary asylum in New Sophiasburgh while reconstruction awaits completion. Only the periphery is left to be built, but looks like there won\\'t be a need for a fence. Let\\'s expand further outward instead.', 4: '2'}"
    },
    {
