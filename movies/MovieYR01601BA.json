        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Forest Guard E', 3: 'For the time being, I would classify this as C-grade damage. The destroyed houses are mainly concentrated in the area we first witnessed. Most of the buildings in other areas survived.', 4: '1'}"
