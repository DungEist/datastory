        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Civilians rushed in to see if the residential regions were intact. Simon also left with the crowd, saying that he needed to look into something with Atiel.'}"
    },
    {
        "Id": 5,
        "ActionId": 6,
