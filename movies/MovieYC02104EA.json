        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'In the beginning, the basket containing rations was placed on top of the table. The cans and biscuits were stacked like mountains.'}"
