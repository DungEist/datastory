        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Researchers have lined up in the corridor outside the canteen. The queue is incredibly long. Lamia cannot see its end.'}"
    },
    {
