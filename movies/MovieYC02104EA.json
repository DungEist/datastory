        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Logistics Staff', 3: 'No. Rations have been strictly calculated based on age, height, weight and daily activity level. This is all you have.', 4: '1'}"
