    {
        "Id": 46,
        "ActionId": 46,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Logistics Staff', 3: 'We only take queries about the expiry date or nutrition values. If you have other concerns, make a complaint to the admin department. There are lots of people waiting behind. Leave.', 4: '1'}"
