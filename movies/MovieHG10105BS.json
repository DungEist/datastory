        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'I compared the curve with the terrain, then calculated Eden\\'s trajectory to accurately pinpoint its location.', 4: '1'}"
