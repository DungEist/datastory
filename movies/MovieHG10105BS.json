        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Most machine parts in the workshop are uniformly rationed, but a few special parts need to go through an application process.', 4: '1'}"
