        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'It\\'s a supply depot for ordering military-grade machine parts. It\\'s off the beaten path, so only a few people know about it.', 4: '1'}"
    },
    {
        "Id": 7,
        "ActionId": 7,
