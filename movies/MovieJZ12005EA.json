        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'John', 3: 'You\\'re a Construct. I think you could have calculated how best to make your moves.', 4: '2'}"
