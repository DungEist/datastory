        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Despite the visible displeasure on her pouting face, Mina\\'s tone lacks any real defiance. It is clear that if Asimov gave the nod, she would set to work without protest.'}"
    },
    {
        "Id": 71,
        "ActionId": 71,
