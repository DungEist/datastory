        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'I\\'ve heard of Derek, but what exactly does \"lead whale\" mean? Is there a hierarchy among these bionic whales?', 4: '13'}"
    },
    {
        "Id": 106,
        "ActionId": 106,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Like Mina, Asimov quickly processes the discussion, seizing on the key term.'}"
    },
