        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Dr. Bear', 3: 'B-but that can\\'t be! Dr. Puff is Rosetta\\'s own grandfather!', 4: '1'}"
    },
    {
