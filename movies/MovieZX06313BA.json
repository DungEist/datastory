        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Not at this time. Your Malkuth reconstruction otherwise matches the manuscript in all key respects, including that \"defective\" black box.', 4: '13'}"
    },
