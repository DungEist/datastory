        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Souls of the dead. Souls of the dying. Souls of the living.'}"
    },
    {
