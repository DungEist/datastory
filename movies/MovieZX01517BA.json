        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The top priority for Tai\\'E units is to ensure human safety.'}"
    },
    {
        "Id": 35,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'He has always had a special affinity toward humans. Whether it be imitating humans on TV or doing silly things to provoke laughter...'}"
    },
    {
        "Id": 36,
        "ActionId": 3010,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'He never understood why he did so. He just knew it would make others look happy—that people would surround him and focus on him.'}"
    },
    {
        "Id": 37,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'He never understood why this behavior makes humans happy.'}"
    },
    {
        "Id": 38,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'But now... For the first time, he seems to be feeling an emotion that is exclusive to humans.'}"
    },
