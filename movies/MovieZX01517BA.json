        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Seeing one of his own turn into a bloodthirsty monster... Seeing what the humans—the ones who trusted and relied on him—did. He suddenly feels... afraid.'}"
    },
    {
        "Id": 49,
        "ActionId": 50,
