        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Somewhere far away, through the cold darkness, through the smoke and war, our city burns in the flames of war.'}"
    },
    {
        "Id": 4,
        "ActionId": 3,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Through my database simulation, I can feel the city bleeding. I can see blown-up bodies lying in the ruins of their homes. I can feel flags trembling in the hands of survivors.'}"
    },
    {
        "Id": 5,
        "ActionId": 4,
