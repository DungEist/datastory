        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'HNB1 scans his system and emotion module in a few milliseconds. At present, it is loaded with Personality No.53. Through big data analysis, it is the most popular personality among Kowloong people. Everything is fine.', 4: '1'}"
    },
    {
