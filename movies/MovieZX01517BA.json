        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'HNB1', 3: 'Something wrong with me?', 4: '2'}"
    },
    {
        "Id": 28,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Little Girl', 3: 'You don\\'t seem to be yourself... You feel different from daytime.', 4: '1'}"
