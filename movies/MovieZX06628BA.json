    {
        "Id": 4,
        "ActionId": 4,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'Huh? we\\'re recording?! You\\'re not even counting down first?!', 18: '100017461'}"
    },
    {
        "Id": 5,
        "ActionId": 5,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'Ahem... Lucia, Commandant. By the time you hear this recording, well... everyone probably knows already.', 18: '100017462'}"
    },
    {
        "Id": 6,
        "ActionId": 6,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'I\\'ve always wanted to say this, you know... the two of you, even back when you\\'re at the F.O.S., you... How do I put this... you\\'re the type to think you\\'ve hidden something really well when literally everyone sees through you!', 18: '100017463'}"
    },
    {
        "Id": 7,
        "ActionId": 7,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'Lucia, you do realize that always leaving an empty spot next to you, no matter where you are, isn\\'t exactly subtle, right? Do you really think we can\\'t tell who it\\'s for?', 18: '100017464'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'That said... something about that was just really endearing... so none of us ever called you out on it.', 18: '100017465'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'Seeing you two being all lovey-dovey makes us happy too.', 18: '100017466'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'Alright, you\\'re getting sappy! Get to the point already! Move it—', 18: '100017468'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogShake",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'Wait, I\\'m not done yet!', 18: '100017469'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'Ahem. Lucia, Commandant.', 18: '100017470'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'I\\'ve been watching you two since day one at the academy. You guys fought battle after battle, finished mission after mission, nearly getting yourselves killed more times than I can count.', 18: '100017471'}"
    },
    {
        "Id": 14,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'And whenever there was any breakthrough in the research on Sefirah technology, the two of you would be first in line to volunteer for testing... I know you just wanted to support my work, but being so reckless doesn\\'t help, you know!', 18: '100017472'}"
    },
    {
        "Id": 15,
        "ActionId": 15,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogShake",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'Hey! You can\\'t just put two reckless daredevils together like that!', 18: '100017474'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'Well yeah, but it\\'s not like anyone can stop them!', 18: '100017475'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'Haha... Yeah, they ended up together anyway. No idea which one of you made the first move, but I bet it was Lucia.', 18: '100017476'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'Anyway, I just hope that you two will stick together and stop being so damn reckless in the days ahead, where it is you decide to go.', 18: '100017477'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'Now take our blessings and go live happily ever after!', 18: '100017478'}"
    },
    {
        "Id": 20,
        "ActionId": 20,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'Okay, I think we\\'ll leave it at that. Adelyde just sent a message saying they\\'re back.', 18: '100017479'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogShake",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'What?! Hold on, there\\'s still one last thing I need to say!', 18: '100017480'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'Then make it quick!', 18: '100017481'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'Anyway, uh, Lucia, Commandant—just say yes to each other already! We\\'re all rooting for you!', 18: '100017482'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'Love you guys! You\\'ll always have my best wishes—I\\'m sending you all my love!', 18: '100017484'}"
    },
    {
        "Id": 25,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'M-Me too! Have a greeeaaat life!', 18: '100017485'}"
    },
    {
        "Id": 26,
        "ActionId": 26,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ophelia', 3: 'They\\'re here! Quick, put it away!', 18: '100017486'}"
    },
    {
        "Id": 27,
        "ActionId": 27,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Joanne', 3: 'Before we go, all the best to you, Commandant!', 18: '100017487'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
