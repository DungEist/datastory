        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Angry Bear', 3: '\"Good\"... Pah. You call yourself a bionic? You\\'d let these humans off, even when they made us into weapons and sealed us underground?!', 4: '1'}"
    },
    {
        "Id": 31,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Angry Bear', 3: 'We woke up to find ourselves stabbed by our own creators—then next thing we know—we\\'re all forced underground via our in-built commands.', 4: '1'}"
    },
    {
        "Id": 32,
        "ActionId": 32,
        "NextActionId": null,
