        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Angry Bear', 3: 'Of course. Without a production line, how else could we keep up with the humans? Your platoon must have been filled with these rookies. Pah.', 4: '1'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
        "NextActionId": null,
