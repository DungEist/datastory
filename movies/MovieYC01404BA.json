        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Angry Bear', 3: 'You don\\'t understand. The mother-frame shares the same goal as ours. We can feel what our mother-frame feels through our receivers, but we are willingly fighting for her ourselves.', 4: '1'}"
    },
    {
        "Id": 45,
        "ActionId": 45,
