        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Angry Bear', 3: 'Indeed. With the body of a mutant, every movement of her brought about destruction. But that is not her most terrifying realization when she woke up...', 4: '1'}"
    },
    {
        "Id": 61,
        "ActionId": 61,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Angry Bear', 3: 'She isn\\'t the master of her own body. The higher-ups in the ARU are.', 4: '1'}"
    },
    {
        "Id": 62,
        "ActionId": 62,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Angry Bear', 3: 'Do you think a little girl could just accept this and live with it?! Her unending anger coursed through her frenzied M.I.N.D.; it shot through the receivers and flowed into our processors.', 4: '1'}"
