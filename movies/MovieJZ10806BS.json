        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Hassen', 3: 'Take a seat. I wanted to talk about the retreat operation and some other news.', 4: '2'}"
    },
    {
        "Id": 8,
        "ActionId": 7,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: '...There\\'s no need.', 4: '1'}"
    },
    {
        "Id": 9,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'You have the right to know.', 4: '2'}"
    },
    {
        "Id": 10,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'Are you worried that I know too much?', 4: '1'}"
    },
    {
        "Id": 11,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 202,
        "IsBlock": null,
