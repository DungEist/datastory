        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'You will be transferred to the Babylonia protection team and head to another launch base...', 4: '2'}"
