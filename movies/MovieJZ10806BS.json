        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'Yes?', 4: '2'}"
    },
    {
        "Id": 30,
        "ActionId": 29,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'I would like to leave Babylonia.', 4: '1'}"
    },
    {
        "Id": 31,
        "ActionId": 30,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'Watanabe? You know you will face a court-martial for that, don\\'t you?', 4: '2'}"
    },
    {
        "Id": 32,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'I\\'ve made up my mind. And you know, once I\\'ve decided to do something, nothing can stop me.', 4: '1'}"
    },
    {
        "Id": 33,
        "ActionId": 32,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'I know.', 4: '2'}"
    },
    {
        "Id": 34,
        "ActionId": 33,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'But why? Because of Cyril? Or...', 4: '2'}"
    },
    {
        "Id": 35,
        "ActionId": 34,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'Stop pretending like you care. I\\'m going to contact the ground military bases that have fallen out of the organization. Is that what you expected?', 4: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: '...As a military man, I understand how you feel.', 4: '2'}"
    },
    {
        "Id": 37,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'Well, I would kindly ask you for a favor then.', 4: '1'}"
    },
    {
        "Id": 38,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'But you do know Constructs are important assets of Babylonia, right?', 4: '2'}"
    },
    {
        "Id": 39,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: '...', 4: '1'}"
    },
    {
        "Id": 40,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'I know there\\'s one shuttle heading to the ground today, shipping \"scrapped\" Constructs.', 4: '1'}"
    },
    {
        "Id": 41,
        "ActionId": 40,
        "NextActionId": null,
