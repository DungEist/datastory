        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Watanabe', 3: 'Actually, I also wanted to talk to you.', 4: '1'}"
    },
    {
        "Id": 29,
        "ActionId": 28,
