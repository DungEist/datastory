        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Hassen', 3: 'Seeing your contribution to the last operation, HQ decided to officially grant you access to Babylonia.', 4: '2'}"
    },
    {
        "Id": 25,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
