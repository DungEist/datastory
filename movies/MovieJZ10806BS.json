        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: '(Lets out a bitter smile) But you know I wasn\\'t talking about the frames.', 4: '2'}"
    },
