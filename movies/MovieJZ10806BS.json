        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 6: '1'}"
    },
    {
        "Id": 12,
        "ActionId": 11,
        "NextActionId": null,
