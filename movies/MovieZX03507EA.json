        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'You said so yourself, every member of the Church has its own unique story.', 4: '1'}"
    },
    {
        "Id": 90,
        "ActionId": 90,
        "NextActionId": null,
