        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'She gazes at her hands, wordlessly questioning all the expectations and resentments borne by this body.'}"
    },
    {
        "Id": 84,
        "ActionId": 84,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'I will never deny that.', 4: '1'}"
    },
    {
        "Id": 85,
        "ActionId": 85,
        "NextActionId": null,
