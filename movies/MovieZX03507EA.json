        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Spooner', 3: 'The Church of Machina welcomes you. Arcana would be overjoyed to hear that.', 4: '2'}"
    },
    {
        "Id": 98,
        "ActionId": 98,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'Perhaps I shouldn\\'t say this, but I truly felt at home at the Church of Machina.', 4: '1'}"
    },
    {
        "Id": 99,
        "ActionId": 99,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'And I only ever felt that way when I spent time with Yoyo.', 4: '1'}"
    },
    {
        "Id": 100,
        "ActionId": 100,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'We can talk about anything and crack jokes, with no formality whatsoever or the need to guess what\\'s going through the other person\\'s mind...', 4: '1'}"
    },
    {
        "Id": 101,
        "ActionId": 101,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Spooner', 3: 'I suppose that\\'s what family is like.', 4: '2'}"
    },
    {
        "Id": 102,
        "ActionId": 102,
