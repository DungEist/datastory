        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'With a gentle smile, Hanying nods.'}"
    },
    {
        "Id": 94,
        "ActionId": 94,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'I just wanted to fulfill my past promise first. Nothing more.', 4: '1'}"
    },
    {
        "Id": 95,
        "ActionId": 95,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'Because... I am probably no longer welcomed on the Nighter—or Kowloong, for that matter—anymore.', 4: '1'}"
    },
    {
        "Id": 96,
        "ActionId": 96,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hanying', 3: 'Whether it is to repay the Sagemachina for awakening me, or for all the help I have received from the Church, I will eventually accept Arcana\\'s invitation and contribute what I can to the Church.', 4: '1'}"
    },
    {
        "Id": 97,
        "ActionId": 97,
