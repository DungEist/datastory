        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '2', 2: '10'}"
    },
    {
        "Id": 86,
        "ActionId": 86,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Spooner', 3: '...Sorry for reminding you of difficult times. I\\'m not very good at talking about profound topics like this.', 4: '2'}"
    },
    {
        "Id": 87,
        "ActionId": 87,
