        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'He slowly presses down on the plush\\'s \"<color=#ff4e4eff>:)</color>\" smile, crumpling it into a wrinkled mess.'}"
    },
    {
        "Id": 86,
        "ActionId": 86,
