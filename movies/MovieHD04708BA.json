        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'As the leader, there\\'s still a lot I need to do.', 4: '1'}"
    },
