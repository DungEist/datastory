        "BeginAnim": "AniZhuanchangEnd",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The top prize turns out to be a huge broccoli plush. Its fluffy top is styled like hair, and its thick green stalk features two stubby black eyes that squint at you two with a silly grin.'}"
    },
    {
        "Id": 75,
        "ActionId": 75,
