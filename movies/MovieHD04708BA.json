        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Carrying something that large makes walking awkward, so Watanabe suggests you rest a while. The two of you, and the broccoli, sit down on a nearby bench.'}"
    },
    {
        "Id": 76,
        "ActionId": 76,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'He sits beside you, gently fingering the tag on the back of the plush toy. As he speaks, his tone turns thoughtful.'}"
    },
    {
        "Id": 77,
        "ActionId": 77,
        "NextActionId": null,
