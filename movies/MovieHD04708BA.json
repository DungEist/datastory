        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'We\\'ve solved most of the food shortage issues, but it\\'s still a long way from what I hope for.', 4: '1'}"
    },
    {
        "Id": 89,
        "ActionId": 89,
        "NextActionId": null,
