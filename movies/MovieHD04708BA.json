        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Watanabe', 3: 'This broccoli plush was originally made by a well-known toy brand during the Golden Age.', 4: '1'}"
    },
    {
