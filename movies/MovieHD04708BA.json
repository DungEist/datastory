        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Together, Watanabe and you burst every balloon in a single run. The stall owner reluctantly hands over the top-shelf prize, then \"politely\" asks you two to leave.'}"
