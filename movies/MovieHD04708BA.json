        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'As he speaks, he notices that you\\'ve gone quiet. He stops kneading the plush\\'s face, lifts his head, and looks you in the eye.'}"
