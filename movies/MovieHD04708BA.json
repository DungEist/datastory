        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'Still... I wouldn\\'t mind living in that kind of time.', 4: '1'}"
    },
