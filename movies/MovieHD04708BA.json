        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'It\\'s been a long time since your last visit... I\\'d like to show you how much the camp has changed since then.', 4: '1'}"
