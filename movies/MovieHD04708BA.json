        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Watanabe', 3: 'If I had the choice, I\\'d want the children of Oasis to grow up like that too, to be able to say \"no\" to food they don\\'t like.', 4: '1'}"
    },
    {
