        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'The \"corruption data\" came from the game\\'s underlying source code. The cause of its emergence remains unknown.', 4: '1'}"
