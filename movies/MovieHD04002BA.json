        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'From what I can tell, it\\'s probably something that has to do with the \"deep learning logic\" in the game engine.', 4: '1'}"
