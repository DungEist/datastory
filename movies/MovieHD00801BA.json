        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'And then Ayla notices the CUB with the many wires and tubes attached to it, and she cannot help but run over to it and hugs it.'}"
    },
    {
        "Id": 57,
        "ActionId": 57,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'Is this critter the thing Leonie designed? What a cutie-pie! I think they also have an official name for it... Yuan something.', 4: '2'}"
    },
    {
        "Id": 58,
        "ActionId": 58,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Allen', 3: 'I believe it\\'s \"Yuan Ye,\" named by Leonie herself.', 4: '1'}"
    },
    {
