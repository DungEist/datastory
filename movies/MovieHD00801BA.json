        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Asimov', 3: 'You could just send this to our comms terminal... There\\'s no need to waste paper.', 4: '1'}"
