        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Ayla takes out a leaflet from her well-prepared folder and hands it to Allen, and she passes another one to Asimov.'}"
    },
    {
        "Id": 47,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ayla', 3: 'Have you forgotten already? The Culture Department of WGAA is hosting some festivities for Lunar New Year this year, but we still haven\\'t finalized a proposal, so they asked me to find you to join the meeting.', 4: '1'}"
    },
    {
        "Id": 48,
