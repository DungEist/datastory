        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'A female Construct in extravagant clothing walks in, and she quickly finds the person she is looking for from the two people in the lab.'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
        "NextActionId": null,
