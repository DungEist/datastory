        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'I felt my M.I.N.D. destabilize as I spoke the words, even though no harm had come to me. I recognized the emotion as \"embarrassment,\" but I resolved to finish the sentence nonetheless.'}"
    },
    {
        "Id": 48,
