        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'Just to be fair. They may have their own considerations on who to pair up with Lucia.', 4: '2'}"
