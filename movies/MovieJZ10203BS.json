        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Technician', 3: 'Understood. We\\'re allocating new members to Gray Raven... Do you have any special considerations, sir?', 4: '3'}"
