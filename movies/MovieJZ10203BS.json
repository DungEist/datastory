        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Understanding that Nikola had his mind set, the technician shakes her head and pulls up a selection of Military Construct files on the terminal.'}"
