        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'A pure mind begets an immaculate body, and vise versa. The mind and body wax and wane together. And Lucia is a supreme example of such a synergy.', 4: '1'}"
    },
