        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Liv and the probe—who claimed to be the Demon King—embarked on a new journey after running away from the guards.'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'Sorry for being rude, but are you really the Demon King? I thought he would be a black giant or something.', 4: '2'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
