        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Demon King', 3: 'I was like that until the heroes defeated me. I turned into this form to survive.', 4: '1'}"
