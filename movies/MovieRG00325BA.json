        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'But if the King knew he was a game character because of the bug, how did you find out about that?', 4: '2'}"
