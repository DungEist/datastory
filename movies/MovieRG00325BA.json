        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Demon King', 3: 'Let me make this clear: I don\\'t plan to take control of the world. In the past, the program made me destroy many cities and humans, and that really upset me. Now I am a Demon King of love and peace.', 4: '1'}"
    },
