        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The game didn\\'t end properly, and was suddenly reset until one day, when new heroes—Liv and others—entered again.'}"
    },
    {
