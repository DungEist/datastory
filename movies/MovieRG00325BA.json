        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Demon King', 3: 'Because I had a bug too.', 4: '1'}"
    },
    {
        "Id": 26,
        "ActionId": 26,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Demon King', 3: 'In the original ending, the King was supposed to turn into Kuroro and be defeated by the heroes. But they left the world too early.', 4: '1'}"
    },
    {
        "Id": 27,
        "ActionId": 27,
        "NextActionId": null,
