        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Demon King', 3: 'No matter how unrealistic, everybody still believes they are living in the \"real world\"...', 4: '1'}"
