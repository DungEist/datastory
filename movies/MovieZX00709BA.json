        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'We need to help Karen\\'s frame sleep to temporarily pause her M.I.N.D., then wait for support or help.', 4: '1'}"
