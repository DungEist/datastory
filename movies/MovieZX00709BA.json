        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'Like I said, I cannot discern the properties of that energy. But at the very least, her M.I.N.D. must be cooled off first.', 4: '1'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
