        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'But the issue is that, even though I\\'ve been externally sending in sleep commands, that energy is disrupting its execution.', 4: '1'}"
