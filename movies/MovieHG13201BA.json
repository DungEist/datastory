        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You knock on Egret\\'s door—except no one answers it.'}"
    },
    {
        "Id": 62,
        "ActionId": 62,
