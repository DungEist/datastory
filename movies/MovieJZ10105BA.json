        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Professor', 3: 'Don\\'t be so pessimistic, if the experiment succeeds, you\\'ll...', 4: '2'}"
    },
