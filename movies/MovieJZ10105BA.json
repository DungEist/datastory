        "EndDelay": null,
        "Params": "{1: '1', 2: 'Professor', 3: 'Your Tantalum-193 affinity is almost perfect. You\\'ll be an excellent subject.', 4: '2'}"
    },
    {
        "Id": 6,
        "ActionId": 6,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Professor', 3: 'Also, you asked, and I checked—your HLA matches with your younger brother\\'s. But, are you sure about this?', 4: '2'}"
    },
    {
        "Id": 7,
        "ActionId": 7,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Morian', 3: 'As long as you keep your end of the bargain—the money for the surgery, an urgent slot for the operation, a guaranteed normal life for Murray afterward, and... my heart transplantation.', 4: '1'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Professor', 3: 'Not only so, but I\\'ll also ensure your younger brother the highest degree of privileges for the rest of his life, even... a ticket to \"Babylonia\".', 4: '2'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
