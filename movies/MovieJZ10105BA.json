        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Morian', 3: '...As long as Murray\\'s safe.', 4: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Professor', 3: 'I did also test your brother\\'s Tantalum-193 affinity, and it\\'s also quite high. Would you perhaps consider an artificial heart for him? Then you wouldn\\'t have to take this risk.', 4: '2'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Morian', 3: 'Don\\'t even think about touching my brother. I know full well the danger of your experiments. You\\'re gambling with our lives. I\\'ll take the risk, so that my brother can stay out of this.', 4: '1'}"
    },
    {
        "Id": 12,
