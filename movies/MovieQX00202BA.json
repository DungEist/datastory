        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'What do you think about that story, Commandant? The lovers did not attempt to break their curse even if it meant they could only meet once a year... Wasn\\'t that a little bit cowardly?', 4: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 11,
