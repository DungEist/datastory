        "ActionId": 6,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It was unexpected—neither the organizers nor the audience were prepared. Everyone had to take shelter in nearby buildings, waiting for it to clear up.'}"
    },
