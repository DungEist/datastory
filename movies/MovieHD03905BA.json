        "ActionId": 5,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'My terminal says an ecological module in the residential area broke down, messing up the water cycle and causing this heavy rain.'}"
    },
