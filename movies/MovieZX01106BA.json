        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Consistent, rigorous, and well-crafted. All the mechanoids and equipment adopt the same operating system.', 4: '3'}"
    },
    {
        "Id": 22,
        "ActionId": 15,
        "NextActionId": null,
        "Type": 301,
