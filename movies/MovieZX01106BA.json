        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'Yes... I tried hacking into them but didn\\'t find a single vulnerability...', 4: '2'}"
    },
    {
        "Id": 20,
        "ActionId": 112,
        "NextActionId": null,
