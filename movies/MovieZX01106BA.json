        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: '...It\\'s likely, Commandant. Our coordinates, our headcount, and even video data of us in combat... have already fallen into someone else\\'s hands.', 4: '1'}"
    },
    {
