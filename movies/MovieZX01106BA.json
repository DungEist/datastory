        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'We might have been led to this storage on purpose.', 3: '21', 4: 'It\\'s a trap!', 5: '21'}"
    },
