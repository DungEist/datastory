        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The blinking signals of servers in the server room form a brilliant sea. The tall server cabinets look like solemn monuments, making the people working among them look like dust.'}"
