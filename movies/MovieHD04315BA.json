        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The elderly backcountry caretaker yawns as he points to a deep, dark tunnel entrance nearby. The twilight sunlight stops right before it reaches the tunnel\\'s entrance, and the weeds growing alongside have reached half a person\\'s height.'}"
    },
