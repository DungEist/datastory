        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'Within a ten-mile radius, this tunnel is the only place without a signal, so I didn\\'t have to guess too far.', 4: '1'}"
