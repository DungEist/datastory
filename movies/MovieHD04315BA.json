        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You\\'ve come so far now, that the entrance has long since been swallowed by darkness. Turning back now would present the same problems as moving forward.'}"
