        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The imaginary spooks don\\'t seem to bother you as much as this endless solitude you now find yourself in...'}"
