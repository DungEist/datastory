        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Says the person with a mysterious smile. When you turn it over, you see a line of words staring back at you—Dare Challenge: Reach Lake Moon\\'s Edge by nightfall.'}"
    },
    {
        "Id": 7,
        "ActionId": 7,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Lake Moon\\'s Edge? You remember it being a scenic spot somewhere in Constellia. According to the map, it\\'s a stone\\'s throw away from where you are now.'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'There is, however, no sign of Luna anywhere. She\\'s most likely already on her way to the lake.'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Let\\'s go.', 3: '10'}"
    },
    {
