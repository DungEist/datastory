        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Walking through this boundless tunnel... you find your feet growing numb and thoughts dull by the second.'}"
