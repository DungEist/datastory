        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Luna falls silent, perhaps having realized she was becoming increasingly agitated.'}"
    },
    {
        "Id": 58,
        "ActionId": 58,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'She turns her face away and falls into an awkward silence.'}"
    },
    {
        "Id": 59,
        "ActionId": 59,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'With nowhere to rest your gaze in the awkward silence, you notice the source of the glow around her—the night light you gave her.'}"
    },
    {
        "Id": 60,
        "ActionId": 60,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'And this tunnel is so narrow and endlessly dark.'}"
    },
    {
        "Id": 61,
        "ActionId": 61,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Getting here meant enduring prolonged loneliness and darkness—and having experienced all that firsthand yourself, you know that Luna must have had to go through the same torment, too, coming to search for you.'}"
    },
    {
        "Id": 62,
        "ActionId": 62,
