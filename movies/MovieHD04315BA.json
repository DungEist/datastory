        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Just as you start walking, you see a massive mountain that stands right between you and Lake Moon\\'s Edge.'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'To reach the lake, you\\'d need to climb over this mountain, and you can\\'t even see how far up it goes from where you\\'re standing.'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
