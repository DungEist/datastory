        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You try but to no avail to see where you are with your terminal, having been stripped of reception. You turn on your flashlight, only to see its beam devoured by the enveloping darkness.'}"
