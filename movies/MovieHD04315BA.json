        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The pitch-black tunnel gives off a bone-chilling coldness... but it\\'s the only available alternative to the mountain.'}"
    },
    {
