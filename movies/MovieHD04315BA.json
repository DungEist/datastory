        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: '(Well, guess I don\\'t have much of a choice here.)', 3: '19', 4: '(Luna is waiting for me.)', 5: '19'}"
