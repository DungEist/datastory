        "Id": 35,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'I don\\'t think a fake paradise like Babylonia will provide them with a real future.', 4: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'The silly, purposeless decorations, the childlike innocence, and the essence of a human being...', 4: '1'}"
