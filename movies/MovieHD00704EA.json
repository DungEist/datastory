        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'Even when they\\'re forsaken on Earth, kids are still gonna be kids... With their kid logic and priorities and choices.', 4: '1'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
