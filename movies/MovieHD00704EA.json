        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'Some things don\\'t get taken away by a catastrophe. That\\'s why I stayed behind.', 4: '1'}"
    },
    {
        "Id": 29,
        "ActionId": 29,
        "NextActionId": null,
