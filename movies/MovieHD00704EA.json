        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'I\\'ve been asked to keep you safe, 【kuroname】, understood? I know it\\'s supposed to be your solo mission, but we better be safe than sorry.', 4: '1'}"
