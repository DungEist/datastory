        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Watanabe', 3: 'Maybe. But whatever it is, they are the children of the Forsaken, and they are the future of humankind.', 4: '1'}"
    },
