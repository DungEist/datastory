        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It might have been a lament, or maybe acceptance. Watanabe covers the sleeping children with his blanket, his motion remarkably gentle.'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
