        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'When you finally wake, you start at the sight of Lucia sitting in the corner of your quarters, calm as a lotus flower.'}"
    },
    {
        "Id": 6,
        "ActionId": 6,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Commandant, you\\'re finally awake.', 4: '1'}"
    },
    {
        "Id": 7,
        "ActionId": 101,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
