        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1000000', 2: 'Someone has to do it. I\\'m glad that I have earned your trust.', 4: '100000230'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 708,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1000000', 2: 'I know you picked the name Hippocrates to remind your student not to betray the oath they made.', 4: '100000231'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 708,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1000000', 2: 'Just like the day I made my oath, I still wish to dedicate my life to the service of humanity. The well-being of my patients always comes first. I will respect the autonomy and dignity of all lives.', 4: '100000232'}"
    },
    {
        "Id": 25,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 708,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1000000', 2: 'It is my greatest honor to be your student and grow under everyone\\'s care.', 4: '100000233'}"
    },
    {
        "Id": 26,
        "ActionId": 26,
        "NextActionId": null,
        "Type": 708,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1000000', 2: 'That\\'s why I will never forget the Hippocratic Oath. Because that is all I wish for.', 4: '100000234'}"
    },
    {
        "Id": 27,
        "ActionId": 27,
        "NextActionId": null,
        "Type": 708,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '600002', 2: '...It seems like there\\'s nothing else I can teach you.', 3: 'Assets/Product/Texture/Image/RoleCharacter/XibokeladiNormal01.png', 4: '100000227', 7: '1'}"
    },
