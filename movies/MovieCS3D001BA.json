        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1000000', 2: 'It\\'s my duty. Everyone is counting on me.', 4: '100000229'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 708,
