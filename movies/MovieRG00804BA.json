        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Valeri', 3: 'This is the only way we stand a chance until backup arrives.', 4: '1'}"
    },
