        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Valeri', 3: 'I\\'m afraid it\\'s already too late.', 4: '1'}"
    },
    {
