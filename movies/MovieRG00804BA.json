        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Valeri', 3: 'New Sophiasburgh still needs you, and that \"ideal\" is waiting for you to fulfill it. Your journey doesn\\'t end here.', 4: '1'}"
