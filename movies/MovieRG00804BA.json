        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The old man warns her, pointing at the ceiling that\\'s on the verge of giving way. The battered structure continues twisting and cracking under the mechanoid guards\\' attacks.'}"
    },
