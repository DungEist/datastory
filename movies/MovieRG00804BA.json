        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Tatyana', 3: 'We can make our escape as the stone chamber collapses. The Forest Guards will have our backs—so long as we can keep the falling debris off us...', 4: '2'}"
    },
    {
        "Id": 39,
        "ActionId": 39,
