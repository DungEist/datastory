        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Valeri', 3: 'They\\'re aiming to take us out along with those mechanoids... It might be an old-fashioned approach, but it definitely works.', 4: '1'}"
    },
    {
        "Id": 31,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Valeri', 3: 'So, there\\'s only one way around this: have someone lure all the guards, then trigger these traps and knock them out in one go.', 4: '1'}"
    },
    {
        "Id": 32,
        "ActionId": 32,
        "NextActionId": null,
