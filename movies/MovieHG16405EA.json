        "Params": "{1: '1', 3: 'Under the cold, dim light of the testing ground, Nirvatia gently touches your cheek, her eyes crinkling slightly.'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 204,
