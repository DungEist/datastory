        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'We\\'ve secured the key evidence. There\\'s still time before we confront Walden.', 3: '12'}"
    },
    {
