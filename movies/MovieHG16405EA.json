        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nirvatia', 3: 'Her final words deserve to be spoken in the place where she poured her heart and soul.', 4: '1', 18: '100015788'}"
    },
    {
