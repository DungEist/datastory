        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Decommissioned mechanoids still spark occasionally, while dust has collected on the workbench where she once worked. Silence envelopes everything, broken only by the hum of her frame\\'s operation and the soft rhythm of your breathing.'}"
    },
    {
