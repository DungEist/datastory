        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nirvatia', 3: 'I\\'m fine, just a little tired. I\\'m leaning on you for a quick \"recharge.\"', 4: '1', 18: '100015786'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
