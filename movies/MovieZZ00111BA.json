        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'After all, most of the systems developed by the ARU at this time were like this—for example, the mech narwhal. So, I didn\\'t pay much attention to it.', 4: '1'}"
    },
    {
