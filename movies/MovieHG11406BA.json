        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The campfire flares up, burning and blooming like a blossom. The embers dance sporadically in the air, become taken by the Arctic wind, then fall and go out on the snow.'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
