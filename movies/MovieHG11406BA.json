        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Rosetta is about to badger you into sleeping again, but a sudden tremor causes her to pause.'}"
    },
    {
        "Id": 30,
        "ActionId": 30,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'It\\'s... raining?', 4: '1'}"
    },
    {
        "Id": 31,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'This is the first time I\\'ve seen it rain here.', 3: '32', 4: 'Do you have an umbrella?', 5: '33'}"
    },
    {
        "Id": 32,
        "ActionId": 32,
        "NextActionId": 34,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'No, not just that... Coupled with the tremors—Commandant, I recommend that we hurry up and take shelter.', 4: '1'}"
    },
    {
        "Id": 33,
        "ActionId": 33,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'We might have a situation, Commandant. We need to find shelter ASAP.', 4: '1'}"
    },
    {
        "Id": 34,
        "ActionId": 34,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Seeing the rain, Rosetta immediately wields her weapon. Her eyes meet your befuddled ones.'}"
    },
    {
        "Id": 35,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'Commandant, remember what the bear said about working at the climate station?', 4: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Yes.', 3: '37', 4: 'Did he cause those tremors?', 5: '38'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
        "NextActionId": 39,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'I don\\'t have any evidence, but based on the change in weather, there may be something wrong with the climate station.', 4: '1'}"
    },
    {
        "Id": 38,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'No, I don\\'t think so. But it looks like there\\'s a problem with the climate station.', 4: '1'}"
    },
    {
        "Id": 39,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'Earthquakes, rain... Who knows what might come next. I\\'m worried that the tent won\\'t keep us safe out here in the snowfield.', 4: '1'}"
    },
    {
        "Id": 40,
        "ActionId": 40,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'Anyway, come with me, quick. There should be a Forest Guard shelter up ahead.', 4: '1'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
        "NextActionId": null,
        "Type": 101,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
