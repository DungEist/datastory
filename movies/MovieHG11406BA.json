        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'The engineers also said that this is kind of a vacation. Most of them were just reluctant to leave the engineering bay.', 4: '1'}"
    },
    {
        "Id": 14,
        "ActionId": 14,
        "NextActionId": null,
