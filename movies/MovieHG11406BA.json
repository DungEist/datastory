        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Rosetta', 3: 'Campfire ready, tent is up, and we got fish from the bear... Good, all ready.', 4: '1'}"
