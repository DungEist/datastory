        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Celica', 3: 'This year, they\\'re hosting another Double Seventh event in Constellia. It\\'s rumored to be huge, and its branches from all over the world are coming to join in.', 4: '1'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
