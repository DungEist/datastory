        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Celica', 3: 'They\\'re holding a special Double Seventh event in each of these areas, making every zone feel unique.', 4: '1'}"
    },
