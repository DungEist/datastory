        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Celica', 3: 'They\\'ve rented out an entire park for the occasion, dividing it into different sections. Each section features a distinct environment or culture—like Kowloong, the Polar region, or the desert...', 4: '1'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
