        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Haicma', 3: 'Are you able to travel back in time, Sagemachina?', 4: '2'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nanami', 3: 'When I first arrived, I didn\\'t know exactly what happened. After witnessing so many sad stories, I came to realize that...', 4: '1'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nanami', 3: 'Just like mecha babushka told me when she sent me here. This is the future of Earth. This is the doomsday for humanity.', 4: '1'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nanami', 3: 'Mecha babushka must be hoping that I can figure out what has happened, so I can avoid the catastrophic future...', 4: '1'}"
    },
    {
        "Id": 25,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
