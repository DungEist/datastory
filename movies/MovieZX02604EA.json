        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nanami', 3: 'That\\'s not what I mean...!', 4: '1'}"
    },
    {
        "Id": 29,
        "ActionId": 29,
