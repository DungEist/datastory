        "ActionId": 33,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Haicma', 3: 'This world is everything I have experienced. To me, this place and its history are real. This is where I belong.', 4: '2'}"
