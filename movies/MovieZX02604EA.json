        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Haicma', 3: 'Are you suggesting... that I am but a piece of data simulated in a program?', 4: '2'}"
    },
    {
        "Id": 27,
        "ActionId": 27,
        "NextActionId": null,
        "Type": 204,
