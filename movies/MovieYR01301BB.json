        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Those were pure mechanical and probabilistic calculations. There\\'s nothing wrong with that.', 4: '2'}"
