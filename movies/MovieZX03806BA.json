        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Echo', 3: 'I can\\'t remember exactly, but Utopia did take in a lot of people every once in a while. Some of them were humans, and some were heavily injured Constructs.', 4: '1'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
