        "Params": "{3: 'Babylonia has registered Conservation Area 112 as a \"Hetero-Creature-ambushed conservation area\", an outpost destroyed because of Hetero-Creatures.'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
