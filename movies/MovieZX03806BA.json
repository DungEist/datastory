        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Echo', 3: 'Cecily came from Babylonia, as a matter of fact. For some reason, she always shook her head with a smile when I asked about Babylonia as if... she was upset.', 4: '1'}"
    },
