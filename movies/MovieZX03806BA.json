        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Echo', 3: 'I occasionally talked to them in between classes. All I remember is they seemed to come from many different places—conservation areas, Forsaken, even... Babylonia.', 4: '1'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
