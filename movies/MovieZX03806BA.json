        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Only a few residents who went out to gather supplies managed to escape. Everyone else inside the conservation area, including the Task Force that went to help, did not survive the incident.'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
