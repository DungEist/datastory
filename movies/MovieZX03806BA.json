        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It was a while before some remains were found in the nearby field, but even those could not be confirmed to belong to residents from Conservation Area 112.'}"
    },
