        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'However, if Asimov saw records of this conservation area in the internal experiment reports from Fort Winter...'}"
