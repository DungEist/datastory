        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'What exactly do you mean? I hope we can settle it during this break before I return to work on the documents.', 4: '1'}"
    },
    {
