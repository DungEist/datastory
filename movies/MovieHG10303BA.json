        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv, you\\'ve been acting like someone else.', 3: '7', 4: 'N-nothing...', 5: '8'}"
