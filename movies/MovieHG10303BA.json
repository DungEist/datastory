        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'Am I sensing concerns about how my personality has changed?', 4: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'I understand that you will worry about my attitude and approach, Commandant.', 4: '1'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'Let\\'s put it this way. I haven\\'t become someone else. I\\'ve merely adapted to suit our situation better.', 4: '1'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
