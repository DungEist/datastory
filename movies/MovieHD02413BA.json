        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Having mentally prepared himself before the meeting, Freeman\\'s words flow effortlessly from his mouth, devoid of any hesitation.'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Freeman', 3: 'I\\'m fully aware of my limitations. When it comes to the stability of the Mind Beacon, I don\\'t meet the standard to become a commandant. In terms of strategic and tactical theory, I fall short of the threshold for the General Staff.', 4: '1'}"
    },
    {
        "Id": 14,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Freeman', 3: 'After my parents died in the war, my sister developed hemophobia, making it impossible for her to study at F.O.S. with the same financial support that I\\'ve received.', 4: '1'}"
    },
    {
        "Id": 15,
        "ActionId": 15,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Freeman', 3: 'My parents\\' pension is not enough to cover my sister\\'s education, so I have to become a commandant... or a Construct.', 4: '1'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Freeman', 3: 'Now that I don\\'t seem to have the talent to become a commandant, my only option is to choose the latter.', 4: '1'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Freeman', 3: 'Instructor, it\\'s not that I want to become a Construct. It\\'s that I have no other choice but to become one.', 4: '1'}"
    },
