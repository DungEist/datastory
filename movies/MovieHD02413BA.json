        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Instructor', 3: 'I can tell how determined you are from your application, but I still want to confirm with you one last time as your instructor.', 4: '1'}"
