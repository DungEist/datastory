        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Vera', 3: 'Is Kurono the one responsible for developing No. 21\\'s new frame now?', 4: '1'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Yes.', 4: '2'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'Under who\\'s order?', 4: '1'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: '...', 4: '2'}"
    },
    {
        "Id": 25,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: '...Forget it.', 4: '1'}"
    },
    {
        "Id": 26,
        "ActionId": 26,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'We\\'d need a lot of help from Kurono even if we wanted to design it ourselves. We have no data on her current design.', 4: '2'}"
    },
    {
        "Id": 27,
        "ActionId": 27,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'This frame might just become the victim of some complicated war one day.', 4: '2'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'It\\'s better to let one party complete the entire design, rather than have both sides be skeptical about the other\\'s design.', 4: '2'}"
    },
    {
        "Id": 29,
        "ActionId": 29,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'For developers, getting the new frame to work is the only way to obtain new, valid data.', 4: '2'}"
    },
    {
        "Id": 30,
        "ActionId": 30,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'So I can understand why he decided to hand over the authority of design.', 4: '2'}"
    },
    {
        "Id": 31,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'But I can promise you that I hold significant influence even if I can only supervise the process.', 4: '2'}"
    },
    {
        "Id": 32,
        "ActionId": 32,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'I would like to receive a copy of every progress and compatibility report. This is a reasonable request from the supervisor of No. 21, right?', 4: '1'}"
    },
    {
        "Id": 33,
        "ActionId": 33,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'I\\'ll see to it as long as classified development information is kept safe.', 4: '2'}"
    },
    {
        "Id": 34,
        "ActionId": 34,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '1'}"
    },
    {
        "Id": 35,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'On behalf of No. 21, I really appreciate your help.', 4: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The red-haired Construct puts on a bright smile, but under her perfect smile stirs raging, suppressed anger.'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
