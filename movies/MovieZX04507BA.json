        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'Haha! Yeah! I lived here before the Punishing outbreak! But I was so small back then, so I can\\'t remember much.', 4: '1'}"
