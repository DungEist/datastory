        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Lee', 3: 'From the radar readings and Changyu\\'s description, this should be the port Commandant\\'s signals came from.', 4: '3'}"
    },
    {
        "Id": 7,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'We can\\'t get a more precise set of coordinates. Our radars are not only being interfered with, but Commandant\\'s signal is being blocked and double-encrypted.', 4: '3'}"
    },
    {
        "Id": 8,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Asslam just took heavy damage and their combative capability is limited. Sophia and Changyu both expressed wishes to join in our rescue of Commandant, but it might not be appropriate.', 4: '3'}"
    },
    {
        "Id": 9,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Yes, we\\'ll have to find Commandant by ourselves.', 4: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Changyu\\'s suggestion is that we wait here for... that legendary \"ship\".', 4: '3'}"
    },
    {
        "Id": 11,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Let\\'s do another ground search. We might have missed something. Commandant...', 4: '1'}"
    },
    {
