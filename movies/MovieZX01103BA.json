        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Calm your M.I.N.D. The signal didn\\'t die off suddenly, so Commandant must have disconnected it on purpose. No harm should have come to Commandant.', 4: '3'}"
    },
    {
        "Id": 16,
        "ActionId": 18,
