        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Roland', 3: 'Unfortunately, they\\'ve cast me in a horror story instead of a fairy tale today... I\\'m the snake that feeds the princess her poisoned apple.', 4: '1'}"
