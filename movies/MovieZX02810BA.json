        "EndDelay": null,
        "Params": "{1: '1', 2: 'Roland', 3: 'Wasn\\'t expecting to actually start the ship on my own... I guess the piloting skills I learned for my character back then haven\\'t been completely forgotten.', 4: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
