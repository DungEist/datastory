        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Roland keeps trying to remember, yet all he can recall is that he was not picked as the main character—he might have been a talented child actor, but he never could become the lead.'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
