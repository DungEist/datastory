        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noan', 3: 'Yeah. I\\'ve met my share of people from Kowloong before. They mentioned their customs and the story behind it, but I never saw them celebrate it.', 4: '1'}"
    },
    {
        "Id": 8,
        "ActionId": 10,
