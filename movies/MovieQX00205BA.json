        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noan', 3: 'Thank you, then. I didn\\'t know you were supposed to give gifts on this day. I would have prepared something for you otherwise.', 4: '1'}"
    },
    {
        "Id": 9,
        "ActionId": 11,
        "NextActionId": null,
