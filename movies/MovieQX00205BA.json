        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'It\\'s fine. It\\'s just a club activity, anyway. Let\\'s open it!', 3: '12'}"
    },
    {
