        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'All those calculated men are so damn stupid. They will not stop fighting each other even when everything is at stake.', 4: '1'}"
