        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'I just think that everything we\\'re doing now is stupid and meaningless.', 4: '1'}"
    },
