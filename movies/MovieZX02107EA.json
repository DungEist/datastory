        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vera', 3: 'The Parliament... Kurono... and this mission are all stupid to their core.', 4: '1'}"
