        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'You think this mission is pointless.', 3: '53', 4: 'You are angry.', 5: '59'}"
