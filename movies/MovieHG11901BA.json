        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'If you\\'re too busy with work and have no time for stuff like this, feel free to toss this letter into the trash.', 2: '0000ffff', 3: '1', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
