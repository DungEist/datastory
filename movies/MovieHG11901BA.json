        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Iris', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1', 9: '1'}"
    },
    {
        "Id": 54,
        "ActionId": 54,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
