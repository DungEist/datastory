        "Params": "{3: '...'}"
    },
    {
        "Id": 20,
        "ActionId": 20,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "AniZhuanchangEnd",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'I\\'m glad you\\'re reading this line. This means this letter hasn\\'t ended up crushed in the trash can.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Please don\\'t get me wrong. This is not a prank.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Truth be told, I\\'m looking for a \"pen pal\".', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '<para\\>I\\'m not sure if you know what a \"pen pal\" is.<para\\>I only learned of it recently when I saw it in a book from the Center of Basic Public Education\\'s library.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Basically, pen pals build a friendship by writing letters to each other.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 25,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'People say that, a long time ago, before the information age arrived, people would write letters to communicate across vast distances.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 26,
        "ActionId": 26,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Perhaps you might think that such an inefficient and costly way of communicating is tedious and a waste of time.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 27,
        "ActionId": 27,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'But when I saw this method, it just seemed so...', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1', 9: '1'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "AniZhuanchangEnd",
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The next word was crossed out several times, and it was obvious that the writer was weighing their words over and over.'}"
    },
    {
        "Id": 29,
        "ActionId": 29,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "AniZhuanchangEnd",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Romantic.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 30,
        "ActionId": 30,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Romantic. Yes, that\\'s right, it\\'s the type of romance that we lack in this era.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 31,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'An era in which everyone is always in a hurry, in pursuit of maximum levels of efficiency.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 32,
        "ActionId": 32,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'The act of finding stillness and putting your thoughts on paper is simply inconceivable.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 33,
        "ActionId": 33,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'There are even times when I feel that the written word is better than spoken language when it comes to expressing what\\'s deep in your heart.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 34,
        "ActionId": 34,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'No matter where I am, things like good etiquette and upbringing... weigh heavily on my shoulders, smothering me.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 35,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'It\\'s only when I\\'m writing that I can cast off those shackles and be myself.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'The words I can never speak, the feelings inside I can\\'t say out loud... the written word will say what my voice can\\'t.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'What\\'s more, I won\\'t have to deal with the immediate reaction from others, nor will I feel ashamed of the unseemliness of my actions.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 38,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'I can write whatever I want on paper and the words that appear on the page reflect who I am inside.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 39,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'I seem to be blabbering. Forgive me for being so immature as to get overexcited and let my emotions get the better of me over such a small matter.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 40,
        "ActionId": 40,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Anyway, since you\\'ve read up to this point, you should already have guessed.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1', 8: '1'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'I would like you, a stranger, to be my pen pal.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 42,
        "ActionId": 42,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '<para\\>At first, I was thinking of trying out this method of communication with my friends, <para\\>but I came to realize that it was too deliberate, making it more awkward than it should be.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 43,
        "ActionId": 43,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'So I started contemplating sending this letter to a random address in Eden, to a stranger I\\'ve never met.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 44,
        "ActionId": 44,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'I don\\'t need to know who you are. Neither do you need to know who I am.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 45,
        "ActionId": 45,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'All we have to do is use this antiquated but simple method of communication to slowly get to know each other.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 46,
        "ActionId": 46,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Let me briefly introduce myself. I\\'m Iris and as you\\'ve probably guessed, this is not my real name, but rather, a pen name.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 47,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Well, that\\'s enough about me. After all, you might not want to know everything about a stranger\\'s life all at once.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 48,
        "ActionId": 48,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Perhaps we can talk about our hobbies in our next letter and share what we\\'re passionate about.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 49,
        "ActionId": 49,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'I\\'ve attached a return envelope and a blank sheet of paper with this letter. I hope to hear from you.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 50,
        "ActionId": 50,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'If you\\'re too busy with work, don\\'t worry about it. This shouldn\\'t be an onerous process.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 51,
        "ActionId": 51,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'All you have to do is to write your thoughts on the subject down. I\\'ll be really happy with just that.', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 52,
        "ActionId": 52,
        "NextActionId": null,
        "Type": 304,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'Yours faithfully,', 2: '0000ffff', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1'}"
    },
    {
        "Id": 53,
        "ActionId": 53,
        "NextActionId": null,
