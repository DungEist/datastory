        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: 'But if you do happen to have some free time or are looking for a way to kill time, please consider flipping over to page two.', 2: '0000ffff', 3: '1', 4: 'Assets/Product/Texture/Image/BgStory/BgStory00.png', 6: '1', 9: '1'}"
