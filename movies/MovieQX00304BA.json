        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'Memories vary across time periods, identities, and places; no two people will recall the same event exactly the same way.', 4: '1'}"
