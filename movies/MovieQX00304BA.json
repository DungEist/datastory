        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'Whether it\\'s about glorifying or altering, what endures is more important. They morph into their own stories.', 4: '1'}"
