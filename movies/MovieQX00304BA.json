        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'Such changes seem a bit self-centered; it\\'s hard for me to pass judgment.', 4: '1'}"
