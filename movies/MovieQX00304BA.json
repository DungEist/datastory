        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'I struggled to appreciate its beauty at first. By the time I started to understand, there were hardly any places left to hear it.', 4: '1'}"
