        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'There used to be troupes invited to perform in the city, but then, other forms of entertainment completely took over.', 4: '1'}"
    },
    {
