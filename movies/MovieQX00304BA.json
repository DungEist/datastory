        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'It seems like it\\'s just trying to hold onto and show off what it once had. Wishful thinking, perhaps.', 4: '1'}"
