        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'The art of Kowloong Opera has been on the brink of extinction for ages. Sometimes I wonder if it\\'s already gone.', 4: '1'}"
    },
    {
        "Id": 31,
        "ActionId": 31,
        "NextActionId": null,
