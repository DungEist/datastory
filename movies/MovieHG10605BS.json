        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'But having fought side by side for so long, I more or less know what the commandant is feeling and thinking.', 4: '2'}"
    },
    {
        "Id": 14,
        "ActionId": 13,
        "NextActionId": null,
