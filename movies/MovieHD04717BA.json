        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You quietly read out the key points of each file, then write your responses, adding your own judgment and suggestions.'}"
