        "ActionId": 64,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'The meaning behind this proposal is pretty obvious. So, 【kuroname】, what are you going to do with it?', 4: '1'}"
    },
