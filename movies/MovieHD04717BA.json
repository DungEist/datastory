        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Qu', 3: 'Plenty of people on my side have had their eye on you for a long time, Commandant. They keep suggesting I find a reason to bring you back to Kowloong, as my partner.', 4: '1'}"
    },
    {
