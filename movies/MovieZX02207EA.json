        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'They form small-scale Red Tides everywhere with Corrupted activities, breaking down machines and attacking humans, rapidly raising the virus concentration in the area, and turning more and more areas into Dead Zones.', 4: '1'}"
    },
    {
        "Id": 49,
