        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'Hetero-Creatures, as a product of the Punishing Virus, are rising from mechanoids that have been infected.', 4: '1'}"
    },
    {
        "Id": 48,
        "ActionId": 48,
        "NextActionId": null,
