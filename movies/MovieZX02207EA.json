        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'Based on our observation, the global Punishing Virus concentration is rising exponentially.', 4: '1'}"
