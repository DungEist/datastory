        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'Babylonia is actively preparing a response for it. All Task Force members, remember your duties as a soldier. Hold your position, protect the civilians, and wait for our notice.', 4: '1'}"
    },
