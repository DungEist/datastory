        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: '...59 seconds have passed. Some mechanoids are beginning to move, but the web is still here...', 4: '1'}"
