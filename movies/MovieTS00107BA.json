        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'I\\'ve deduced that this \"shift pattern\" exists because of the differences in their mechanoid models.', 4: '1'}"
