        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Bridget', 3: 'Beautiful, isn\\'t it? Few people come here. That\\'s why I love it here.', 4: '1'}"
