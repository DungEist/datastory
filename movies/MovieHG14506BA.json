        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'The first time I had cotton candy was when Dad got one for me. I was so little at the time that most memories have faded, but I still remember...', 4: '1'}"
