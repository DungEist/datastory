        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'I would have had a normal childhood. I would go to school, come home after classes, and spend weekends shopping with my parents.', 4: '1'}"
