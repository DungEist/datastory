        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'Maybe Mom would have made me take dance lessons. She always loved telling us how she taught Dad to waltz.', 4: '1'}"
