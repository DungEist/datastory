        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Bridget', 3: 'Whenever I sit here and gaze at Earth, I can\\'t help but wonder...', 4: '1'}"
