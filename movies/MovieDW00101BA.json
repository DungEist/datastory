        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Having lived on board for such a long time, Pulao has conflicted feelings about the Nighter.'}"
    },
