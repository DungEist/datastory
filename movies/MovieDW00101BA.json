        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Pulao', 3: 'Be careful! Lash the corners tight. Did they not teach you how to tie knots?', 4: '1'}"
    },
    {
        "Id": 8,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Pulao is directing the Nighter crew to move the vast amounts of cargo still on board the ship.'}"
    },
    {
        "Id": 9,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pulao', 3: 'There is only so much that we can carry. All this precious cargo, supplies that have kept the Voyage afloat for all this time. A tragedy, to be honest......', 4: '1'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
