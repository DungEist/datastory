        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Pulao', 3: 'They\\'ve all scurried ashore and left this mess for me to clean up. The Nighter is so quiet—eh? Perhaps not so quiet after all.', 4: '1'}"
    },
