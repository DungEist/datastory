        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'I read about the festival in a book before. I was quite interested in this form of art, so I still remember bits of it.', 4: '2'}"
