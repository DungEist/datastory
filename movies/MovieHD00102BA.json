        "IsEnd": null,
        "BeginAnim": "RImgBg1Shake",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"Thud!\" You hear a container falling behind you, and a familiar voice follows.'}"
    },
