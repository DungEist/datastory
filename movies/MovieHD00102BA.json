        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'I don\\'t need your apology... Forget it. Good to have you back.', 4: '1', 18: '100001109'}"
