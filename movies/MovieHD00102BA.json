        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'You still remember my interest, Commandant... Liv was the one who placed the plant here, indeed.', 4: '1', 18: '100001124'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
