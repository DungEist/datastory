        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You have not been back here for a while. You were fully expecting to be forgotten, but a surging familiarity surrounds you the moment you step inside the lounge.'}"
    },
    {
        "Id": 4,
        "ActionId": 4,
        "NextActionId": null,
