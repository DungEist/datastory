        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'This is your plant, Lucia?', 3: '19'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I thought it was Liv\\'s.', 3: '20', 4: 'I don\\'t remember you being interested in them.', 5: '21'}"
    },
    {
        "Id": 20,
        "ActionId": 20,
        "NextActionId": 22,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'You still remember, Commandant. Liv was the one who placed the plant here, indeed.', 4: '1', 18: '100001123'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
        "NextActionId": null,
