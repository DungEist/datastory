        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'You don\\'t have to say anything, Commandant. We all understand the weight of our responsibility to save others, don\\'t we?', 4: '1', 18: '100001113'}"
    },
    {
        "Id": 88,
        "ActionId": 88,
        "NextActionId": null,
