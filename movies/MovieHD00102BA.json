        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'I\\'m sorry I\\'m late. The Star of Life requested my help earlier today, but I came as soon as I received Lucia\\'s message.', 4: '1', 18: '100001112'}"
    },
    {
        "Id": 84,
