        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Wait! I have to let Liv and Lee know immediately.', 4: '1', 18: '100001122'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
        "NextActionId": null,
        "Type": 301,
