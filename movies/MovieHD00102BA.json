    },
    {
        "Id": 35,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '1081001', 3: '1'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Kamui', 3: 'It\\'s you, 【kuroname】! No wonder Lee stopped the meeting so abruptly. You\\'re back!', 4: '1', 18: '100001132'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Kamui\\'s voice sounds exactly as you remember. He walks toward you, patting you on the arm and the back as if he last saw you yesterday, and he looks relieved.'}"
    },
    {
        "Id": 38,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Kamui', 3: 'Not bad! You seem to be in one piece and well-rested! Capt. and Wanshi would also love to see you, but they\\'re still carrying out a mission on the surface.', 4: '1', 18: '100001133'}"
    },
    {
        "Id": 39,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Kamui', 3: 'Let me tell them this good news—choose recipients... Let\\'s just tell everyone!', 4: '1', 18: '100001134'}"
    },
    {
        "Id": 40,
        "ActionId": 40,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Ah? There\\'s no need to make a big deal out of this!', 3: '41'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You hear the sound of his fingers tapping on the terminal before you can finish. Kamui smiles cheerfully, waving a victory sign at you.'}"
    },
    {
        "Id": 42,
        "ActionId": 42,
        "NextActionId": null,
        "Type": 202,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 6: '1'}"
    },
    {
        "Id": 43,
        "ActionId": 43,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'As expected, new guests soon arrive at the Gray Raven lounge.'}"
    },
    {
        "Id": 44,
        "ActionId": 44,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500494', 3: '13'}"
    },
    {
        "Id": 45,
        "ActionId": 45,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Karenina', 3: 'Here I thought something important happened, but it was just you... Hmph. You left without a word, and you came back without a heads-up.', 4: '1', 18: '100001102'}"
    },
    {
        "Id": 46,
        "ActionId": 46,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '6'}"
    },
    {
        "Id": 47,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Karenina', 3: 'Why are you staring at me? Do you not recognize me?! Who the hell let you go away for such a long time...', 4: '1', 18: '100001103'}"
    },
    {
        "Id": 48,
        "ActionId": 48,
        "NextActionId": null,
        "Type": 202,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 6: '1'}"
    },
    {
        "Id": 49,
        "ActionId": 49,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500128', 3: '1'}"
    },
    {
        "Id": 50,
        "ActionId": 50,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Bianca', 3: 'I trust Commandant\\'s decision, Karen.', 4: '1', 18: '100001098'}"
    },
    {
        "Id": 51,
        "ActionId": 51,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'There must be a mission-related reason that kept the commandant from telling us anything, but it\\'s okay. We\\'re together now.', 4: '1', 18: '100001099'}"
    },
    {
        "Id": 52,
        "ActionId": 52,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '2'}"
    },
    {
        "Id": 53,
        "ActionId": 53,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bianca', 3: 'That said, we\\'re all ears if you want to talk to us, Commandant.', 4: '1', 18: '100001100'}"
    },
    {
        "Id": 54,
        "ActionId": 54,
        "NextActionId": null,
