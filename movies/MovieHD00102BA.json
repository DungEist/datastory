        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I\\'m sorry.', 3: '66', 4: 'There won\\'t be a next time.', 5: '67'}"
    },
    {
