        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'Don\\'t feel sorry or pressured, Commandant. We\\'ll walk this path together from now on.', 4: '1', 18: '100001116'}"
    },
    {
        "Id": 92,
        "ActionId": 92,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Liv\\'s eyes are still as bright as they were, but now they are so clear that they can almost reflect the future.'}"
    },
