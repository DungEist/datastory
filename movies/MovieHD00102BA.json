        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'So, whenever you feel like you need the time to take care of yourself, Gray Raven... no, all of us will be here waiting for you!', 4: '1', 18: '100001115'}"
    },
    {
        "Id": 91,
        "ActionId": 91,
        "NextActionId": null,
