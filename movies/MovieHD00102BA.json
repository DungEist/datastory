        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You imagine how Liv ran back for you, and your chest suddenly feels heavy.'}"
    },
