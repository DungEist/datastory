        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The mood in the room relaxes after Nanami\\'s wacky \"performance.\" Suddenly, you realize someone is noticeably absent from the scene of jubilation.'}"
    },
