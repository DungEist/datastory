        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Above her flushed cheeks are a pair of teary eyes. Right before her suppressed emotions erupt, Liv attentively collects herself.'}"
    },
    {
        "Id": 82,
        "ActionId": 82,
        "NextActionId": null,
        "Type": 204,
