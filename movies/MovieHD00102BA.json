        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Liv applied for a new one the next day and said we had to take better care of it. I\\'m watering it for her today.', 4: '1', 18: '100001126'}"
    },
