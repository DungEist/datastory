        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Still... don\\'t you ever leave like that again.', 4: '1', 18: '100001108'}"
