        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The only thing that has changed is the sprouting cultivar plant at the center of the desk. Touching the pot, you reckon someone has been watering it regularly based on the moisture level and the weight of the soil.'}"
    },
    {
        "Id": 5,
        "ActionId": 5,
        "NextActionId": null,
