        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'We spent too long on the surface in a previous mission, and the plant died by the time we returned.', 4: '1', 18: '100001125'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
