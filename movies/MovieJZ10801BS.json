        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'Captain Cyril, you have my utmost respect. It is almost impossible to pilot \"Fenrir\" with a human body... Yet you have done it.', 4: '1'}"
