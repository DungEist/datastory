        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'In the all-too-brief time with her human friend, Veronica never had the chance to fully appreciate the complexities of humanity.'}"
