        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'What does one say to a friend who will never return? Serra never told her the appropriate thing to do if she ever found herself in a situation like this.'}"
