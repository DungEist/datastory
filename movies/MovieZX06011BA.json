        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Flowers sway in Veronica\\'s optical modules as her metal fingers touch the moist soil and velvety petals. They feel nothing like the cold metallic objects she\\'s used to, leaving her momentarily disoriented.'}"
    },
    {
        "Id": 55,
