        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Veronica repeats what Serra once said, failing to see how flowers can make anyone happy.'}"
    },
    {
