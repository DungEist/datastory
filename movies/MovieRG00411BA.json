        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staessen', 3: 'There are not just refugees from the Green-Vanostok Line, but also from Central Asia and Western Europe.', 4: '1'}"
