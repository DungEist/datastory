        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You turn around to find that ethereal woman gone. The falling petals and the flying sleeves have vanished, leaving only the decrepit garden and the old tree.'}"
    },
    {
        "Id": 88,
        "ActionId": 88,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It is as if what you saw was just a dream.'}"
    },
    {
        "Id": 89,
        "ActionId": 89,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I saw someone dancing here...', 3: '90'}"
    },
    {
        "Id": 90,
        "ActionId": 90,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'Did you, now? I only saw you here...', 4: '1'}"
    },
