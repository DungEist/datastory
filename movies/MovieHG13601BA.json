        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Hearing you, the Chaofeng Crew behind the Construct takes apart a device by the road that has been imitating a rock.'}"
    },
    {
        "Id": 95,
        "ActionId": 95,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chaofeng', 3: 'Business was poor here at the end of the Golden Age. To attract more tourists, they made a lot of virtual reality environments and performances, as well as bought a lot of puppet dancers from the KCC.', 4: '2'}"
    },
    {
        "Id": 96,
        "ActionId": 96,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chaofeng', 3: '...A lot of them were set up all over this mountain, but the Punishing Virus outbreak happened before they got to use any of them.', 4: '2'}"
    },
    {
        "Id": 97,
        "ActionId": 97,
        "NextActionId": null,
