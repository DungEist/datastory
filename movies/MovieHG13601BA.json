        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chaofeng', 3: 'This might not be the best comparison, but you should think of it like a dream. After all, what was depicted in the projection was long gone already.', 4: '2'}"
