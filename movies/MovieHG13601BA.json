        "Params": "{1: '1', 2: 'Construct', 3: 'Analysis on C-973920 complete...', 4: '1'}"
    },
    {
        "Id": 33,
        "ActionId": 33,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The video data is larger than expected. Even though you have sped up the footage on your terminal, you can still glimpse the extravagance of Kowloong\\'s past.'}"
    },
    {
        "Id": 34,
        "ActionId": 34,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Now, all you can see here is a decrepit building, its shattered green tiles telling this countryside theater\\'s former glory.'}"
    },
    {
        "Id": 35,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The Construct operating the terminal scans through all the data at lightning speed before shaking his head.'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'I\\'ve roughly looked through all readable data...', 4: '1'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'Most of them are promotional materials for Kowloong\\'s Golden Age tourist spots and traditional opera. There\\'s nothing about \"The Cradle\" here.', 4: '1'}"
    },
    {
        "Id": 38,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Let\\'s bring everything back and let the Science Council and the Fuxi Crew analyze it first.', 3: '39'}"
    },
    {
        "Id": 39,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'Understood.', 4: '1'}"
    },
    {
        "Id": 40,
        "ActionId": 40,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'We\\'ve also located the source of the unknown signals Babylonia detected.', 4: '1'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The Construct points at the fallen mechanoids in the footage.'}"
    },
    {
        "Id": 42,
        "ActionId": 42,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'When the Punishing Virus broke out, the human administrators here quickly evacuated from the hill and left behind the worker mechanoids they couldn\\'t destroy in time.', 4: '1'}"
    },
    {
        "Id": 43,
        "ActionId": 43,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'Those distress signals were sent by the malfunctioning mechanoids by mistake. It\\'s not uncommon.', 4: '1'}"
    },
    {
        "Id": 44,
        "ActionId": 44,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
