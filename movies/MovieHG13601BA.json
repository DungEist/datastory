        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chaofeng', 3: 'But all those mechanoids have stopped working. There will be no one playing the morning drums after we\\'re gone.', 4: '1'}"
