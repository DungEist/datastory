        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You turn around to look at the ancient temple one last time. It has stood there for a millennium, and it will still stand in the distant future until time erases it all.'}"
