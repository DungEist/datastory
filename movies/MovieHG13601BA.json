        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Construct', 3: 'Commandant! You\\'re here! I\\'ve been looking for you.', 4: '1'}"
    },
