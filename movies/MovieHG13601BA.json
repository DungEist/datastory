        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'A loud voice suddenly interrupts the quiet moment from behind, dragging you away from the serene scene.'}"
