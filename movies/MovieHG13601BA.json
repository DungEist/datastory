        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nothing unusual is good.', 3: '51', 4: 'It\\'s hard to get used to such easy missions.', 5: '51'}"
    },
