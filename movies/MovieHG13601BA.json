        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Even with all your years carrying out missions in different parts of Earth, you have rarely seen a view as beautiful as this. And you have nothing to do while your team is taking inventory.'}"
    },
    {
        "Id": 67,
        "ActionId": 67,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'So you start heading into the woods, following a path of pebbles.'}"
    },
    {
        "Id": 68,
        "ActionId": 68,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Your intel shows that this used to be an ancient temple inside the tourist spot, but there were barely any visitors at the end of the Golden Age.'}"
    },
    {
        "Id": 69,
        "ActionId": 69,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Passing through the ramshackle doorway, you find an old tree behind a slanted wall. The canopy shakes in the wind, making a rattling sound.'}"
    },
    {
        "Id": 70,
        "ActionId": 70,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It is no longer the season of blooming flowers, yet you find petals falling before you.'}"
    },
    {
        "Id": 71,
        "ActionId": 71,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500640'}"
    },
    {
        "Id": 72,
        "ActionId": 72,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 3: 'Between the falling flowers is an ethereal dancing figure.'}"
    },
    {
        "Id": 73,
        "ActionId": 73,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You have seen the Kemuri dancers perform on the Nighter, but the dance before you is nothing from anything you have seen before.'}"
    },
    {
        "Id": 74,
        "ActionId": 74,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You are stunned as if plunging into a dream older than the Golden Age Kowloong, and your breath slows.'}"
    },
    {
        "Id": 75,
        "ActionId": 75,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The earth and sky fade away, and all you can see is the dancing figure amidst the flowers.'}"
    },
    {
        "Id": 76,
        "ActionId": 76,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '—You have no idea how long has passed.'}"
    },
    {
        "Id": 77,
        "ActionId": 77,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The dancing woman suddenly gazes at you from afar. For a brief moment, she seems to lock eyes with you from behind her dancing fan—'}"
    },
    {
        "Id": 78,
        "ActionId": 78,
        "NextActionId": null,
