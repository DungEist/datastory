        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Construct', 3: 'Right. And we\\'ve finished taking stock, Commandant. We should head down.', 4: '1'}"
