        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chaofeng', 3: 'Although there are no humans stationed here anymore, Kowloong mechanoids still follow their preset commands, patrolling this area and performing the morning drums at dawn without exception.', 4: '1'}"
