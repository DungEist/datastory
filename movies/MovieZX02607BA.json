        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'This is obviously not one of the possible futures Nanami has imagined.'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'She walks speedily among the ruins, scanning every possibly useful data. Searching for a weak signal she detected, she begins to get the lay of the land.'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'All structures in this area look twisted. They are built with large, uniform pyramids, and they all look odd and cold without a hint of humanity.'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
