        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Nanami has never seen a battlefield like this.'}"
    },
    {
        "Id": 4,
        "ActionId": 4,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The ground is charred black under the moonlight. The smell of sulfur spreads in the air as fires slowly burn in the ruins.'}"
    },
    {
        "Id": 5,
        "ActionId": 5,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Dead bodies of humans, Constructs, and mechanoids remain tangled in a fight. Broken mechanoids speak with their stammering voices, \"Free will for machines.\"'}"
    },
    {
        "Id": 6,
        "ActionId": 6,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'But no one here is alive. There is no sign of life.'}"
    },
    {
        "Id": 7,
        "ActionId": 7,
        "NextActionId": null,
