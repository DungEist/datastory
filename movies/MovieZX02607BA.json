        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'As she analyzes, she finds the frontline on this battlefield retreating. Scales of engagements also seem to be reducing.'}"
    },
