        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'I would have asked a technician to track her down any other day, but we really need to do it ourselves now.', 4: '1'}"
    },
