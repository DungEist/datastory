        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'So here\\'s the deal: the Silk Worm Commandant and a Construct member have been engulfed by the rising tide. We\\'ve lost all contact with them.', 4: '1'}"
    },
    {
        "Id": 11,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'I think it might be too late to do anything now...', 4: '1'}"
    },
    {
        "Id": 12,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'One of the two remaining Constructs in their team has been assigned to a different group.', 4: '1'}"
    },
    {
        "Id": 13,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'Things are a little more complicated with the other one. She wasn\\'t there with them when their commandant was attacked, because she had been under treatment for severe injury.', 4: '1'}"
    },
    {
        "Id": 14,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'She regretted not being able to save their commandant, and firmly believes that he is just too injured to contact us and that he\\'s waiting to be rescued.', 4: '1'}"
    },
    {
        "Id": 15,
        "ActionId": 14,
