        "ActionId": 7,
        "NextActionId": 2301,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'Come on. It\\'s got to do with the Red Tide, and we can\\'t really ask the newbies for help. I\\'m sure Gray Raven is a lot more experienced.', 4: '1'}"
    },
    {
        "Id": 8,
