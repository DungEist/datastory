        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Bridget', 3: 'So she refused to be assigned to a different team and later escaped at night. She\\'s also somehow blocked location tracking.', 4: '1'}"
