        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Chrome', 3: 'How do you feel about this, 【kuroname】?', 4: '1'}"
    },
    {
        "Id": 20,
        "ActionId": 20,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Regarding this topic...', 3: '21'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I don\\'t think I have the right to speak on it, unlike you.', 3: '22'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'I must disappoint you, then. I\\'ve never stopped thinking about this, but I have yet to come to a conclusion.', 4: '1'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Then that should be my answer too.', 3: '24'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'I think most people would say it\\'s the latter.', 4: '1'}"
    },
    {
        "Id": 25,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '—The Other.'}"
    },
    {
        "Id": 26,
        "ActionId": 26,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'That was the reason for what transpired earlier today.'}"
    },
    {
        "Id": 27,
        "ActionId": 27,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Are you disappointed?', 3: '28'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'You seem to have asked me something similar not long ago.', 4: '1'}"
    },
    {
        "Id": 29,
        "ActionId": 29,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'No, I\\'m not disappointed. It wasn\\'t unexpected.', 4: '1'}"
    },
    {
        "Id": 30,
        "ActionId": 30,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'I\\'m just... concerned.', 4: '1'}"
    },
    {
        "Id": 31,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Chrome\\'s eyes stay on your face, but he has his gaze on something far more remote, somewhere in the far future.'}"
    },
    {
        "Id": 32,
        "ActionId": 32,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "AniZhuanchangEnd",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The pink hue of the artificial dusk quietly fades to a navy night sky.'}"
    },
    {
        "Id": 33,
        "ActionId": 33,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'You might find my concern ridiculous, but I worry that...', 4: '1'}"
    },
    {
        "Id": 34,
        "ActionId": 34,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'You worry that the world is getting a little colder.', 3: '35'}"
    },
    {
        "Id": 35,
        "ActionId": 35,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You inadvertently speak your mind before Chrome can finish his sentence.'}"
    },
    {
        "Id": 36,
        "ActionId": 36,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'That wasn\\'t what I wanted to say, but... you understand what I was going for.', 4: '1'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'To position Constructs as Others so that people can be indifferent to the casualties of battles...', 4: '1'}"
    },
    {
        "Id": 38,
        "ActionId": 38,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'This war will create new problems for humanity, and it\\'s not the Punishing Virus.', 4: '1'}"
    },
    {
        "Id": 39,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'What is legal and what is moral... the line between them will only get more and more unclear.', 4: '1'}"
    },
    {
        "Id": 40,
        "ActionId": 40,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'When I was confused, if not enraged, by this idea, I came to the realization of something else.', 4: '1'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'Even if the Punishing Virus is eliminated... it\\'s still possible to find more conflicts in the future, leading to more clashes and wars.', 4: '1'}"
    },
    {
        "Id": 42,
        "ActionId": 42,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'He does not specify who will be warring with whom.'}"
    },
    {
        "Id": 43,
        "ActionId": 43,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Even now, it is too cruel to say them out loud.'}"
    },
    {
        "Id": 44,
        "ActionId": 44,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Perhaps.', 3: '45'}"
    },
    {
        "Id": 45,
        "ActionId": 45,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'But I don\\'t feel too pessimistic about it.', 3: '46'}"
    },
    {
        "Id": 46,
        "ActionId": 46,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'Oh?', 4: '1'}"
    },
    {
        "Id": 47,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Some people are thinking about it.', 3: '48'}"
    },
    {
        "Id": 48,
        "ActionId": 48,
