        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Student', 3: 'I\\'m sorry to disturb you... but are you Langston Smith?', 4: '1'}"
