        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'In the end, it is neither you nor Chrome who breaks the silence.'}"
    },
    {
        "Id": 55,
        "ActionId": 55,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'A student shows up out of nowhere, walking toward Chrome slightly awkwardly.'}"
    },
    {
        "Id": 56,
        "ActionId": 56,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You reckon he has to be a student studying here to know the spot you are in.'}"
