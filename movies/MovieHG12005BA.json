    {
        "Id": 57,
        "ActionId": 57,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It seems that Chrome and you have taken up the desk where he usually studies.'}"
    },
    {
