        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The student does not even try to hide his ecstatic expression.'}"
    },
    {
        "Id": 62,
        "ActionId": 62,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Student', 3: 'I just saw you in the distance and I wondered if it was actually you.', 4: '1'}"
    },
    {
        "Id": 63,
        "ActionId": 63,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Student', 3: 'I thought you would be giving a speech on the stage today...', 4: '1'}"
    },
    {
        "Id": 64,
        "ActionId": 64,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Realizing what he is about to say seems inappropriate, the student stops like a stuck cassette tape, his line abruptly ending halfway through. His eyes dart around in a slight panic.'}"
    },
    {
        "Id": 65,
        "ActionId": 65,
        "NextActionId": null,
        "Type": 301,
