        "ActionId": 23,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Qu', 3: 'Yazi, turn on the video system. This will be my first time on the stage in this role and perhaps my last. Here begins the endless night.', 4: '1'}"
    },
