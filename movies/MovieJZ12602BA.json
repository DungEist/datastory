        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Upon the tallest tower on the Nighter, a Construct in a mask is half-kneeling on the floor, her head lowered, waiting quietly for her actual mistress.'}"
    },
    {
        "Id": 5,
        "ActionId": 5,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Soon, the Construct hears her mistress\\' familiar footsteps, and an imposing woman steps forward from the dark hall. The Construct lowers her head further.'}"
    },
    {
        "Id": 6,
        "ActionId": 6,
        "NextActionId": null,
        "Type": 201,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '500150'}"
    },
    {
