        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'However, we cannot promise whether deviation will occur with time or not even if we adopt the more conservative plan.', 4: '1'}"
