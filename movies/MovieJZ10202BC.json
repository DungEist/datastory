        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Even if I can deal with it, our connection is insufficient to meet the requirement of such a high-precision transfer.', 4: '1'}"
