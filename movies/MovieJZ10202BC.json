        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Then I have to tell you that part of her consciousness is in a state of high-entropy, which is kind of chaotic, and very... persistent.', 4: '1'}"
