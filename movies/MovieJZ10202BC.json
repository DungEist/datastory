        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Frankly speaking, we\\'re only able to simulate the human consciousness even with the technology of M.I.N.D.', 4: '1'}"
