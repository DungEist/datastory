        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'I just need her will to be strong enough to last until the end of the war, as for the deviation...', 4: '2'}"
