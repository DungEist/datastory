        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'In this case, I\\'ll carry out a branch operation on her consciousness, and make a copy of it.', 4: '1'}"
