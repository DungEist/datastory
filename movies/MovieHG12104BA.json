        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'No. 21', 3: 'But if I can\\'t fight because of emotions... Even if they want to throw me away, I\\'ll...', 4: '1'}"
