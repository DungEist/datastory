        "ActionId": 51,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'No. 21', 3: 'But I want to have emotions. That way I\\'ll have the scent of a human. I want the scent of humans.', 4: '1'}"
