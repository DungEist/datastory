        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Technician', 3: '...If she\\'s not fully operational... It\\'s going to be the same no matter where she is.', 4: '1'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
        "NextActionId": null,
