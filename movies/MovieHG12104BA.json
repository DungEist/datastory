        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'No. 21', 3: 'Those belong to me. They\\'re mine. I worked so hard to have them.', 4: '1'}"
