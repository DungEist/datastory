        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Technician', 3: 'In terms of training... It seems that you volunteered to work together during the combat simulation. I figured only appointed commandants would do that for their team members.', 4: '1'}"
    },
    {
        "Id": 15,
        "ActionId": 15,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Technician', 3: 'Not to mention... She\\'s a member of the remote link team. No wonder they\\'re so anxious to replace her.', 4: '1'}"
