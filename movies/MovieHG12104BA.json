        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Searching for and putting together these unfamiliar words, No. 21\\'s breath begins to quicken, and she tries her best to express her thoughts.'}"
