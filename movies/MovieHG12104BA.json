        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Technician', 3: 'I don\\'t know if you\\'re too confident or too ignorant for accepting this mission... Let alone sign your name on the liability statement.', 4: '1'}"
    },
    {
        "Id": 22,
        "ActionId": 22,
        "NextActionId": null,
