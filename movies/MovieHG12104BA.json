        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Sorry?', 3: '19'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
        "NextActionId": null,
