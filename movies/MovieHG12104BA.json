        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'That\\'s because I believe in her.', 3: '23', 4: 'I\\'ve linked with a Transcendant. This is nothing.', 5: '24'}"
    },
