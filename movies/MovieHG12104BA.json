        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The technician in charge of calibrating the equipment raises her head from the complex array of equipment and gives you a bewildered look.'}"
