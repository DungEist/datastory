        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The technician\\'s last sentence is quiet, as if an ambivalent sigh to herself, and it gets lost in the rumbling noise of the machines.'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
        "NextActionId": null,
