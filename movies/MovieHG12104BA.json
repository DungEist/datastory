        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'No. 21', 3: 'I don\\'t know what to do. These emotions... are so strange to me.', 4: '1'}"
