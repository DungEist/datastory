        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Technician', 3: 'Nothing. Don\\'t worry about it.', 4: '1'}"
    },
    {
        "Id": 20,
        "ActionId": 20,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Technician', 3: 'Once a Construct\\'s M.I.N.D. begins to deviate in battle, it may cause irreversible cognitive damage to the link team\\'s commandant. I\\'m sure a remote link is no exception.', 4: '1'}"
    },
    {
