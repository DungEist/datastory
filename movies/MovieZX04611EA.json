        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '\"He\" seems to have merely replicated Lee\\'s appearance and fundamental attack strategies, yet to those acquainted with Lee, it would be evident that this imitation is merely skin-deep.'}"
