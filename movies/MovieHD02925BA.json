        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'How about trying a normal greeting next time, like \"hello\"?', 3: '20', 4: '(Walk directly to the fire and sit down)', 5: '22'}"
