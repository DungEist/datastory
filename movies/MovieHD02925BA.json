        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Piercing through the thin clouds, the moonlight falls onto the ground and reflects off the snow, illuminating its surroundings.'}"
