        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'When you\\'ve climbed over the stacked rocks and through the dense forests and arrived at the summit, the view before you suddenly clears up.'}"
