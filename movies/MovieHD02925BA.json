        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Silence... but it doesn\\'t really matter. It was meant as a casual remark, and it\\'s not like you really expect her to change anyway...'}"
