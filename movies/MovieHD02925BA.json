        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The steep terrain levels out, and with no obstacles blocking your view, deep tranquility fills you as you gaze into the distance.'}"
    },
