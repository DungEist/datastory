        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Liv gazes quietly at the view. The city reflects in her gentle eyes. She smooths a strand of wind-blown hair behind her ear, then turns to you with a soft smile.'}"
    },
