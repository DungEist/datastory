        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Even with the sea of people blocking your view, you easily spot the familiar pink silhouette waiting at the meeting spot.'}"
    },
    {
        "Id": 6,
        "ActionId": 6,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'She sits quietly on a bench by the street, perfectly still. Sunlight filters through her soft, straight hair and lights up her fair skin. She almost seems translucent—so translucent that, against the busy backdrop, she stands out even more.'}"
    },
