        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It\\'s not too complicated. The device scans both users, analyzes their features, and combines them with the environment to design a matching pair of chibi figures. It then uses miniature 3D printing to turn them into real badges.'}"
    },
    {
        "Id": 37,
        "ActionId": 37,
