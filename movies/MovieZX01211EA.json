        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'I\\'m... unsure if I\\'ve introduced myself before, but it doesn\\'t matter. As trivial as you all are, you have treated my sister well.', 4: '1'}"
    },
    {
        "Id": 44,
        "ActionId": 40,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'My name is Luna, Lucia\\'s younger sister. I direct the actions of Roland and the other Ascendants.', 4: '1'}"
    },
    {
        "Id": 45,
        "ActionId": 41,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Saying so, Luna lets off a half-smile that sends chills down your spine. This white-clad girl before you looks straight out of a fairytale.'}"
    },
    {
        "Id": 46,
        "ActionId": 42,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Despite standing directly before you, she appears dreamier and more unreal than anything in the world.'}"
    },
    {
        "Id": 47,
        "ActionId": 43,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'As for the other details... I\\'m sure you\\'ve all gleaned information about me through various means.', 4: '1'}"
    },
    {
        "Id": 48,
        "ActionId": 44,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Are you really Lucia\\'s younger sister?', 3: '45', 4: 'All the things the Ascendants have done so far...', 5: '47'}"
    },
    {
        "Id": 49,
        "ActionId": 45,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'Are you asking if Lucia has a younger sister? Or if I\\'m truly her younger sister?', 4: '1'}"
    },
    {
        "Id": 50,
        "ActionId": 46,
        "NextActionId": 48,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'Well, the question to both answers is yes. I... am Lucia\\'s younger sister.', 4: '1'}"
    },
    {
        "Id": 51,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'Some of them acted on their own, but most of them operated on my orders.', 4: '1'}"
