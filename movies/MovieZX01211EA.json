        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'Though... How laughable this is. Me, introducing myself to a commandant...', 4: '1'}"
