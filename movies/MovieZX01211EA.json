        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Lucia—uncertain of which—speaks her name. You and the others realize that this girl in white is the leader of the Ascendants.'}"
    },
    {
        "Id": 43,
        "ActionId": 39,
        "NextActionId": null,
