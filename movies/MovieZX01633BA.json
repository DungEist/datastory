        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Gabriel', 3: 'But—before we continue, I must be certain of one thing.', 4: '1'}"
    },
    {
