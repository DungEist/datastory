        "Params": "{1: '2', 2: '500238', 4: '-500'}"
    },
    {
        "Id": 23,
        "ActionId": 23,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Luna', 3: 'Huaxu... didn\\'t disappoint, to a certain extent.', 4: '2'}"
    },
    {
        "Id": 24,
        "ActionId": 24,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'It\\'s because of Huaxu that I\\'ve obtained the secret behind the Inver-Device. To label that level of technology as highly-classified... Humans are so absurd sometimes.', 4: '2'}"
    },
    {
        "Id": 25,
        "ActionId": 25,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Gabriel', 3: 'Huaxu\\'s failure has not been unexpected. I have never put my faith in an outsider, which is why I have prepared an alternative.', 4: '1'}"
    },
    {
        "Id": 26,
        "ActionId": 26,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'Is that what you\\'ve been hiding underneath the Core Area?', 4: '2'}"
    },
    {
        "Id": 27,
        "ActionId": 27,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Gabriel', 3: '...Of course, nothing escapes Miss Luna.', 4: '1'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'Gabriel, you aren\\'t skilled enough to hide things from me yet.', 4: '2'}"
    },
    {
        "Id": 29,
        "ActionId": 29,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Luna', 3: 'I don\\'t care how you do it. I only want results.', 4: '2'}"
    },
    {
        "Id": 30,
        "ActionId": 30,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Gabriel', 3: 'Understood.', 4: '1'}"
    },
    {
        "Id": 31,
