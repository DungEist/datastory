        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'I thought so too. Maybe it\\'s a compiling error from reordering memory files.', 4: '1'}"
