        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'H-huh... really? I can\\'t seem to find the relevant logs... Unless you\\'re toying with me, Commandant?', 4: '1'}"
    },
