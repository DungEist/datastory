        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'Though, to be honest, the more I try to adapt to the old me, the more distant I feel from her... hence, these strange actions I\\'m prone to.', 4: '1'}"
    },
    {
