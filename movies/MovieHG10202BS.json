        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'It\\'s hard to explain, but touching your hand seemed to accelerate this frame\\'s heartbeat... Well, \"heartbeat\" might be an inaccurate term.', 4: '1'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'That is, my M.I.N.D. was just overwhelmed by a wave of unknown fluctuations that didn\\'t match with the memory data I have.', 4: '1'}"
    },
    {
        "Id": 12,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'These fluctuations did exist in the data from the previous frame, but they were flagged as errors and dismissed...', 4: '1'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: '...But I didn\\'t expect the last flux to be so volatile. What came over me? Why did I suggest something like holding hands...?', 4: '1'}"
    },
    {
        "Id": 14,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lucia', 3: 'I don\\'t think the old me ever said anything like that, right Commandant?', 4: '1'}"
    },
    {
        "Id": 15,
        "ActionId": 102,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'I think she did.', 3: '15', 4: 'Don\\'t think so...?', 5: '16'}"
    },
    {
        "Id": 16,
        "ActionId": 15,
        "NextActionId": 17,
        "Type": 301,
        "IsBlock": null,
