        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Hassen', 3: 'The ACA is a special faction that built their empire on the train. They combined Cosmos Industries\\' Central Purification Filter technology with a train and transformed it into a mobile Akdilek purification system.', 4: '2'}"
    },
    {
