        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'This stage has witnessed her glory and listened to her when she was lost.'}"
    },
    {
        "Id": 18,
        "ActionId": 18,
