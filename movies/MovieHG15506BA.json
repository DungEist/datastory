        "Params": "{1: '1', 2: 'Selena', 3: 'I once spoke of war with careless admiration, romanticizing humanity\\'s brilliance while arrogantly claiming to \"depict the real world\" through what I called \"hellish trials.\"', 4: '1', 18: '100008942'}"
    },
