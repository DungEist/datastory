        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Selena', 3: 'It\\'s these... stories I\\'ve recorded myself.', 4: '1', 18: '100008936'}"
