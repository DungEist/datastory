        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'A blush spreads across her cheeks as Selena picks it up from the floor, but you still manage to read the first line.'}"
    },
    {
        "Id": 30,
        "ActionId": 30,
        "NextActionId": null,
