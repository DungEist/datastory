        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Selena', 3: 'I want to... be someone who listens, someone who writes those songs down.', 4: '1', 18: '100008944'}"
