        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Illusion and reality intertwine. She has witnessed countless joys and sorrows from within the Red Tide.'}"
