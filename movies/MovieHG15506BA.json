        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Selena', 3: 'It\\'s been so long. This place brings back memories...', 4: '1', 18: '100008926'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
        "NextActionId": null,
