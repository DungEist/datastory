        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Selena', 3: 'Kind of.', 4: '1', 18: '100008927'}"
    },
    {
        "Id": 20,
        "ActionId": 20,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Selena', 3: 'Sounds fun, but that\\'s not why I asked you here today.', 4: '1', 18: '100008928'}"
    },
    {
