        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Selena', 3: 'With the power of the Transcendant and the Red Tide, I\\'ve read so many stories... ones that have vanished from the world.', 4: '1', 18: '100008937'}"
    },
    {
