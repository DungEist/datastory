        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Selena', 3: 'Lately, I\\'ve been compiling and preserving every story I could find.', 4: '1', 18: '100008938'}"
