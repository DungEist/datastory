        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Selena', 3: 'But... this isn\\'t what I wanted to show you this time.', 4: '1', 18: '100008935'}"
    },
    {
