        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Her thoughts take root in the soil. She has heard cries of agony and Auguries of Innocence.'}"
