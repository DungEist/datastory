        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Do you want to revisit the memories?', 3: '19', 4: 'Do you want to see WGAA\\'s new plays?', 5: '20'}"
    },
    {
        "Id": 19,
        "ActionId": 19,
        "NextActionId": 21,
