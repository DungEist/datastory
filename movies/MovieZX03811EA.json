        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Lee', 3: 'Purifying Force isn\\'t too far from where we are now, Commandant.', 4: '1'}"
    },
    {
        "Id": 83,
        "ActionId": 83,
