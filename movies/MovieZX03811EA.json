        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Kurono\\'s research base, stationed by their secret force.', 3: '104'}"
    },
    {
        "Id": 104,
        "ActionId": 104,
        "NextActionId": null,
