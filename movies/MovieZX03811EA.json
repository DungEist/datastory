        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Would it be possible for you to get your hands on more of this data?', 4: '2'}"
    },
    {
        "Id": 101,
        "ActionId": 101,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'It should all be sitting inside Utopia.', 3: '102'}"
    },
    {
