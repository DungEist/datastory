        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'They said Utopia had promised them a future where they wouldn\\'t have to worry about food or anything else—so long as they agreed to become a part of this place.', 4: '1'}"
    },
    {
        "Id": 47,
        "ActionId": 47,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'I went through the file myself. Many of them are runaways from some of the other factions, some are being hunted down, some are registered as dead in official records, and others came because they wanted a stable life...', 4: '1'}"
    },
    {
        "Id": 48,
        "ActionId": 48,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Lee passes you the file before casting a look at Echo, who\\'s doing her best to convince the Constructs and humans to leave.'}"
    },
    {
        "Id": 49,
        "ActionId": 49,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'I\\'m afraid she isn\\'t going to get the reaction she wants from them.', 4: '1'}"
    },
    {
        "Id": 50,
        "ActionId": 50,
        "NextActionId": null,
        "Type": 202,
