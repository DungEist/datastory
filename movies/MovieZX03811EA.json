        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It\\'s been so long since you last saw \"her\"...'}"
    },
    {
        "Id": 128,
        "ActionId": 128,
