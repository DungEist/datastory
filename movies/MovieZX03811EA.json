        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Echo volunteers to go on a patrol. After she leaves, Lee stops what he\\'s doing and looks this way.'}"
    },
    {
        "Id": 81,
        "ActionId": 81,
        "NextActionId": null,
        "Type": 201,
