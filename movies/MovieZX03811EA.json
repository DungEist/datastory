        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Those who are after the \"Kurono test subject\"?', 3: '84'}"
    },
    {
        "Id": 84,
        "ActionId": 84,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Right. Issarius is leading the team. I tried muddying the waters with some misinformation, but there is no telling how long that can keep them stalled.', 4: '1'}"
    },
    {
        "Id": 85,
        "ActionId": 85,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Something that strikes me as weird, though, is that there is another force trying to muddy the waters, too. We won\\'t be found anytime soon, but I\\'m having no luck identifying the other force.', 4: '1'}"
    },
    {
        "Id": 86,
        "ActionId": 86,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Their purpose is still unclear, and if they ever find...', 4: '1'}"
    },
    {
        "Id": 87,
        "ActionId": 87,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Don\\'t worry.', 3: '88'}"
    },
    {
        "Id": 88,
        "ActionId": 88,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You put together the information you\\'ve gathered from Echo\\'s deep M.I.N.D. and send it to Asimov in an encrypted format.'}"
    },
    {
        "Id": 89,
        "ActionId": 89,
        "NextActionId": null,
