        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'And according to this log they\\'ve kept, most of these Constructs and humans... came here voluntarily.', 4: '1'}"
    },
    {
        "Id": 45,
        "ActionId": 45,
        "NextActionId": null,
