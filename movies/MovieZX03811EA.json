        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The Task Force squad you\\'ve reached out to earlier has arrived. With their help, the Constructs and humans board, in groups, the transport vehicles that take them to the nearest conservation area.'}"
    },
    {
        "Id": 80,
        "ActionId": 80,
