        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Asimov', 3: 'Utopia?', 4: '2'}"
    },
    {
        "Id": 103,
        "ActionId": 103,
        "NextActionId": null,
