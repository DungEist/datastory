        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Commandant, I\\'ve roped up all those Constructs who claim they are from Aurora Squadron. And to keep us hidden, I\\'ve intercepted the signals around here.', 4: '1'}"
    },
    {
        "Id": 44,
        "ActionId": 44,
