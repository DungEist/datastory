        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Vonnegut', 3: 'Luna is currently blocked by the Ascension-Network. She has lost the power of an agent, but not her status as one... It is a most peculiar situation.', 4: '1'}"
    },
    {
        "Id": 94,
        "ActionId": 94,
