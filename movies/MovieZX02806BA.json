        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vonnegut', 3: 'And now, people have restarted the zero-point reactor there, using it to create the \"Omega Weapons\" that are lethal to the Punishing Virus.', 4: '2'}"
    },
