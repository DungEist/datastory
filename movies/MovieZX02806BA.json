        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Finding a burnt tree trunk, Roland sits down and tears off a piece of blank paper from the book. After some thought, he quietly places a small object above the paper before folding it...'}"
    },
    {
        "Id": 11,
        "ActionId": 11,
