        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Cinderelik', 3: 'Mister won\\'t lie to you. If he says she\\'s on the Moon, then Luna is on the Moon. As for how you get there...', 4: '1'}"
    },
    {
        "Id": 68,
        "ActionId": 68,
