        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'A girl walks out of the shadow, curious about how Roland keeps folding the paper in his hand.'}"
    },
