        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Vonnegut', 3: 'An unexpected byproduct, I\\'d say. It\\'s not very intelligent, but it can tell friends from foes when controlled. That\\'s good enough.', 4: '1'}"
    },
