        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Roland', 3: 'Oh? Well, then, I should probably go and claim it quickly.', 4: '1'}"
    },
