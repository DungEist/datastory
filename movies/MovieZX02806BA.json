        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The man facing away from Cinderelik is looking at the night sky, seemingly deep in thought. Hearing her, he nods and turns around.'}"
    },
    {
        "Id": 41,
        "ActionId": 41,
