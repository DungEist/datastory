        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vonnegut', 3: 'Her survival has certainly given humans an opportunity to cheat, which would hinder the Ascension-Network. That is why I want you to rescue Luna from the humans. And if she can\\'t be saved...', 4: '1'}"
    },
    {
        "Id": 95,
        "ActionId": 95,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Vonnegut nods at Cinderelik, signaling her to take out the prepared sealed case.'}"
    },
    {
        "Id": 96,
        "ActionId": 96,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Vonnegut', 3: 'Luna cannot be allowed to exist—not her body, not her mind, not even the idea of her.', 4: '1'}"
    },
    {
        "Id": 97,
        "ActionId": 97,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Roland takes the case and opens it. Inside, he finds a container that is filled with crimson liquid, a slice of constantly-mutating pale flesh submerged within.'}"
