        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Roland turns around and looks at the scorched earth behind him. Perhaps a group of Hetero-Creatures or some powerful Corrupted swept across this crimson land, destroying everything but this small notebook.'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
