        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Voodoo', 3: 'There is an intact space shuttle underneath the ruins of that city. Those people are trying to board it to return to Babylonia—I believe that model is capable of traveling to the Moon.', 4: '1'}"
    },
    {
        "Id": 89,
        "ActionId": 89,
