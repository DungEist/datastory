        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Roland\\'s gaze shifts just a little bit, his expression remaining the same as if he is performing the role he has always been playing with ease—someone whose thought is inscrutable.'}"
    },
    {
        "Id": 28,
        "ActionId": 28,
