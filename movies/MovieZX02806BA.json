        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Roland', 3: 'I see. If we can get to the ship first, we can easily go for a joyride to the Moon.', 4: '1'}"
