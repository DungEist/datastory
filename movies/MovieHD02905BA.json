        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'As the card falls, the \"bystanders\" who have been waiting behind suddenly gather around. Someone shouts \"Three, two, one\"\\' and everyone shouts blessings together.'}"
    },
    {
        "Id": 46,
        "ActionId": 46,
