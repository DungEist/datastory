        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The card has a completely different design from that of the others, with a small cake with candles in all sorts of colors painted in the middle.'}"
