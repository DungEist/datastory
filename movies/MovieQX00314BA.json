        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Chrome', 3: 'Isn\\'t alcohol supposed to mess with your head? I hate the feeling of losing control.', 4: '1'}"
