        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Before you can take the glass away, Chrome reaches out too, holding it steady.'}"
    },
    {
