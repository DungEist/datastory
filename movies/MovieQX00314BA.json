        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Under the warm yellow light, Chrome\\'s hair shimmers like champagne. As always, he sits perfectly upright, even at the bar.'}"
