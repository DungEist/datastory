        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Selene', 3: 'These thoughts are meaningless, overcomplicated, and redundant. The Ascension-Network has no use for such consciousnesses—they\\'re dead weight.', 4: '1'}"
    },
