        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Agent Zero', 3: 'This isn\\'t a normal Hetero Tower! Something\\'s wrong here—can\\'t you feel it? We\\'re losing power.', 4: '2'}"
