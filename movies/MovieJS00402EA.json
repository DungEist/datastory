        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It was a handwritten letter—which was a rarity, given that people rarely wrote letters by hand in the Golden Age.'}"
