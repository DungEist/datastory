        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'You sit beside Haicma, taking in the scattered graffiti across the canvas. Most appear in pairs, and some even have hearts circling the names.'}"
