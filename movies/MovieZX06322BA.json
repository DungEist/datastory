        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Zack', 3: 'To contain the virus, I was left with no choice but to detonate the city alongside a handful of loyal companions... It was not the Punishing Virus that destroyed Sophiasburgh. It was humanity, tearing itself apart.', 4: '18'}"
    },
    {
