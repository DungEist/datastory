        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Zack', 3: 'It is this fractured, squabbling world that is the true folly! Rosetta, 【kuroname】, have you never pondered what it would truly take to defeat the Punishing Virus?', 4: '1'}"
    },
    {
        "Id": 31,
        "ActionId": 31,
        "NextActionId": null,
        "Type": 302,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: '...And you have what it takes?', 3: '32', 4: 'I strive for that goal every single day.', 5: '36'}"
    },
    {
        "Id": 32,
        "ActionId": 32,
        "NextActionId": null,
