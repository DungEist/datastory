        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Zack', 3: 'It is these disparate, fragmented memetics that prevent unified thought and scatter humanity\\'s strength. Conversely, if we forge a single, perfected paradise, we can erase these useless memetics.', 4: '1'}"
