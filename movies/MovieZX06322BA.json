        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Zack', 3: 'Of course. 【kuroname】, you have seen countless battlefields.', 4: '1'}"
    },
    {
        "Id": 34,
        "ActionId": 34,
        "NextActionId": null,
        "Type": 204,
