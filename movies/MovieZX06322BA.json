        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Rosetta', 3: 'I will not surrender, nor will I partake in this foolish delusion of \"Amalgamation\"!', 4: '1'}"
    },
    {
