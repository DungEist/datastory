        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Zack', 3: 'Rosetta, 【kuroname】. After fighting your way through Sophiasburgh, you must have learned of the tragedy that unfolded there.', 4: '1'}"
    },
    {
        "Id": 54,
        "ActionId": 54,
