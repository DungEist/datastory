        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Zack', 3: 'Your actions demonstrate resolve, but merely \"responding to threats\" is not enough!', 4: '1'}"
    },
    {
