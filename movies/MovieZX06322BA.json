        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Zack', 3: 'When the Punishing Virus hit, panic consumed the people. The elite and the common folk turned on each other for scraps of resources. Social order disintegrated.', 4: '1'}"
    },
