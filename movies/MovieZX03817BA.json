        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'A team of Task Force has been ordered to head down as support. Won\\'t be long before Dark Aries arrives as well.', 4: '2'}"
    },
    {
        "Id": 10,
        "ActionId": 10,
        "NextActionId": null,
