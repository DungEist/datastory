        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Wells', 3: 'We\\'ve had all the information compiled. Aurora Squadron\\'s main force is in the central flying fortress, but it\\'s going to take us a while to break through the line of defense formed by all the smaller flying fortresses surrounding it.', 4: '1'}"
    },
    {
