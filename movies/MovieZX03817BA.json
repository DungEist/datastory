        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'Say what\\'s on your mind, Wells. You\\'ve been quiet for far too long.', 4: '2'}"
