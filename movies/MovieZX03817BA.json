        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'That Construct by the name Echo... who\\'s also the Kurono test subject, has made her way into one of the flying fortresses.', 4: '2'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
        "NextActionId": null,
