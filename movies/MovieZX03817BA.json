        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'We\\'ve constantly seen small flying vessels fall, and our guess is that it\\'s the doing of said Construct.', 4: '2'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
        "NextActionId": null,
