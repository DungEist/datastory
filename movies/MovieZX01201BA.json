        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Lee', 3: 'Well, in that case, let\\'s talk about something that\\'s on top of everyone\\'s mind. You\\'re absolutely sure we\\'re headed for that \"city,\" right?', 4: '2'}"
    },
    {
        "Id": 39,
