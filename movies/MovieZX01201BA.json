        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Are there still people living there?', 3: '39', 4: 'What kind of place is it?', 5: '40'}"
    },
    {
        "Id": 41,
        "ActionId": 39,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Yazi', 3: 'We may have been gone for a while, but according to the details in the other plan, Kowloong is built to last.', 4: '1'}"
