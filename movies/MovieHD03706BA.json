        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nanami', 3: 'It\\'s love! Love can overcome fear, and even transcend gravity and time itself!', 4: '1'}"
    },
    {
        "Id": 27,
