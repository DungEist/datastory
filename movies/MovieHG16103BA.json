        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Liv', 3: 'What a strange feeling... When you opened the door for me just now, I almost thought I was back in the Gray Raven lounge.', 4: '1', 18: '100013081'}"
    },
    {
        "Id": 42,
        "ActionId": 42,
        "NextActionId": null,
