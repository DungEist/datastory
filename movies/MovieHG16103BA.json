        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Maiden', 3: 'Oh, you misunderstand... These little ones are not just paper scraps. They were once lovely creatures, wounded and lost.', 4: '1', 18: '100013078'}"
    },
    {
