        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'It\\'s this little cabin out back. My dad actually used to play in it when he was a kid, too.', 4: '1', 18: '100013088'}"
    },
    {
        "Id": 61,
        "ActionId": 61,
        "NextActionId": null,
