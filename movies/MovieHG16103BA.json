        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'But then, the winds began to blow, ever stronger than before, tearing across the land. They snatched the paper scraps, hurling them high into the sky and over the mountains far away.'}"
    },
    {
        "Id": 21,
        "ActionId": 21,
