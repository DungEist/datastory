        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'So what brought you back to this house now?', 3: '62'}"
    },
    {
        "Id": 62,
        "ActionId": 62,
        "NextActionId": null,
        "Type": 202,
        "IsBlock": null,
