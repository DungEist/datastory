        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: '...I know. I started feeling this way after Mom passed away. Dad remarried, and they built a new life here...', 4: '1', 18: '100013086'}"
    },
    {
        "Id": 56,
        "ActionId": 56,
        "NextActionId": null,
        "Type": 204,
        "IsBlock": null,
