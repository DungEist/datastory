        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Maiden', 3: 'They are in pain. I cannot bear to let them cry.', 4: '1', 18: '100013079'}"
