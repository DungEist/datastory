        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: '...Back to the place that held no warmth for her childhood?'}"
    },
    {
        "Id": 64,
        "ActionId": 64,
        "NextActionId": null,
