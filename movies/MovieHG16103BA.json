        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: '8'}"
    },
    {
        "Id": 57,
        "ActionId": 57,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Liv', 3: 'Even Calliope, the maid Mom hired to look after me, left too... I just... prefer to spend more time at my secret base instead.', 4: '1', 18: '100013087'}"
    },
    {
        "Id": 58,
        "ActionId": 58,
        "NextActionId": null,
