        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Day by day, the luminous wings upon her back dwindled. Her very form began to thin, becoming translucent against the sun...'}"
