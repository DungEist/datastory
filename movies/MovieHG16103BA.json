        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The maiden struggled to her feet, swaying as a frail leaf in the gale, straining to follow them.'}"
