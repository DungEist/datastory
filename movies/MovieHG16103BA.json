        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'With every creature she folded, tiny specks of light escaped from between her fingers, flowing into the new creation.'}"
    },
