        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Unable to bear the sight of her helplessness, the little gray raven plunged into the fierce wind, flying higher and farther than it ever had, chasing the lost scraps to bring them back to her.'}"
    },
