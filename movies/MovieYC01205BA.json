        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Corrupted remains are scattered all over the ground. Watanabe tells his men to salvage the still usable supplies, and he peers at Kowloong Corp in the distance.'}"
    },
    {
        "Id": 10,
        "ActionId": 9,
