        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The sight is grandiose and consuming, but to Watanabe it borders on a sickly obsession. Home is comfort, but shelter too deep, and it becomes a prison.'}"
    },
