        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'John', 3: 'You asked for me, Commander?', 4: '2'}"
    },
    {
        "Id": 6,
        "ActionId": 5,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The files lie spread out on the desk. Besides the routine paper, there\\'s also a brief report outlining resort findings.'}"
    },
    {
        "Id": 7,
        "ActionId": 6,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It\\'s the first time the military has recently received a successful report in Construct modification.'}"
    },
    {
        "Id": 8,
        "ActionId": 7,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'Chrome.', 4: '3'}"
    },
    {
        "Id": 9,
        "ActionId": 8,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'I don\\'t see this name in the roster files of Babylonian members.', 4: '3'}"
    },
    {
        "Id": 10,
        "ActionId": 9,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'The refitting was a success. A perfect success.', 4: '3'}"
    },
    {
        "Id": 11,
        "ActionId": 10,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'This was the first experiment ever made on the specialized Inver-Device. Smith Langston... Ah, your son is indeed talented.', 4: '3'}"
    },
    {
        "Id": 12,
        "ActionId": 11,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'John', 3: '...', 4: '2'}"
    },
    {
        "Id": 13,
        "ActionId": 12,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'Still, be it the blade or the one who wields it, their fates are one and the same on the battlefield.', 4: '3'}"
    },
    {
        "Id": 14,
        "ActionId": 13,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'What differences are there, after all?', 4: '3'}"
    },
    {
        "Id": 15,
        "ActionId": 14,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'As long as we win.', 4: '3'}"
    },
    {
        "Id": 16,
        "ActionId": 15,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'Still, I find your tradition to pass down the family name instead of the bloodline quite admirable.', 4: '3'}"
    },
    {
        "Id": 17,
        "ActionId": 16,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'If only everyone were like you and I... practical, instead of full of flights of fancy... we\\'d have reclaimed Earth already.', 4: '3'}"
    },
    {
        "Id": 18,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'Anyway, now that we have live data on specialized Inver-Devices, the council will have to shut up and continue providing us resources.', 4: '3'}"
    },
    {
        "Id": 19,
        "ActionId": 18,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'Well, enough of that boring chitchat. The first refitting condition—', 4: '3'}"
    },
    {
        "Id": 20,
        "ActionId": 19,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "AniZhuanchangBegin",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Nikola', 3: 'Congratulations on your promotion, John Smith.', 4: '3'}"
    },
