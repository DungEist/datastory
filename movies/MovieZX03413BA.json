        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'It will take a long time for humanity to ease the pains that emerge from the transition between old and new orders.'}"
    },
