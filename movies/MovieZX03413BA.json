        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'Self-modification is destined to be a painful path. To change humanity itself means that all the social structures, ethics and morals built upon the biological foundation of humans will be reshuffled.'}"
    },
    {
        "Id": 4,
        "ActionId": 4,
