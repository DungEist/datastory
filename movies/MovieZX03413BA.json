        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Research Assistant', 3: 'But they will never have a second chance.', 4: '1'}"
