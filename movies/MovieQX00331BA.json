        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noan', 3: 'They collect their raw materials from specific spots, then hit up artisans to work their magic. Their stores always look like this, a mishmash of goodies but all made from the same materials.', 4: '1'}"
    },
    {
        "Id": 16,
        "ActionId": 16,
        "NextActionId": null,
