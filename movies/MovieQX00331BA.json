        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'He points to a \"mixed\" flower shop ahead. They\\'ve got everything—fresh blooms, potted plants, and those fancy preserved flower crafts.'}"
    },
    {
        "Id": 15,
        "ActionId": 15,
        "NextActionId": null,
