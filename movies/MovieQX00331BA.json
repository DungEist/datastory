        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Were you like this?', 3: '17'}"
    },
    {
        "Id": 17,
        "ActionId": 17,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": "DialogDisable",
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Noan', 3: 'Yeah, but flowers weren\\'t exactly essentials, so they only traded for the bare minimum. When I was a kid, I used to sneak off to the ruins hunting for wild roses. Back then, I was just a budding merchant at heart.', 4: '1'}"
    },
    {
