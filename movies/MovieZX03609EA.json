        "BeginAnim": "DialogEnable",
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The transport craft that Vera\\'s team brought is now filled with people. The majority are elders and children, with only a few individuals being carried on stretchers.'}"
    },
    {
        "Id": 13,
        "ActionId": 13,
        "NextActionId": null,
