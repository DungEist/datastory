        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The shop once again falls silent when the shop attendant is gone. The heavy wooden door blocks out the bustling noise from the street outside, with only gentle music flowing like water through the space.'}"
    },
    {
        "Id": 53,
        "ActionId": 53,
