        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The small shop is decorated in deep, antiquated tones. Through the glass windows, you can see the interior filled with an assortment of miscellaneous items.'}"
