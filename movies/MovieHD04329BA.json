        "Id": 45,
        "ActionId": 45,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'As far as you can see, the shop is filled with old objects from the Golden Age. Despite how old they must be, everything has been polished to immaculate cleanliness.'}"
    },
    {
        "Id": 46,
        "ActionId": 46,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'A shop attendant in classical formal attire emerges from behind the shop and greets you both with a gentle bow. You feel like you\\'ve just stepped into a warm dream of bygone days.'}"
    },
    {
        "Id": 47,
        "ActionId": 47,
