        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'This place feels like a beautiful dream coming straight out of the Golden Age, exactly as she said.'}"
    },
