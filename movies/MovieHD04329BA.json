        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{3: 'The words \"Echoes of the Past\" on the sign stand out prominently, with a smaller line underneath reading \"Experience life in the Golden Age\".'}"
    },
