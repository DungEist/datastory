        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{1: '1', 2: 'Staff', 3: 'Welcome to \"Echoes of the Past\". We specialize in providing authentic everyday experiences from the Golden Age.', 4: '1'}"
    },
    {
        "Id": 49,
        "ActionId": 49,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staff', 3: 'There is not one bit of simulation technology in the things you see here—everything is genuinely from the Golden Age.', 4: '1'}"
    },
    {
        "Id": 50,
        "ActionId": 50,
        "NextActionId": null,
        "Type": 301,
        "IsBlock": null,
        "IsEnd": null,
        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Staff', 3: 'Please feel free to explore at your leisure. If you need anything, I\\'ll just be in the room in the back.', 4: '1'}"
    },
