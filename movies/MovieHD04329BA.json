        "BeginAnim": null,
        "EndAnim": null,
        "BeginDelay": null,
        "EndDelay": null,
        "Params": "{2: 'Echo', 3: 'People usually like to play music out of their terminals nowadays because you can play at the speed you want and switch songs whenever you like.', 4: '1'}"
